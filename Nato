-- SPEED SLIDERS พร้อมชื่อและค่าเรียลไทม์
local function makeSlider(y, max, default, callback, name)
    local label = Instance.new("TextLabel", panel)
    label.Size = UDim2.new(0,200,0,20)
    label.Position = UDim2.new(0,10,y-20)
    label.TextColor3 = Color3.fromRGB(200,200,255)
    label.BackgroundTransparency = 1
    label.Font = Enum.Font.Gotham
    label.TextSize = 13

    local val = default
    label.Text = name .. ": " .. val

    local track = Instance.new("Frame", panel)
    track.Size = UDim2.new(1,-20,0,8)
    track.Position = UDim2.new(0,10,0,y)
    track.BackgroundColor3 = Color3.fromRGB(50,50,75)
    Instance.new("UICorner", track).CornerRadius = UDim.new(1,0)

    local fill = Instance.new("Frame", track)
    fill.Size = UDim2.new(default/max,0,1,0)
    fill.BackgroundColor3 = Color3.fromRGB(90,255,100)
    Instance.new("UICorner", fill).CornerRadius = UDim.new(1,0)

    local knob = Instance.new("TextButton", track)
    knob.Size = UDim2.new(0,18,0,18)
    knob.Position = UDim2.new(default/max,-9,0.5,-9)
    knob.BackgroundColor3 = Color3.fromRGB(220,220,255)
    knob.Text = ""
    Instance.new("UICorner", knob).CornerRadius = UDim.new(1,0)

    local dragging = false
    knob.MouseButton1Down:Connect(function() dragging = true end)
    UserInputService.InputEnded:Connect(function(i) dragging = false end)
    UserInputService.InputChanged:Connect(function(i)
        if dragging then
            local r = math.clamp((i.Position.X-track.AbsolutePosition.X)/track.AbsoluteSize.X,0,1)
            val = math.floor(r*max)
            fill.Size = UDim2.new(r,0,1,0)
            knob.Position = UDim2.new(r,-9,0.5,-9)
            label.Text = name .. ": " .. val
            callback(val)
        end
    end)
end

makeSlider(50,20000,100,function(v) tweenSpeed=v end, "Farm Speed")
