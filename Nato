local Players           = game:GetService("Players")
local CollectionService = game:GetService("CollectionService")
local RunService        = game:GetService("RunService")
local VirtualUser       = game:GetService("VirtualUser")

local player = Players.LocalPlayer
if not player.Character then player.CharacterAdded:Wait() end

local running = false
local currentTarget = nil

-- 🔥 Anti AFK
player.Idled:Connect(function()
    VirtualUser:Button2Down(Vector2.new(0,0), workspace.CurrentCamera.CFrame)
    task.wait(1)
    VirtualUser:Button2Up(Vector2.new(0,0), workspace.CurrentCamera.CFrame)
end)

-- Root
local function getHRP()
    local char = player.Character
    return char and (char:FindFirstChild("HumanoidRootPart") or char.PrimaryPart)
end

-- 🔥 กันผู้เล่น
local function isPlayerNear(pos, radius)
    for _, plr in ipairs(Players:GetPlayers()) do
        if plr ~= player and plr.Character then
            local hrp = plr.Character:FindFirstChild("HumanoidRootPart")
            if hrp and (hrp.Position - pos).Magnitude < radius then
                return true
            end
        end
    end
    return false
end

-- หา food
local function getClosestFood()
    local hrp = getHRP()
    if not hrp then return nil end

    local best, bestDist = nil, math.huge

    for _, food in CollectionService:GetTagged("Food") do
        if not food or not food.Parent then continue end

        local pos = (food:IsA("Model") and food:GetPivot().Position)
                 or (food:IsA("BasePart") and food.Position)

        if pos and not isPlayerNear(pos, 50) then
            local d = (hrp.Position - pos).Magnitude
            if d < bestDist then
                bestDist = d
                best = food
            end
        end
    end

    return best
end

-- 🔥 Heartbeat mover (ลื่น ไม่ค้าง)
RunService.Heartbeat:Connect(function()
    if not running then return end

    local hrp = getHRP()
    if not hrp then return end

    -- หาเป้าใหม่
    if not currentTarget or not currentTarget.Parent then
        currentTarget = getClosestFood()
        return
    end

    local pos =
        (currentTarget:IsA("Model") and currentTarget:GetPivot().Position)
        or (currentTarget:IsA("BasePart") and currentTarget.Position)

    if not pos then
        currentTarget = nil
        return
    end

    -- 🔥 กันผู้เล่น
    if isPlayerNear(pos, 40) then
        currentTarget = nil
        return
    end

    local diff = pos - hrp.Position
    local dist = diff.Magnitude

    -- ถึงแล้ว
    if dist < 10 then
        hrp.CFrame = CFrame.new(pos)
        currentTarget = nil
        return
    end

    -- 🔥 speed 200
    local step = math.min(200, dist)
    hrp.CFrame = CFrame.new(hrp.Position + diff.Unit * step)
end)

-- 🎨 GUI ดำขาว
local gui = Instance.new("ScreenGui", player:WaitForChild("PlayerGui"))
gui.ResetOnSpawn = false

local frame = Instance.new("Frame", gui)
frame.Size = UDim2.new(0,240,0,150)
frame.Position = UDim2.new(0.5,-120,0.5,-75)
frame.BackgroundColor3 = Color3.fromRGB(15,15,15)
frame.Active = true
frame.Draggable = true
Instance.new("UICorner", frame).CornerRadius = UDim.new(0,12)

local stroke = Instance.new("UIStroke", frame)
stroke.Color = Color3.fromRGB(255,255,255)
stroke.Thickness = 1

local title = Instance.new("TextLabel", frame)
title.Size = UDim2.new(1,0,0,40)
title.BackgroundTransparency = 1
title.Text = "Food Collector"
title.TextColor3 = Color3.fromRGB(255,255,255)
title.Font = Enum.Font.GothamBold
title.TextSize = 16

local status = Instance.new("TextLabel", frame)
status.Position = UDim2.new(0,0,0,40)
status.Size = UDim2.new(1,0,0,25)
status.BackgroundTransparency = 1
status.Text = "Status: Idle"
status.TextColor3 = Color3.fromRGB(200,200,200)

local function setStatus(t)
    status.Text = "Status: "..t
end

local function makeBtn(text,pos,color)
    local b = Instance.new("TextButton", frame)
    b.Size = UDim2.new(0,90,0,35)
    b.Position = pos
    b.Text = text
    b.BackgroundColor3 = color
    b.TextColor3 = Color3.new(1,1,1)
    b.Font = Enum.Font.GothamBold
    Instance.new("UICorner", b).CornerRadius = UDim.new(0,8)
    return b
end

local startBtn = makeBtn("START", UDim2.new(0,20,0,90), Color3.fromRGB(40,40,40))
local stopBtn  = makeBtn("STOP",  UDim2.new(0,130,0,90), Color3.fromRGB(80,80,80))

-- loop แสดงสถานะ
local function loop()
    while running do
        if not currentTarget then
            setStatus("Searching...")
        else
            setStatus("Collecting")
        end
        task.wait(0.2)
    end
    setStatus("Stopped")
end

startBtn.Activated:Connect(function()
    if running then return end
    running = true
    setStatus("Running")
    task.spawn(loop)
end)

stopBtn.Activated:Connect(function()
    running = false
end)

setStatus("Idle")
