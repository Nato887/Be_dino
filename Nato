-- WHITE SCREEN
local whiteLabel

makeButton("White Screen",145,function(b)
    whiteScreenOn = not whiteScreenOn
    b.Text = whiteScreenOn and "White: ON" or "White Screen"

    if whiteScreenOn then
        if whiteGui:FindFirstChild("Overlay") then return end

        local f = Instance.new("Frame", whiteGui)
        f.Name = "Overlay"
        f.Size = UDim2.new(1,0,1,0)
        f.BackgroundColor3 = Color3.new(1,1,1)
        f.ZIndex = 999999

        whiteLabel = Instance.new("TextLabel", f)
        whiteLabel.Size = UDim2.new(1,0,1,0)
        whiteLabel.BackgroundTransparency = 1
        whiteLabel.TextColor3 = Color3.new(0,0,0)
        whiteLabel.Font = Enum.Font.GothamBlack
        whiteLabel.TextScaled = true

        task.spawn(function()
            while whiteScreenOn and whiteLabel do
                local t = os.time() - startTime
                local h = math.floor(t/3600)
                local m = math.floor((t%3600)/60)
                local s = t % 60

                whiteLabel.Text =
                    "FARMING...\n\n"..
                    string.format("%02dh %02dm %02ds",h,m,s)

                task.wait(1)
            end
        end)
    else
        if whiteGui:FindFirstChild("Overlay") then
            whiteGui.Overlay:Destroy()
        end
        whiteLabel = nil
    end
end)

