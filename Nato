-- ================= CORE LOGIC (WITH ADVANCED ANTI-VOID) =================

-- ฟังก์ชันเช็คว่าข้างหน้ามีพื้นไหม
local function isFloorAhead(pos)
    if not settings.antiVoid then return true end
    local ray = Ray.new(pos + Vector3.new(0, 5, 0), Vector3.new(0, -50, 0)) -- ยิงเลเซอร์ลงพื้น 50 Studs
    local hit = workspace:FindPartOnRayWithIgnoreList(ray, {player.Character})
    return hit ~= nil
end

RunService.Heartbeat:Connect(function(dt)
    local hrp = getHRP()
    if not hrp then return end

    -- 🛡️ 1. Ultra Anti-Void (ตกไปแล้วดึงกลับ)
    if settings.antiVoid and hrp.Position.Y < -30 then
        hrp.Velocity = Vector3.new(0, 0, 0)
        hrp.CFrame = CFrame.new(hrp.Position.X, 150, hrp.Position.Z)
        return
    end

    -- 🏃 2. Avoid Logic (หนีคนตัวใหญ่)
    if settings.avoidPlayers then
        local nearestBigger = nil
        local minDist = 150
        for _, p in ipairs(Players:GetPlayers()) do
            if p ~= player and p.Character and p.Character:FindFirstChild("HumanoidRootPart") then
                local eRoot = p.Character.HumanoidRootPart
                local dist = (hrp.Position - eRoot.Position).Magnitude
                if dist < minDist and eRoot.Size.Magnitude > hrp.Size.Magnitude then
                    nearestBigger = eRoot; minDist = dist
                end
            end
        end

        if nearestBigger then
            local escapeDir = (hrp.Position - nearestBigger.Position).Unit
            local targetPos = hrp.Position + (escapeDir * settings.tweenSpeed * dt)
            
            -- ตรวจสอบก่อนหนีว่าข้างหน้ามีพื้นไหม ถ้าไม่มีจะหยุดหนีเพื่อไม่ให้ตกแมพ
            if isFloorAhead(targetPos) then
                hrp.CFrame = CFrame.new(targetPos.X, hrp.Position.Y, targetPos.Z)
                hrp.Velocity = Vector3.new(0, 0.5, 0)
                return
            end
        end
    end

    -- 🦖 3. Hunt & 🍖 4. Auto Food
    local target = nil
    if settings.huntWeaker then
        for _, p in ipairs(Players:GetPlayers()) do
            if p ~= player and p.Character and p.Character:FindFirstChild("HumanoidRootPart") then
                local eRoot = p.Character.HumanoidRootPart
                if eRoot.Size.Magnitude < hrp.Size.Magnitude and eRoot.Size.Magnitude > 20 then target = eRoot; break end
            end
        end
    end

    if not target and settings.autoFood then
        for _, v in ipairs(CollectionService:GetTagged("Food")) do if v and v.Parent then target = v; break end end
    end

    -- เคลื่อนที่ไปหาเป้าหมาย (พร้อมเช็คพื้น)
    if target then
        local tPos = (target:IsA("Model") and target:GetPivot().Position) or target.Position
        local moveDir = (tPos - hrp.Position).Unit
        local nextStep = hrp.Position + (moveDir * settings.tweenSpeed * dt)
        
        -- ตรวจสอบพื้นก่อนพุ่งไป
        if isFloorAhead(nextStep) then
            hrp.CFrame = CFrame.new(nextStep)
            hrp.Velocity = Vector3.new(0, 0.1, 0)
        else
            -- ถ้าไม่มีพื้น ให้หยุดเดินทันที
            hrp.Velocity = Vector3.new(0, 0, 0)
        end
    end
end)

