local Players           = game:GetService("Players")
local CollectionService = game:GetService("CollectionService")
local VirtualUser       = game:GetService("VirtualUser")

local player = Players.LocalPlayer
if not player.Character then player.CharacterAdded:Wait() end

-- ⚙️ ระยะวงเก็บ (ปรับได้)
local COLLECT_RADIUS = 25
local SAFE_RADIUS = 150

-- Anti AFK
player.Idled:Connect(function()
    VirtualUser:Button2Down(Vector2.new(0,0), workspace.CurrentCamera.CFrame)
    task.wait(1)
    VirtualUser:Button2Up(Vector2.new(0,0), workspace.CurrentCamera.CFrame)
end)

local running = false

-- Root
local function getHRP()
    local char = player.Character
    if not char then return nil end
    return char:FindFirstChild("HumanoidRootPart") or char.PrimaryPart
end

-- ตรวจผู้เล่นรอบตัว
local function isDangerousNear(pos, radius)
    radius = radius or SAFE_RADIUS
    local myChar = player.Character
    if not myChar then return false end
    local myHum = myChar:FindFirstChildOfClass("Humanoid")
    if not myHum then return false end

    for _, plr in ipairs(Players:GetPlayers()) do
        if plr ~= player and plr.Character then
            local root = plr.Character:FindFirstChild("HumanoidRootPart")
            local hum  = plr.Character:FindFirstChildOfClass("Humanoid")
            if root and hum then
                if (root.Position - pos).Magnitude < radius and hum.Health > myHum.Health then
                    return true
                end
            end
        end
    end
    return false
end

-- หาอาหาร
local function getFoods()
    local hrp = getHRP()
    if not hrp then return {} end

    local inRange = {}
    local near = {}

    for _, food in ipairs(CollectionService:GetTagged("Food")) do
        if food and food.Parent then
            local pos
            if food:IsA("Model") then
                pos = food:GetPivot().Position
            elseif food:IsA("BasePart") then
                pos = food.Position
            end

            if pos and not isDangerousNear(pos,SAFE_RADIUS) then
                local dist = (hrp.Position - pos).Magnitude

                if dist <= COLLECT_RADIUS then
                    table.insert(inRange, {instance = food, position = pos})
                else
                    table.insert(near, {instance = food, position = pos, dist = dist})
                end
            end
        end
    end

    if #inRange > 0 then
        return inRange
    end

    table.sort(near, function(a,b)
        return a.dist < b.dist
    end)

    local result = {}
    for i=1, math.min(10, #near) do
        table.insert(result, near[i])
    end
    return result
end

-- Warp ขึ้นก่อนลง ตรวจสอบพื้น
local function godWarp(target)
    local hrp = getHRP()
    if not hrp or not target.instance or not target.instance.Parent then return end

    local pos = target.position
    hrp.CFrame = CFrame.new(pos + Vector3.new(0,25,0)) -- ขึ้นก่อน

    local groundPos = nil
    local tries = 0

    while tries < 20 do
        local ray = workspace:Raycast(pos + Vector3.new(0,10,0), Vector3.new(0,-50,0))
        if ray then
            groundPos = ray.Position
            break
        end
        tries += 1
        task.wait(0.03)
    end

    if not groundPos then return end
    hrp.CFrame = CFrame.new(groundPos + Vector3.new(0,3,0)) -- ลงเก็บ
end

-- ตรวจและ respawn
local function ensureCharacter()
    local char = player.Character
    local hum = char and char:FindFirstChildOfClass("Humanoid")
    if not hum or hum.Health <= 0 then
        player.CharacterAdded:Wait()
        task.wait(0.5)
    end
end

-- LOOP ฟาร์ม
local function farmLoop()
    while running do
        ensureCharacter()
        local foods = getFoods()

        for _, f in ipairs(foods) do
            if not running then break end
            ensureCharacter()
            godWarp(f)
        end

        task.wait(0.01)
    end
end

