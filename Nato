local Players = game:GetService("Players")
local RunService = game:GetService("RunService")
local CollectionService = game:GetService("CollectionService")
local UserInputService = game:GetService("UserInputService")
local VirtualUser = game:GetService("VirtualUser")

local player = Players.LocalPlayer
if not player.Character then player.CharacterAdded:Wait() end

-- [[ CONFIGURATION ]]
local SAFE_Y = -50
local running = false
local farmSpeed = 100
local avoidSpeed = 150
local avoidDistance = 150
local whiteScreenOn = false
local avoidPlayerEnabled = false
local fastMode = false

-- [[ UTILS ]]
local function getHRP(target)
    local char = target or player.Character
    if not char then return nil end
    return char:FindFirstChild("HumanoidRootPart") or char.PrimaryPart
end

local function getGrowth(plr)
    local ls = plr:FindFirstChild("leaderstats")
    if ls and ls:FindFirstChild("Growth") then return ls.Growth.Value end
    return 0
end

-- 🔥 RAYCAST หา Y พื้น
local function getGroundY(pos)
    local rayOrigin = pos + Vector3.new(0, 50, 0)
    local rayDir = Vector3.new(0, -200, 0)

    local params = RaycastParams.new()
    params.FilterDescendantsInstances = {player.Character}
    params.FilterType = Enum.RaycastFilterType.Blacklist

    local result = workspace:Raycast(rayOrigin, rayDir, params)

    if result then
        return result.Position.Y + 3
    else
        return pos.Y
    end
end

-- [[ FAST MODE ]]
local function runFastMode()
    for _, v in pairs(workspace:GetDescendants()) do
        if v:IsA("BasePart") or v:IsA("MeshPart") then
            local n = v.Name:lower()
            if n:find("tree") or n:find("rock") or n:find("mountain") or n:find("bush") then
                v:Destroy()
            end
        end
    end
end

-- [[ AVOID PLAYER ]]
local function getDangerPlayer()
    if not avoidPlayerEnabled then return nil end
    local hrp = getHRP()
    if not hrp then return nil end
    local myGrowth = getGrowth(player)

    local nearest = nil
    local minDist = avoidDistance + 30
    for _, p in pairs(Players:GetPlayers()) do
        if p ~= player and p.Character then
            local tHrp = getHRP(p.Character)
            if tHrp then
                local d = (hrp.Position - tHrp.Position).Magnitude
                if d < minDist and getGrowth(p) > myGrowth then
                    minDist = d
                    nearest = tHrp
                end
            end
        end
    end
    return nearest
end

-- [[ MOVEMENT ]]
local moverConn
local function stopMover()
    if moverConn then moverConn:Disconnect() moverConn = nil end
end

local function startMovementLoop()
    stopMover()
    moverConn = RunService.Heartbeat:Connect(function(dt)
        local hrp = getHRP()
        if not hrp or not running then return end

        -- 🔥 กันตกแมพขั้นเทพ
        if hrp.Position.Y < SAFE_Y then
            local safeY = getGroundY(hrp.Position)
            hrp.CFrame = CFrame.new(hrp.Position.X, safeY + 10, hrp.Position.Z)
            hrp.AssemblyLinearVelocity = Vector3.zero
            return
        end

        local danger = getDangerPlayer()

        if danger then
            local dir = (hrp.Position - danger.Position).Unit
            local speedToUse = math.max(avoidSpeed, farmSpeed + 20)

            local move = dir * (speedToUse * dt)
            if move.Magnitude > 15 then
                move = move.Unit * 15
            end

            local newPos = hrp.Position + move
            local groundY = getGroundY(newPos)

            hrp.CFrame = CFrame.new(newPos.X, groundY, newPos.Z)

        else
            local foodPos, dist = nil, math.huge
            for _, f in CollectionService:GetTagged("Food") do
                if f and f.Parent then
                    local p = f:IsA("Model") and f:GetPivot().Position or f.Position
                    local d = (hrp.Position - p).Magnitude
                    if d < dist then
                        dist = d
                        foodPos = p
                    end
                end
            end

            if foodPos then
                local diff = foodPos - hrp.Position
                local dist = diff.Magnitude

                if dist > 0.1 then
                    local step = math.min(farmSpeed * dt, dist)
                    local move = diff.Unit * step

                    if move.Magnitude > 15 then
                        move = move.Unit * 15
                    end

                    local newPos = hrp.Position + move
                    local groundY = getGroundY(newPos)

                    hrp.CFrame = CFrame.new(newPos.X, groundY, newPos.Z)
                end
            else
                hrp.AssemblyLinearVelocity = Vector3.zero
            end
        end
    end)
end

