-- SLIDER (MOBILE FRIENDLY)
local function makeSlider(y, max, default, name, callback)
    local label = Instance.new("TextLabel", panel)
    label.Size = UDim2.new(0, 420, 0, 20)
    label.Position = UDim2.new(0, 20, 0, y)
    label.Text = name .. ": " .. default
    label.TextColor3 = Color3.new(1,1,1)
    label.BackgroundTransparency = 1
    label.TextXAlignment = Enum.TextXAlignment.Left

    local track = Instance.new("Frame", panel)
    track.Size = UDim2.new(0, 420, 0, 8)
    track.Position = UDim2.new(0, 20, 0, y + 25)
    track.BackgroundColor3 = Color3.new(0.15, 0.15, 0.25)
    Instance.new("UICorner", track)

    local fill = Instance.new("Frame", track)
    fill.Size = UDim2.new(default/max, 0, 1, 0)
    fill.BackgroundColor3 = Color3.fromRGB(0, 255, 150)
    Instance.new("UICorner", fill)

    local knob = Instance.new("TextButton", track)
    knob.Size = UDim2.new(0, 26, 0, 26)
    knob.Position = UDim2.new(default/max, -13, 0.5, -13)
    knob.Text = ""
    knob.BackgroundColor3 = Color3.new(1, 1, 1)
    Instance.new("UICorner", knob)

    local function updateSlider(input)
        local delta = math.clamp((input.Position.X - track.AbsolutePosition.X) / track.AbsoluteSize.X, 0, 1)
        local val = math.floor(delta * max)
        fill.Size = UDim2.new(delta, 0, 1, 0)
        knob.Position = UDim2.new(delta, -13, 0.5, -13)
        label.Text = name .. ": " .. val
        callback(val)
        if whiteLabel then
            whiteLabel.Text = "🦖 FARMING...\nFarm Spd: "..farmSpeed.." | Avoid Spd: "..avoidSpeed
        end
    end

    local dragging = false
    knob.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
            dragging = true
        end
    end)
    UserInputService.InputEnded:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
            dragging = false
        end
    end)
    UserInputService.InputChanged:Connect(function(input)
        if dragging and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
            updateSlider(input)
        end
    end)
end

makeSlider(45, 1000, farmSpeed, "Speed Farm", function(v) farmSpeed = v end)
makeSlider(95, 1000, avoidSpeed, "Speed Avoid Player", function(v) avoidSpeed = v end)

