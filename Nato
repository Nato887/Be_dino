local Players           = game:GetService("Players")
local CollectionService = game:GetService("CollectionService")
local UserInputService  = game:GetService("UserInputService")
local VirtualUser       = game:GetService("VirtualUser")

local player = Players.LocalPlayer
if not player.Character then player.CharacterAdded:Wait() end

local running    = false
local tweenSpeed = 500 -- ใช้เป็น step แล้ว
local MAX_SPEED  = 10000

-- 🔥 Anti AFK
player.Idled:Connect(function()
    VirtualUser:Button2Down(Vector2.new(0,0), workspace.CurrentCamera.CFrame)
    task.wait(1)
    VirtualUser:Button2Up(Vector2.new(0,0), workspace.CurrentCamera.CFrame)
end)

-- Root
local function getHRP()
    local char = player.Character
    if not char then return nil end
    return char:FindFirstChild("HumanoidRootPart") or char.PrimaryPart
end

-- 🔥 กันผู้เล่น
local function isPlayerNear(pos, radius)
    for _, plr in ipairs(Players:GetPlayers()) do
        if plr ~= player and plr.Character then
            local hrp = plr.Character:FindFirstChild("HumanoidRootPart")
            if hrp and (hrp.Position - pos).Magnitude < radius then
                return true
            end
        end
    end
    return false
end

-- หา food
local function getClosestFood()
    local hrp = getHRP()
    if not hrp then return nil end

    local best, bestDist = nil, math.huge

    for _, food in CollectionService:GetTagged("Food") do
        if not food or not food.Parent then continue end

        local pos = (food:IsA("Model") and food:GetPivot().Position)
                 or (food:IsA("BasePart") and food.Position)

        if pos then
            if isPlayerNear(pos, 50) then continue end

            local d = (hrp.Position - pos).Magnitude
            if d < bestDist then
                bestDist = d
                best = {instance = food, position = pos}
            end
        end
    end

    return best
end

-- 🔥 moveTo (วาร์ปรัว 500)
local function moveTo(targetPos)
    local startTime = tick()

    while running do
        local hrp = getHRP()
        if not hrp then break end

        local diff = targetPos - hrp.Position
        local dist = diff.Magnitude

        if dist < 10 then
            hrp.CFrame = CFrame.new(targetPos)
            break
        end

        if isPlayerNear(targetPos, 40) then
            break
        end

        if tick() - startTime > 3 then
            hrp.CFrame = CFrame.new(targetPos)
            break
        end

        local step = math.min(tweenSpeed, dist)
        hrp.CFrame = CFrame.new(hrp.Position + diff.Unit * step)

        task.wait()
    end
end

-- GUI
local gui = Instance.new("ScreenGui", player:WaitForChild("PlayerGui"))
gui.ResetOnSpawn = false

local panel = Instance.new("Frame", gui)
panel.Size = UDim2.new(0,270,0,215)
panel.Position = UDim2.new(0.5,-135,0.5,-107)
panel.BackgroundColor3 = Color3.fromRGB(18,18,28)
panel.Active = true
panel.Draggable = true

local statusLbl = Instance.new("TextLabel", panel)
statusLbl.Position = UDim2.new(0,10,0,46)
statusLbl.Size = UDim2.new(1,-20,0,22)
statusLbl.BackgroundTransparency = 1
statusLbl.Text = "Status: Idle"

local speedLbl = Instance.new("TextLabel", panel)
speedLbl.Position = UDim2.new(0,10,0,94)
speedLbl.Size = UDim2.new(1,-20,0,20)
speedLbl.BackgroundTransparency = 1
speedLbl.Text = "Speed: 500"

local function setStatus(msg)
    statusLbl.Text = "Status: "..msg
end

-- slider มือถือ
local track = Instance.new("Frame", panel)
track.Size = UDim2.new(1,-20,0,8)
track.Position = UDim2.new(0,10,0,122)

local fill = Instance.new("Frame", track)
fill.Size = UDim2.new(tweenSpeed/MAX_SPEED,0,1,0)

local knob = Instance.new("TextButton", track)
knob.Size = UDim2.new(0,20,0,20)
knob.Position = UDim2.new(tweenSpeed/MAX_SPEED,-10,0.5,-10)

local dragging = false

knob.InputBegan:Connect(function(i)
    if i.UserInputType == Enum.UserInputType.Touch or i.UserInputType == Enum.UserInputType.MouseButton1 then
        dragging = true
    end
end)

UserInputService.InputEnded:Connect(function(i)
    if i.UserInputType == Enum.UserInputType.Touch or i.UserInputType == Enum.UserInputType.MouseButton1 then
        dragging = false
    end
end)

UserInputService.InputChanged:Connect(function(i)
    if not dragging then return end
    if i.UserInputType ~= Enum.UserInputType.Touch and i.UserInputType ~= Enum.UserInputType.MouseMovement then return end

    local ratio = math.clamp((i.Position.X - track.AbsolutePosition.X)/track.AbsoluteSize.X,0,1)

    tweenSpeed = math.floor(ratio * MAX_SPEED)
    fill.Size = UDim2.new(ratio,0,1,0)
    knob.Position = UDim2.new(ratio,-10,0.5,-10)
    speedLbl.Text = "Speed: "..tweenSpeed
end)

-- buttons
local function makeBtn(text,x)
    local b = Instance.new("TextButton", panel)
    b.Size = UDim2.new(0,112,0,36)
    b.Position = UDim2.new(0,x,0,162)
    b.Text = text
    return b
end

local startBtn = makeBtn("Start",16)
local stopBtn  = makeBtn("Stop",142)

-- loop
local function loop()
    while running do
        local food = getClosestFood()

        if not food then
            setStatus("No safe food")
            task.wait(0.3)
            continue
        end

        setStatus("Going to "..food.instance.Name)
        moveTo(food.position)
    end

    setStatus("Stopped")
end

startBtn.Activated:Connect(function()
    if running then return end
    running = true
    setStatus("Running")
    task.spawn(loop)
end)

stopBtn.Activated:Connect(function()
    running = false
    setStatus("Stopped")
end)

setStatus("Idle")
