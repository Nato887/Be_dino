-- Slider Logic
local dragging = false
knob.MouseButton1Down:Connect(function() dragging = true end)
UserInputService.InputEnded:Connect(function(i) if i.UserInputType == Enum.UserInputType.MouseButton1 then dragging = false end end)
UserInputService.InputChanged:Connect(function(i)
    if dragging and (i.UserInputType == Enum.UserInputType.MouseMovement or i.UserInputType == Enum.UserInputType.Touch) then
        local r = math.clamp((i.Position.X - track.AbsolutePosition.X) / track.AbsoluteSize.X, 0, 1)
        tweenSpeed = math.floor(r * 1000)
        knob.Position = UDim2.new(r, -9, 0.5, -9)
        speedLbl.Text = "Speed: " .. tweenSpeed
    end
end)

startBtn.MouseButton1Click:Connect(function()
    if running then return end
    running = true
    startBtn.Text = "RUNNING..."
    task.spawn(function()
        while running do
            local target = getTarget()
            if target then
                status.Text = "Status: Going to " .. target.instance.Name
                moveTo(target.pos)
            else
                status.Text = "Status: Searching..."
                task.wait(0.5)
            end
            task.wait(0.1)
        end
        status.Text = "Status: Idle"
        startBtn.Text = "START"
    end)
end)

stopBtn.MouseButton1Click:Connect(function()
    running = false; stopTween()
end)

