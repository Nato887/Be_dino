local Players           = game:GetService("Players")
local RunService        = game:GetService("RunService")
local CollectionService = game:GetService("CollectionService")
local UserInputService  = game:GetService("UserInputService")

local player = Players.LocalPlayer

-- รอ Character ให้พร้อม
local function waitChar()
    local char = player.Character or player.CharacterAdded:Wait()
    repeat task.wait() until char:FindFirstChild("HumanoidRootPart")
    return char
end

local function getHRP()
    local char = player.Character
    if not char then return nil end
    return char:FindFirstChild("HumanoidRootPart")
end

local running    = false
local tweenSpeed = 100
local moverConn  = nil

local BOOST = 5
local TARGET_SAFE = 75
local SELF_DANGER = 50

-- 🧠 เช็คผู้เล่นใกล้
local function isPlayerNear(pos, radius)
    for _, p in ipairs(Players:GetPlayers()) do
        if p ~= player and p.Character and p.Character:FindFirstChild("HumanoidRootPart") then
            if (p.Character.HumanoidRootPart.Position - pos).Magnitude <= radius then
                return true
            end
        end
    end
    return false
end

local function isPlayerNearMe()
    local hrp = getHRP()
    if not hrp then return false end
    return isPlayerNear(hrp.Position, SELF_DANGER)
end

-- 🔎 หาอาหาร (ไม่มี continue แล้ว)
local function getClosestFood()
    local hrp = getHRP()
    if not hrp then return nil end

    local best = nil
    local bestDist = math.huge

    for _, food in ipairs(CollectionService:GetTagged("Food")) do
        if food and food.Parent then
            local pos
            if food:IsA("Model") then
                pos = food:GetPivot().Position
            elseif food:IsA("BasePart") then
                pos = food.Position
            end

            if pos then
                if not isPlayerNear(pos, TARGET_SAFE) then
                    local d = (hrp.Position - pos).Magnitude
                    if d < bestDist then
                        bestDist = d
                        best = {instance = food, position = pos}
                    end
                end
            end
        end
    end

    return best
end

local function stopMover()
    if moverConn then moverConn:Disconnect(); moverConn = nil end
end

-- ⚡ เคลื่อนที่ + หนี
local function moveTo(targetPos)
    local reached = false
    stopMover()

    moverConn = RunService.Heartbeat:Connect(function(dt)
        local hrp = getHRP()
        if not hrp or not running then
            reached = true
            stopMover()
            return
        end

        -- 🏃 หนีผู้เล่น
        if isPlayerNearMe() then
            hrp.CFrame = hrp.CFrame + Vector3.new(math.random(-120,120),0,math.random(-120,120))
            reached = true
            stopMover()
            return
        end

        -- 🧠 กันเป้าหมาย
        if isPlayerNear(targetPos, TARGET_SAFE) then
            reached = true
            stopMover()
            return
        end

        local diff = targetPos - hrp.Position
        local dist = diff.Magnitude

        if dist < 2 then
            reached = true
            stopMover()
            return
        end

        local step = math.min((tweenSpeed * BOOST) * dt, dist)
        hrp.CFrame = CFrame.new(hrp.Position + diff.Unit * step)
    end)

    while not reached do
        task.wait()
    end
end

-- 💀 ตายแล้วหยุด
local function bindCharacter(char)
    local hum = char:WaitForChild("Humanoid")
    hum.Died:Connect(function()
        running = false
        stopMover()
    end)
end

bindCharacter(waitChar())
player.CharacterAdded:Connect(bindCharacter)

-- ── GUI ──
local gui = Instance.new("ScreenGui", player:WaitForChild("PlayerGui"))
gui.ResetOnSpawn = false

local panel = Instance.new("Frame", gui)
panel.Size = UDim2.new(0,250,0,150)
panel.Position = UDim2.new(0.5,-125,0.5,-75)
panel.BackgroundColor3 = Color3.fromRGB(20,20,30)
panel.Active = true
panel.Draggable = true

local statusLbl = Instance.new("TextLabel", panel)
statusLbl.Size = UDim2.new(1,0,0,30)
statusLbl.BackgroundTransparency = 1
statusLbl.Text = "Status: Idle"

local function setStatus(t)
    statusLbl.Text = "Status: "..t
end

local start = Instance.new("TextButton", panel)
start.Size = UDim2.new(0.4,0,0,30)
start.Position = UDim2.new(0.05,0,0.6,0)
start.Text = "Start"

local stop = Instance.new("TextButton", panel)
stop.Size = UDim2.new(0.4,0,0,30)
stop.Position = UDim2.new(0.55,0,0.6,0)
stop.Text = "Stop"

-- ✅ ใช้ Activated (มือถือ/PC)
start.Activated:Connect(function()
    if running then return end
    running = true
    setStatus("Running")

    task.spawn(function()
        while running do
            local food = getClosestFood()

            if food then
                setStatus("Going "..food.instance.Name)
                moveTo(food.position)
            else
                setStatus("No food")
                task.wait(0.2)
            end
        end
    end)
end)

stop.Activated:Connect(function()
    running = false
    stopMover()
    setStatus("Stopped")
end)
