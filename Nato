local Players           = game:GetService("Players")
local TweenService      = game:GetService("TweenService")
local CollectionService = game:GetService("CollectionService")
local UserInputService  = game:GetService("UserInputService")
local RunService        = game:GetService("RunService")

local player = Players.LocalPlayer
local running = false
local avoidPlayers = true
local tweenSpeed = 100
local currentTween = nil

-- ── ฟังก์ชันหาตำแหน่งตัวละคร ──
local function getHRP()
    local char = player.Character
    return char and (char:FindFirstChild("HumanoidRootPart") or char.PrimaryPart)
end

-- ── ฟังก์ชันคำนวณตำแหน่งที่ปลอดภัย (กันตกแมพ) ──
local function getAvoidanceOffset()
    local hrp = getHRP()
    if not hrp or not avoidPlayers then return Vector3.new() end
    local force = Vector3.new()
    for _, other in ipairs(Players:GetPlayers()) do
        if other ~= player and other.Character and other.Character:FindFirstChild("HumanoidRootPart") then
            local otherPos = other.Character.HumanoidRootPart.Position
            local diff = hrp.Position - otherPos
            if diff.Magnitude < 50 then -- ระยะหลบ 50 studs
                force = force + (diff.Unit * (50 - diff.Magnitude))
            end
        end
    end
    return force
end

-- ── ค้นหาเนื้อหรือไข่ที่ใกล้ที่สุด ──
local function getTarget()
    local hrp = getHRP()
    if not hrp then return nil end
    local best, bestDist = nil, math.huge
    
    -- ค้นหาจาก Tag "Food" (เนื้อ) และตรวจสอบไข่เพิ่มเติมหากมี Tag อื่น
    for _, obj in ipairs(CollectionService:GetTagged("Food")) do
        if obj and obj.Parent then
            local pos = obj:IsA("Model") and obj:GetPivot().Position or obj.Position
            local dist = (hrp.Position - pos).Magnitude
            if dist < bestDist then
                bestDist = dist
                best = {instance = obj, pos = pos}
            end
        end
    end
    return best
end

local function stopTween()
    if currentTween then currentTween:Cancel(); currentTween = nil end
end

-- ── ระบบเดินแบบ Tween (กันตกแมพ) ──
local function moveTo(targetPos)
    local hrp = getHRP()
    if not hrp then return end
    
    stopTween()
    local avoidForce = getAvoidanceOffset()
    local finalPos = targetPos + avoidForce
    
    -- ล็อกความสูง Y ให้เท่ากับตัวละครปัจจุบันเพื่อกันตกแมพหรือจมดิน
    local safePos = Vector3.new(finalPos.X, hrp.Position.Y, finalPos.Z)
    local dist = (hrp.Position - safePos).Magnitude
    local duration = dist / tweenSpeed
    
    local info = TweenInfo.new(duration, Enum.EasingStyle.Linear)
    currentTween = TweenService:Create(hrp, info, {CFrame = CFrame.new(safePos, Vector3.new(targetPos.X, hrp.Position.Y, targetPos.Z))})
    currentTween:Play()
    currentTween.Completed:Wait()
end

