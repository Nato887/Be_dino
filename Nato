-- [[ SLIDER CREATOR ]]
local function makeSlider(y, max, default, name, callback)
    local label = Instance.new("TextLabel", panel)
    label.Size = UDim2.new(0, 280, 0, 20)
    label.Position = UDim2.new(0, 15, 0, y)
    label.Text = name .. ": " .. default
    label.TextColor3 = Color3.new(1,1,1)
    label.BackgroundTransparency = 1
    label.TextXAlignment = Enum.TextXAlignment.Left

    local track = Instance.new("Frame", panel)
    track.Size = UDim2.new(0, 260, 0, 6)
    track.Position = UDim2.new(0, 20, 0, y + 25)
    track.BackgroundColor3 = Color3.new(0.2, 0.2, 0.3)
    local fill = Instance.new("Frame", track)
    fill.Size = UDim2.new(default/max, 0, 1, 0)
    fill.BackgroundColor3 = Color3.fromRGB(0, 255, 155)
    local knob = Instance.new("TextButton", track)
    knob.Size = UDim2.new(0, 16, 0, 16)
    knob.Position = UDim2.new(default/max, -8, 0.5, -8)
    knob.Text = ""
    Instance.new("UICorner", knob)

    local dragging = false
    knob.MouseButton1Down:Connect(function() dragging = true end)
    UserInputService.InputEnded:Connect(function(i) if i.UserInputType == Enum.UserInputType.MouseButton1 then dragging = false end end)
    UserInputService.InputChanged:Connect(function(i)
        if dragging and i.UserInputType == Enum.UserInputType.MouseMovement then
            local r = math.clamp((i.Position.X - track.AbsolutePosition.X) / track.AbsoluteSize.X, 0, 1)
            local val = math.floor(r * max)
            fill.Size = UDim2.new(r, 0, 1, 0)
            knob.Position = UDim2.new(r, -8, 0.5, -8)
            label.Text = name .. ": " .. val
            callback(val)
            updateWhiteScreenInfo()
        end
    end)
end

makeSlider(55, 1000, farmSpeed, "Speed Farm", function(v) farmSpeed = v end)
makeSlider(125, 1000, avoidSpeed, "Speed Avoid Player", function(v) avoidSpeed = v end)

