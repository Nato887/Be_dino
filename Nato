local Players           = game:GetService("Players")
local RunService        = game:GetService("RunService")
local CollectionService = game:GetService("CollectionService")
local UserInputService  = game:GetService("UserInputService")
local VirtualUser       = game:GetService("VirtualUser")

local player = Players.LocalPlayer
if not player.Character then player.CharacterAdded:Wait() end

-- ✅ Anti AFK
player.Idled:Connect(function()
    VirtualUser:Button2Down(Vector2.new(0,0), workspace.CurrentCamera.CFrame)
    task.wait(1)
    VirtualUser:Button2Up(Vector2.new(0,0), workspace.CurrentCamera.CFrame)
end)

local running   = false
local tweenSpeed = 100
local moverConn  = nil

-- Root
local function getHRP()
    local char = player.Character
    if not char then return nil end
    for _, v in ipairs(char:GetChildren()) do
        if v.Name == "RootPart" and v:IsA("BasePart") and not v.Massless then
            return v
        end
    end
    return char.PrimaryPart
end

-- ❗ ของเดิม 100%
local function getClosestFood()
    local hrp = getHRP()
    if not hrp then return nil end

    local best, bestDist = nil, math.huge
    for _, food in CollectionService:GetTagged("Food") do
        if not food or not food.Parent then continue end
        local ok, pos = pcall(function()
            if food:IsA("Model") then return food:GetPivot().Position
            elseif food:IsA("BasePart") then return food.Position end
        end)

        if ok and pos then
            local d = (hrp.Position - pos).Magnitude
            if d < bestDist then
                bestDist = d
                best = { instance = food, position = pos }
            end
        end
    end
    return best
end

local function stopMover()
    if moverConn then moverConn:Disconnect(); moverConn = nil end
end

-- 🔥 วาร์ปไม่ตกแมพ
local function moveTo(targetPos)
    local reached = false
    stopMover()

    moverConn = RunService.Heartbeat:Connect(function()
        local hrp = getHRP()
        if not hrp or not running then reached = true; stopMover(); return end

        local dist = (hrp.Position - targetPos).Magnitude
        if dist < 5 then reached = true; stopMover(); return end

        -- วาร์ปลอยเหนือเป้าหมาย
        hrp.CFrame = CFrame.new(targetPos + Vector3.new(0, 5, 0))
    end)

    while not reached do task.wait(0.05) end

    -- ลงพื้นแบบปลอดภัย
    local hrp = getHRP()
    if hrp then
        hrp.CFrame = CFrame.new(targetPos + Vector3.new(0, 2, 0))
    end
end

-- GUI
local gui = Instance.new("ScreenGui")
gui.Name = "FoodCollector"
gui.ResetOnSpawn = false
gui.Parent = player:WaitForChild("PlayerGui")

-- Toggle GUI
local toggleBtn = Instance.new("TextButton")
toggleBtn.Size = UDim2.new(0,120,0,40)
toggleBtn.Position = UDim2.new(0,20,0,20)
toggleBtn.Text = "Toggle GUI"
toggleBtn.BackgroundColor3 = Color3.fromRGB(40,40,60)
toggleBtn.TextColor3 = Color3.new(1,1,1)
toggleBtn.Parent = gui
Instance.new("UICorner", toggleBtn)

local panel = Instance.new("Frame")
panel.Size = UDim2.new(0,270,0,215)
panel.Position = UDim2.new(0.5,-135,0.5,-107)
panel.BackgroundColor3 = Color3.fromRGB(18,18,28)
panel.Active = true
panel.Draggable = true
panel.Parent = gui
Instance.new("UICorner", panel)

local visible = true
toggleBtn.MouseButton1Click:Connect(function()
    visible = not visible
    panel.Visible = visible
end)

-- Labels
local statusLbl = Instance.new("TextLabel", panel)
statusLbl.Position = UDim2.new(0,10,0,40)
statusLbl.Size = UDim2.new(1,-20,0,20)
statusLbl.BackgroundTransparency = 1
statusLbl.Text = "Status: Idle"
statusLbl.TextColor3 = Color3.new(1,1,1)

local speedLbl = Instance.new("TextLabel", panel)
speedLbl.Position = UDim2.new(0,10,0,70)
speedLbl.Size = UDim2.new(1,-20,0,20)
speedLbl.BackgroundTransparency = 1
speedLbl.Text = "Speed: 100"

-- Slider
local track = Instance.new("Frame", panel)
track.Position = UDim2.new(0,10,0,100)
track.Size = UDim2.new(1,-20,0,8)
track.BackgroundColor3 = Color3.fromRGB(50,50,75)

local fill = Instance.new("Frame", track)
fill.Size = UDim2.new(tweenSpeed/1000,0,1,0)
fill.BackgroundColor3 = Color3.fromRGB(90,160,255)

local knob = Instance.new("Frame", track)
knob.Size = UDim2.new(0,18,0,18)
knob.Position = UDim2.new(tweenSpeed/1000,-9,0.5,-9)

local dragging = false

local function updateSlider(x)
    local ratio = math.clamp((x - track.AbsolutePosition.X)/track.AbsoluteSize.X,0,1)
    tweenSpeed = math.max(1, math.floor(ratio * 1000))
    fill.Size = UDim2.new(ratio,0,1,0)
    knob.Position = UDim2.new(ratio,-9,0.5,-9)
    speedLbl.Text = "Speed: "..tweenSpeed
end

track.InputBegan:Connect(function(i)
    if i.UserInputType == Enum.UserInputType.MouseButton1 or i.UserInputType == Enum.UserInputType.Touch then
        dragging = true
        panel.Draggable = false
        updateSlider(i.Position.X)
    end
end)

UserInputService.InputChanged:Connect(function(i)
    if dragging and (i.UserInputType == Enum.UserInputType.MouseMovement or i.UserInputType == Enum.UserInputType.Touch) then
        updateSlider(i.Position.X)
    end
end)

UserInputService.InputEnded:Connect(function(i)
    if i.UserInputType == Enum.UserInputType.MouseButton1 or i.UserInputType == Enum.UserInputType.Touch then
        dragging = false
        panel.Draggable = true
    end
end)

-- Buttons
local function makeBtn(text, color, x)
    local b = Instance.new("TextButton", panel)
    b.Size = UDim2.new(0,110,0,35)
    b.Position = UDim2.new(0,x,0,150)
    b.Text = text
    b.BackgroundColor3 = color
    b.TextColor3 = Color3.new(1,1,1)
    return b
end

local startBtn = makeBtn("START", Color3.fromRGB(40,165,70), 10)
local stopBtn  = makeBtn("STOP",  Color3.fromRGB(180,60,60), 140)

-- Loop
local function setStatus(t)
    statusLbl.Text = "Status: "..t
end

local function loop()
    while running do
        local food = getClosestFood()
        if food then
            setStatus("Going "..food.instance.Name)
            moveTo(food.position)
        else
            setStatus("No food")
            task.wait(0.3)
        end
    end
    setStatus("Stopped")
end

startBtn.MouseButton1Click:Connect(function()
    if running then return end
    running = true
    setStatus("Running")
    task.spawn(loop)
end)

stopBtn.MouseButton1Click:Connect(function()
    running = false
    stopMover()
    setStatus("Stopped")
end)

setStatus("Idle")
