speedLbl.Text = "Speed: 100"

-- ── GUI TOGGLE (วางหลังสร้าง panel แต่ก่อนปุ่ม Start/Stop) ──
local guiVisible = true
UserInputService.InputBegan:Connect(function(input,gp)
    if gp then return end
    if input.KeyCode == Enum.KeyCode.RightControl then
        if panel and panel.Parent then
            guiVisible = not guiVisible
            panel.Visible = guiVisible
        end
    end
end)

-- ── BUTTON ──────────────────────────────────────
local startBtn = Instance.new("TextButton", panel)
startBtn.Size = UDim2.new(0,100,0,35)
startBtn.Position = UDim2.new(0,20,0,150)
startBtn.Text = "Start"

local stopBtn = Instance.new("TextButton", panel)
stopBtn.Size = UDim2.new(0,100,0,35)
stopBtn.Position = UDim2.new(0,140,0,150)
stopBtn.Text = "Stop"

-- ── LOOP ───────────────────────────────────────
local function setStatus(txt)
    statusLbl.Text = "Status: "..txt
end

local function loop()
    while running do
        local food = getClosestFood()

        if food then
            setStatus("Going: "..food.instance.Name)
            moveTo(food.position)
        else
            setStatus("No food")
            task.wait(0.5)
        end
    end
end

startBtn.MouseButton1Click:Connect(function()
    if running then return end
    running = true
    setStatus("Running")
    task.spawn(loop)
end)

stopBtn.MouseButton1Click:Connect(function()
    running = false
    stopMover()
    setStatus("Stopped")
end)
