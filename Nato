-- ================= MAIN LOOP =================
RunService.Heartbeat:Connect(function(dt)
    if not settings.flyFarm then return end
    local hrp = getHRP()
    if not hrp then return end

    -- ปิดแรงโน้มถ่วงชั่วขณะ (กันตกล่วงหน้า)
    hrp.Velocity = Vector3.new(0, 0.1, 0)

    -- 1. ลำดับที่ 1: หนีคนตัวใหญ่ (Avoid)
    local danger = getDangerPlayer()
    if danger then
        local escapeDir = (hrp.Position - danger.Position).Unit
        -- บินหนีขึ้นฟ้าเฉียงๆ เพื่อความปลอดภัย
        hrp.CFrame = CFrame.new(hrp.Position + (escapeDir + Vector3.new(0, 0.5, 0)).Unit * (settings.tweenSpeed * dt))
        return
    end

    -- 2. ลำดับที่ 2: บินไปหาของกิน (Auto Fly to Food)
    local food = getClosestFood()
    if food then
        local targetPos = food.position
        local diff = targetPos - hrp.Position
        if diff.Magnitude > 2 then
            -- บินตรงไปยังจุดที่ของกินอยู่ (ขยับ CFrame โดยตรงในอากาศ)
            hrp.CFrame = CFrame.new(hrp.Position + diff.Unit * (settings.tweenSpeed * dt))
        end
    end
end)
