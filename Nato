local Players           = game:GetService("Players")
local RunService        = game:GetService("RunService")
local CollectionService = game:GetService("CollectionService")
local UserInputService  = game:GetService("UserInputService")

local player = Players.LocalPlayer
if not player.Character then player.CharacterAdded:Wait() end

local running      = false
local avoidPlayers = true -- ระบบหลบผู้เล่น
local tweenSpeed   = 100
local moverConn    = nil

-- ── ฟังก์ชันหา RootPart ──
local function getHRP()
    local char = player.Character
    if not char then return nil end
    return char:FindFirstChild("HumanoidRootPart") or char.PrimaryPart
end

-- ── ฟังก์ชันคำนวณการหลบผู้เล่น ──
local function getAvoidanceForce()
    local hrp = getHRP()
    if not hrp or not avoidPlayers then return Vector3.new() end
    
    local force = Vector3.new()
    for _, other in ipairs(Players:GetPlayers()) do
        if other ~= player and other.Character and other.Character:FindFirstChild("HumanoidRootPart") then
            local otherHrp = other.Character.HumanoidRootPart
            local diff = hrp.Position - otherHrp.Position
            local dist = diff.Magnitude
            if dist < 15 then -- ระยะที่จะเริ่มหลบ (15 studs)
                force = force + (diff.Unit * (15 - dist))
            end
        end
    end
    return force
end

local function getClosestFood()
    local hrp = getHRP()
    if not hrp then return nil end
    local best, bestDist = nil, math.huge
    for _, food in ipairs(CollectionService:GetTagged("Food")) do
        if not food or not food.Parent then continue end
        local ok, pos = pcall(function()
            if food:IsA("Model") then return food:GetPivot().Position
            elseif food:IsA("BasePart") then return food.Position end
        end)
        if ok and pos then
            local d = (hrp.Position - pos).Magnitude
            if d < bestDist then
                bestDist = d
                best = { instance = food, position = pos }
            end
        end
    end
    return best
end

local function stopMover()
    if moverConn then moverConn:Disconnect(); moverConn = nil end
end

local function moveTo(targetPos)
    local reached = false
    stopMover()
    moverConn = RunService.Heartbeat:Connect(function(dt)
        local hrp = getHRP()
        if not hrp or not running then reached = true; stopMover(); return end
        
        local avoidForce = getAvoidanceForce()
        local finalTarget = targetPos + avoidForce
        
        local diff = finalTarget - hrp.Position
        local dist = diff.Magnitude
        
        if dist < 2 then reached = true; stopMover(); return end
        
        local step = math.min(tweenSpeed * dt, dist)
        hrp.CFrame = CFrame.new(hrp.Position + diff.Unit * step, Vector3.new(targetPos.X, hrp.Position.Y, targetPos.Z))
    end)
    while not reached and running do task.wait() end
end

