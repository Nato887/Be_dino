local Players           = game:GetService("Players")
local RunService        = game:GetService("RunService")
local CollectionService = game:GetService("CollectionService")
local UserInputService  = game:GetService("UserInputService")

local player = Players.LocalPlayer
if not player.Character then player.CharacterAdded:Wait() end

local running    = false
local tweenSpeed = 100
local moverConn  = nil

-- ── Get the REAL root ──
local function getHRP()
    local char = player.Character
    if not char then return nil end
    for _, v in ipairs(char:GetChildren()) do
        if v.Name == "RootPart" and v:IsA("BasePart") and not v.Massless then
            return v
        end
    end
    return char.PrimaryPart
end

local function getClosestFood()
    local hrp = getHRP()
    if not hrp then return nil end
    local best, bestDist = nil, math.huge
    for _, food in CollectionService:GetTagged("Food") do
        if not food or not food.Parent then continue end
        local ok, pos = pcall(function()
            if food:IsA("Model") then return food:GetPivot().Position
            elseif food:IsA("BasePart") then return food.Position end
        end)
        if ok and pos then
            local d = (hrp.Position - pos).Magnitude
            if d < bestDist then
                bestDist = d
                best = { instance = food, position = pos }
            end
        end
    end
    return best
end

local function stopMover()
    if moverConn then moverConn:Disconnect(); moverConn = nil end
end

-- 🔥 FIX ค้าง + เสถียรขึ้น
local function moveTo(targetPos)
    local reached = false
    local startTime = tick()

    stopMover()
    moverConn = RunService.Heartbeat:Connect(function(dt)
        local hrp = getHRP()
        if not hrp or not running then
            reached = true
            stopMover()
            return
        end

        if not targetPos or typeof(targetPos) ~= "Vector3" then
            reached = true
            stopMover()
            return
        end

        local diff = targetPos - hrp.Position
        local dist = diff.Magnitude

        if dist < 2 then
            reached = true
            stopMover()
            return
        end

        if dist ~= dist then
            reached = true
            stopMover()
            return
        end

        local step = math.min(tweenSpeed * dt, dist)
        hrp.CFrame = CFrame.new(hrp.Position + diff.Unit * step)

        -- ⛔ timeout กันค้าง
        if tick() - startTime > 3 then
            reached = true
            stopMover()
            return
        end
    end)

    while not reached do
        task.wait(0.05)
    end
end

-- ── GUI ──
local gui = Instance.new("ScreenGui")
gui.Name = "FoodCollector"
gui.ResetOnSpawn = false
gui.Parent = player:WaitForChild("PlayerGui")

local panel = Instance.new("Frame", gui)
panel.Size = UDim2.new(0, 270, 0, 215)
panel.Position = UDim2.new(0.5, -135, 0.5, -107)
panel.BackgroundColor3 = Color3.fromRGB(18,18,28)
panel.Active = true
panel.Draggable = true
Instance.new("UICorner", panel)

local title = Instance.new("TextLabel", panel)
title.Size = UDim2.new(1,0,0,30)
title.Text = "🦖 Food Collector"
title.BackgroundTransparency = 1
title.TextColor3 = Color3.fromRGB(255,255,255)

local statusLbl = Instance.new("TextLabel", panel)
statusLbl.Position = UDim2.new(0,0,0,40)
statusLbl.Size = UDim2.new(1,0,0,20)
statusLbl.BackgroundTransparency = 1
statusLbl.Text = "Status: Idle"

local speedLbl = Instance.new("TextLabel", panel)
speedLbl.Position = UDim2.new(0,0,0,70)
speedLbl.Size = UDim2.new(1,0,0,20)
speedLbl.BackgroundTransparency = 1
speedLbl.Text = "Speed: 100"

local track = Instance.new("Frame", panel)
track.Position = UDim2.new(0,10,0,100)
track.Size = UDim2.new(1,-20,0,8)

local fill = Instance.new("Frame", track)
fill.Size = UDim2.new(tweenSpeed/1000,0,1,0)

local knob = Instance.new("TextButton", track)
knob.Size = UDim2.new(0,20,0,20)
knob.Position = UDim2.new(tweenSpeed/1000,-10,0.5,-10)

-- ✅ รองรับมือถือ
local dragging = false
knob.InputBegan:Connect(function(i)
    if i.UserInputType == Enum.UserInputType.MouseButton1 or i.UserInputType == Enum.UserInputType.Touch then
        dragging = true
    end
end)
UserInputService.InputEnded:Connect(function(i)
    if i.UserInputType == Enum.UserInputType.MouseButton1 or i.UserInputType == Enum.UserInputType.Touch then
        dragging = false
    end
end)
UserInputService.InputChanged:Connect(function(i)
    if not dragging then return end
    if i.UserInputType ~= Enum.UserInputType.MouseMovement and i.UserInputType ~= Enum.UserInputType.Touch then return end

    local ratio = math.clamp((i.Position.X - track.AbsolutePosition.X)/track.AbsoluteSize.X,0,1)
    tweenSpeed = math.floor(ratio*1000)
    fill.Size = UDim2.new(ratio,0,1,0)
    knob.Position = UDim2.new(ratio,-10,0.5,-10)
    speedLbl.Text = "Speed: "..tweenSpeed
end)

-- ── Loop ──
local function setStatus(t)
    statusLbl.Text = "Status: "..t
end

local function loop()
    while running do
        local food = getClosestFood()
        if food then
            setStatus("Going "..food.instance.Name)
            moveTo(food.position)
        else
            setStatus("No food")
            task.wait(0.3)
        end
    end
end

-- ปุ่ม
local start = Instance.new("TextButton", panel)
start.Position = UDim2.new(0,10,1,-40)
start.Size = UDim2.new(0.4,0,0,30)
start.Text = "Start"

local stop = Instance.new("TextButton", panel)
stop.Position = UDim2.new(0.55,0,1,-40)
stop.Size = UDim2.new(0.4,0,0,30)
stop.Text = "Stop"

start.MouseButton1Click:Connect(function()
    if running then return end
    running = true
    task.spawn(loop)
end)

stop.MouseButton1Click:Connect(function()
    running = false
    stopMover()
end)
