-- SLIDER (วงกลมลากได้)
local label = Instance.new("TextLabel", frame)
label.Position = UDim2.new(0,10,0,205)
label.Size = UDim2.new(1,-20,0,20)
label.Text = "Speed: "..farmSpeed
label.TextColor3 = Color3.new(1,1,1)
label.BackgroundTransparency = 1

local track = Instance.new("Frame", frame)
track.Position = UDim2.new(0,10,0,230)
track.Size = UDim2.new(1,-20,0,6)
track.BackgroundColor3 = Color3.fromRGB(80,80,80)
Instance.new("UICorner", track)

local knob = Instance.new("Frame", track)
knob.Size = UDim2.new(0,18,0,18)
knob.Position = UDim2.new(farmSpeed/1000,-9,0.5,-9)
knob.BackgroundColor3 = Color3.new(1,1,1)
Instance.new("UICorner", knob).CornerRadius = UDim.new(1,0)

local dragging = false

knob.InputBegan:Connect(function()
    dragging = true
end)

UserInputService.InputEnded:Connect(function()
    dragging = false
end)

UserInputService.InputChanged:Connect(function(input)
    if dragging then
        local delta = math.clamp((input.Position.X - track.AbsolutePosition.X)/track.AbsoluteSize.X,0,1)
        farmSpeed = math.floor(delta*1000)
        knob.Position = UDim2.new(delta,-9,0.5,-9)
        label.Text = "Speed: "..farmSpeed
    end
end)

