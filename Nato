local player = Players.LocalPlayer
if not player.Character then player.CharacterAdded:Wait() end

-- [[ CONFIGURATION ]]
local SAFE_Y = -50
local running = false
local farmSpeed = 100
local avoidSpeed = 150
local avoidDistance = 150
local whiteScreenOn = false
local avoidPlayerEnabled = false

-- [[ UTILS ]]
local function getHRP(target)
    local char = target or player.Character
    if not char then return nil end
    return char:FindFirstChild("HumanoidRootPart") or char.PrimaryPart
end

local function getGrowth(plr)
    local ls = plr:FindFirstChild("leaderstats")
    if ls and ls:FindFirstChild("Growth") then return ls.Growth.Value end
    return 0
end

-- [[ AVOID PLAYER LOGIC ]]
local function getDangerPlayer()
    if not avoidPlayerEnabled then return nil end
    local hrp = getHRP()
    if not hrp then return nil end
    
    local myGrowth = getGrowth(player)
    for _, p in pairs(Players:GetPlayers()) do
        if p ~= player and p.Character then
            local targetHrp = getHRP(p.Character)
            if targetHrp then
                local dist = (hrp.Position - targetHrp.Position).Magnitude
                if dist < avoidDistance and getGrowth(p) > myGrowth then
                    return targetHrp
                end
            end
        end
    end
    return nil
end

-- [[ MOVEMENT SYSTEM ]]
local moverConn
local function stopMover() if moverConn then moverConn:Disconnect() moverConn = nil end end

local function startMovementLoop()
    stopMover()
    moverConn = RunService.Heartbeat:Connect(function(dt)
        local hrp = getHRP()
        if not hrp or not running then return end
        
        -- Anti-Void
        if hrp.Position.Y < SAFE_Y then hrp.CFrame = CFrame.new(hrp.Position.X, 50, hrp.Position.Z) end

        local danger = getDangerPlayer()
        if danger then
            -- Logic: วิ่งหนี (Away from player)
            local direction = (hrp.Position - danger.Position).Unit
            hrp.CFrame = CFrame.new(hrp.Position + (direction * (avoidSpeed * dt)))
        else
            -- Logic: ฟาร์มปกติ
            local foodPos, dist = nil, math.huge
            for _, f in CollectionService:GetTagged("Food") do
                if f and f.Parent then
                    local p = f:IsA("Model") and f:GetPivot().Position or f.Position
                    local d = (hrp.Position - p).Magnitude
                    if d < dist then dist = d foodPos = p end
                end
            end
            
            if foodPos and (foodPos - hrp.Position).Magnitude > 3 then
                local dir = (foodPos - hrp.Position).Unit
                hrp.CFrame = CFrame.new(hrp.Position + (dir * (farmSpeed * dt)))
            end
        end
    end)
end

