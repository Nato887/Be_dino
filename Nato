local Players           = game:GetService("Players")
local RunService        = game:GetService("RunService")
local CollectionService = game:GetService("CollectionService")
local UserInputService  = game:GetService("UserInputService")

local player = Players.LocalPlayer
if not player.Character then player.CharacterAdded:Wait() end

local running   = false
local tweenSpeed = 100
local moverConn  = nil
local AVOID_DISTANCE = 12

-- ── ROOT ─────────────────────────────────────────
local function getHRP()
    local char = player.Character
    if not char then return nil end
    for _, v in ipairs(char:GetChildren()) do
        if v.Name == "RootPart" and v:IsA("BasePart") and not v.Massless then
            return v
        end
    end
    return char.PrimaryPart
end

-- ── FOOD ─────────────────────────────────────────
local function getClosestFood()
    local hrp = getHRP()
    if not hrp then return nil end
    local best, bestDist = nil, math.huge
    for _, food in ipairs(CollectionService:GetTagged("Food")) do
        if not food or not food.Parent then continue end
        local pos
        if food:IsA("Model") then pos = food:GetPivot().Position
        elseif food:IsA("BasePart") then pos = food.Position end
        if pos then
            local dist = (hrp.Position - pos).Magnitude
            if dist < bestDist then
                bestDist = dist
                best = {instance = food, position = pos}
            end
        end
    end
    return best
end

-- ── PLAYER AVOID ─────────────────────────────────
local function getClosestPlayer()
    local hrp = getHRP()
    if not hrp then return nil end
    local closest, distMin = nil, math.huge
    for _, plr in ipairs(Players:GetPlayers()) do
        if plr ~= player and plr.Character then
            local root = plr.Character:FindFirstChild("RootPart") or plr.Character:FindFirstChild("HumanoidRootPart")
            if root then
                local d = (hrp.Position - root.Position).Magnitude
                if d < distMin then
                    distMin = d
                    closest = root
                end
            end
        end
    end
    return closest, distMin
end

-- ── MOVE ─────────────────────────────────────────
local function stopMover()
    if moverConn then
        moverConn:Disconnect()
        moverConn = nil
    end
end

local function moveTo(targetPos)
    local hrp = getHRP()
    if not hrp or not hrp.Parent then return end

    stopMover()
    local reached = false

    moverConn = RunService.Heartbeat:Connect(function(dt)
        if not hrp or not hrp.Parent or not running then
            reached = true
            stopMover()
            return
        end
        local direction = targetPos - hrp.Position
        local dist = direction.Magnitude
        if dist < 2 then
            reached = true
            stopMover()
            return
        end

        local moveDir = direction.Unit
        local threat, threatDist = getClosestPlayer()
        if threat and threatDist < AVOID_DISTANCE then
            local avoid = (hrp.Position - threat.Position)
            if avoid.Magnitude > 0 then
                moveDir = (moveDir + avoid.Unit * 2).Unit
            end
        end

        local step = math.min(tweenSpeed * 2 * dt, dist) -- ปรับ multiplier 2
        hrp.CFrame = CFrame.new(hrp.Position + moveDir * step)
    end)

    task.spawn(function()
        while not reached do task.wait(0.03) end
    end)
end

