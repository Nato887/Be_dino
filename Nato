-- ── ระบบ Teleport Step ต่อเนื่อง ──
task.spawn(function()
    local hrp = player.Character or player.CharacterAdded:Wait()
    hrp = hrp:WaitForChild("HumanoidRootPart", 5)
    while true do
        RunService.RenderStepped:Wait()
        if running and hrp then
            if not targetFood or not targetFood.instance or not targetFood.instance.Parent then
                targetFood = getClosestFood()
            end

            if targetFood and targetFood.instance and targetFood.instance.Parent then
                local targetPos = Vector3.new(targetFood.position.X, hrp.Position.Y, targetFood.position.Z)
                local direction = targetPos - hrp.Position
                local dist = direction.Magnitude

                if dist > 0.5 then
                    local stepDistance = math.max(speed * 0.05, 0.5)
                    local moveVector = direction.Unit * math.min(stepDistance, dist)

                    -- ตรวจสอบผู้เล่นคนอื่น
                    for _, other in ipairs(Players:GetPlayers()) do
                        if other ~= player and other.Character and other.Character:FindFirstChild("HumanoidRootPart") then
                            local otherPos = other.Character.HumanoidRootPart.Position
                            if (hrp.Position + moveVector - otherPos).Magnitude < 3 then
                                moveVector = Vector3.new(0, 0, 0)
                                break
                            end
                        end
                    end

                    hrp.CFrame = CFrame.lookAt(hrp.Position + moveVector, targetPos)
                else
                    targetFood = nil
                end
            end
        end
    end
end)
