local function createToggle(parent, name, key)
	local b = Instance.new("TextButton", parent)
	b.Size = UDim2.new(0.95, 0, 0, 45)
	b.BackgroundColor3 = Color3.fromRGB(30, 25, 50)
	b.Text = "   "..name
	b.TextColor3 = Color3.new(1,1,1)
	b.BorderSizePixel = 0
	Instance.new("UICorner", b)

	b.MouseButton1Click:Connect(function()
		settings[key] = not settings[key]
		b.BackgroundColor3 = settings[key] and Color3.fromRGB(130,60,255) or Color3.fromRGB(30,25,50)
	end)
end

local function createBtn(parent, name, func)
	local b = Instance.new("TextButton", parent)
	b.Size = UDim2.new(0.95, 0, 0, 40)
	b.Text = name
	b.BackgroundColor3 = Color3.fromRGB(35,30,55)
	b.TextColor3 = Color3.new(1,1,1)
	b.BorderSizePixel = 0
	Instance.new("UICorner", b)
	b.MouseButton1Click:Connect(func)
end

