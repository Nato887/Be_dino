local Players           = game:GetService("Players")
local RunService        = game:GetService("RunService")
local CollectionService = game:GetService("CollectionService")
local UserInputService  = game:GetService("UserInputService")
local VirtualInputManager = game:GetService("VirtualInputManager")

local player = Players.LocalPlayer

-- ================= SETTINGS (V15) =================
local settings = {
    huntWeaker = false,
    avoidPlayers = false,
    antiVoid = true,
    antiAFK = true,
    autoBoss = false, -- ✅ ระบบ Auto Boss ใหม่
    tweenSpeed = 150
}

-- ── 🦖 ระบบ Auto Boss (Auto QTE 0.15s) ──
local function handleAutoBoss()
    if not settings.autoBoss then return end
    
    -- ค้นหา UI ของบอสที่มักจะมีปุ่ม QTE โผล่มา
    local playerGui = player:WaitForChild("PlayerGui")
    -- หมายเหตุ: ชื่อ UI "QTE" หรือ "SkillCheck" อาจเปลี่ยนไปตามเกม Be Dino
    local qteFrame = playerGui:FindFirstChild("QTE", true) or playerGui:FindFirstChild("SkillCheck", true)
    
    if qteFrame and qteFrame.Visible then
        task.wait(0.15) -- ⚡ หน่วงเวลา 0.15 วินาที ตามรูปภาพ
        -- จำลองการกดคลิกซ้าย หรือกดปุ่มที่เกมกำหนดสำหรับ QTE
        VirtualInputManager:SendMouseButtonEvent(0, 0, 0, true, game, 1)
        task.wait(0.05)
        VirtualInputManager:SendMouseButtonEvent(0, 0, 0, false, game, 1)
    end
end

-- ================= GUI Nato Hub V15 =================
local gui = Instance.new("ScreenGui", player:WaitForChild("PlayerGui"))
gui.Name = "NatoHub_V15"; gui.ResetOnSpawn = false

local panel = Instance.new("Frame", gui)
panel.Size = UDim2.new(0, 280, 0, 460); panel.Position = UDim2.new(0.5, -140, 0.5, -230)
panel.BackgroundColor3 = Color3.fromRGB(15, 10, 28); Instance.new("UICorner", panel)

-- [ ส่วนหัวข้อ Title เหมือนเดิม... ]

local function createToggle(name, sub, pos, prop)
    local btn = Instance.new("TextButton", panel)
    btn.Size = UDim2.new(0, 250, 0, 50); btn.Position = UDim2.new(0.5, -125, 0, pos)
    btn.BackgroundColor3 = settings[prop] and Color3.fromRGB(130, 60, 255) or Color3.fromRGB(30, 25, 55)
    btn.Text = ""; Instance.new("UICorner", btn)
    
    local ml = Instance.new("TextLabel", btn)
    ml.Size = UDim2.new(1, 0, 0, 25); ml.Position = UDim2.new(0, 12, 0, 5); ml.Text = name; ml.TextColor3 = Color3.new(1,1,1); ml.Font = Enum.Font.GothamBold; ml.TextSize = 13; ml.BackgroundTransparency = 1; ml.TextXAlignment = Enum.TextXAlignment.Left
    
    local sl = Instance.new("TextLabel", btn)
    sl.Size = UDim2.new(1, 0, 0, 15); sl.Position = UDim2.new(0, 12, 0, 25); sl.Text = sub; sl.TextColor3 = Color3.fromRGB(140, 140, 160); sl.Font = Enum.Font.Gotham; sl.TextSize = 9; sl.BackgroundTransparency = 1; sl.TextXAlignment = Enum.TextXAlignment.Left

    btn.MouseButton1Click:Connect(function()
        settings[prop] = not settings[prop]
        btn.BackgroundColor3 = settings[prop] and Color3.fromRGB(130, 60, 255) or Color3.fromRGB(30, 25, 55)
    end)
end

-- เพิ่มรายการเมนูตามรูปใหม่ของคุณ
createToggle("Auto Boss", "Fires attack within 0.15s of each QTE", 50, "autoBoss")
createToggle("Eat Smaller Players", "Hunt Growth > 5000 when safe", 105, "huntWeaker")
createToggle("Avoid Players", "TP away from bigger dinos (150s)", 160, "avoidPlayers")
createToggle("Anti Void", "Prevents falling into void", 215, "antiVoid")
createToggle("Anti AFK", "Prevent AFK kick", 270, "antiAFK")

-- [ ส่วน Speed Slider และปุ่ม Nato ลอย เหมือนเดิม... ]

-- ================= MAIN LOOP =================
RunService.Heartbeat:Connect(function(dt)
    local hrp = getHRP()
    if not hrp then return end

    -- 1. เรียกใช้งาน Auto Boss
    handleAutoBoss()

    -- 2. ระบบ Anti-Void
    if settings.antiVoid and hrp.Position.Y < -50 then
        hrp.CFrame = CFrame.new(hrp.Position.X, 120, hrp.Position.Z); return
    end

    -- 3. ระบบหนีตัวใหญ่
    if settings.avoidPlayers then
        for _, p in ipairs(Players:GetPlayers()) do
            if p ~= player and p.Character and p.Character:FindFirstChild("HumanoidRootPart") then
                local eRoot = p.Character.HumanoidRootPart
                if eRoot.Size.Magnitude > hrp.Size.Magnitude and (hrp.Position - eRoot.Position).Magnitude < 150 then
                    hrp.CFrame = CFrame.new(hrp.Position + (hrp.Position - eRoot.Position).Unit * (settings.tweenSpeed * dt))
                    return
                end
            end
        end
    end

    -- 4. ระบบล่าผู้เล่น (Eat Smaller)
    local target = getTargetPlayer() -- ฟังก์ชันเดิมที่เช็ค Growth > 5000
    if target then
        local diff = target.Position - hrp.Position
        if diff.Magnitude > 1.5 then
            hrp.CFrame = CFrame.new(hrp.Position + diff.Unit * (settings.tweenSpeed * dt))
        end
    end
end)
