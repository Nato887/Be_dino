-- ================= CORE LOGIC (Tween & Movement) =================
RunService.Heartbeat:Connect(function(dt)
    local hrp = getHRP()
    if not hrp then return end

    if settings.antiVoid and hrp.Position.Y < -60 then
        hrp.Velocity = Vector3.new(0,0,0); hrp.CFrame = CFrame.new(hrp.Position.X, 150, hrp.Position.Z); return
    end

    if settings.avoidPlayers then
        for _, p in ipairs(Players:GetPlayers()) do
            if p ~= player and p.Character and p.Character:FindFirstChild("HumanoidRootPart") then
                local eRoot = p.Character.HumanoidRootPart
                if (hrp.Position - eRoot.Position).Magnitude < 150 and eRoot.Size.Magnitude > hrp.Size.Magnitude then
                    local escapeDir = (hrp.Position - eRoot.Position).Unit
                    hrp.CFrame = hrp.CFrame + (escapeDir * settings.tweenSpeed * dt)
                    hrp.Velocity = Vector3.new(0, 0.1, 0); return
                end
            end
        end
    end

    local target = nil
    if settings.huntWeaker then
        for _, p in ipairs(Players:GetPlayers()) do
            if p ~= player and p.Character and p.Character:FindFirstChild("HumanoidRootPart") then
                local eRoot = p.Character.HumanoidRootPart
                if eRoot.Size.Magnitude < hrp.Size.Magnitude and eRoot.Size.Magnitude > 20 then target = eRoot; break end
            end
        end
    end

    if not target and settings.autoFood then
        for _, v in ipairs(CollectionService:GetTagged("Food")) do if v and v.Parent then target = v; break end end
    end

    if target then
        local tPos = (target:IsA("Model") and target:GetPivot().Position) or target.Position
        hrp.CFrame = hrp.CFrame + ((tPos - hrp.Position).Unit * settings.tweenSpeed * dt)
        hrp.Velocity = Vector3.new(0, 0.1, 0)
    end
end)

