local currentTween
local startTime = os.time()

-- UTILS
local function getHRP()
    local c = player.Character
    return c and (c:FindFirstChild("HumanoidRootPart") or c.PrimaryPart)
end

-- FOOD FINDER
local function getNearestFood()
    local hrp = getHRP()
    if not hrp then return nil end

    local closest, dist = nil, math.huge
    for _, f in ipairs(CollectionService:GetTagged("Food")) do
        if f and f.Parent then
            local p = f:IsA("Model") and f:GetPivot().Position or f.Position
            local d = (hrp.Position - p).Magnitude
            if d < dist then
                dist = d
                closest = p
            end
        end
    end
    return closest
end

-- SAFE TWEEN (ไม่ตกแมพ)
local function tweenTo(pos)
    local hrp = getHRP()
    if not hrp then return end

    pos = Vector3.new(pos.X, math.max(pos.Y, 5), pos.Z)

    if currentTween then currentTween:Cancel() end

    local dist = (hrp.Position - pos).Magnitude
    local time = math.clamp(dist / farmSpeed, 0.15, 3)

    currentTween = TweenService:Create(hrp,
        TweenInfo.new(time, Enum.EasingStyle.Linear),
        {CFrame = CFrame.new(pos)}
    )
    currentTween:Play()
end

-- LOOP (แก้ START ไม่ทำงาน)
RunService.Heartbeat:Connect(function()
    if not running then return end

    local target = getNearestFood()
    if target then
        tweenTo(target)
    end
end)

-- FAST MODE
local function runFast()
    for _, v in pairs(workspace:GetDescendants()) do
        if v:IsA("BasePart") then
            local n = v.Name:lower()
            if n:find("tree") or n:find("rock") then
                v:Destroy()
            end
        end
    end
end

