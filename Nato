local RunService = game:GetService("RunService")
local CollectionService = game:GetService("CollectionService")
local UserInputService = game:GetService("UserInputService")
local VirtualUser = game:GetService("VirtualUser")
local TweenService = game:GetService("TweenService")

local player = Players.LocalPlayer
if not player.Character then player.CharacterAdded:Wait() end

-- CONFIG
local SAFE_Y = -50
local running = false
local farmSpeed = 100
local avoidSpeed = 150
local avoidDistance = 150
local whiteScreenOn = false
local avoidPlayerEnabled = false
local fastMode = false

-- TWEEN
local currentTween = nil

-- UTILS
local function getHRP(target)
    local char = target or player.Character
    if not char then return nil end
    return char:FindFirstChild("HumanoidRootPart") or char.PrimaryPart
end

local function getGrowth(plr)
    local ls = plr:FindFirstChild("leaderstats")
    if ls and ls:FindFirstChild("Growth") then return ls.Growth.Value end
    return 0
end

-- FAST MODE
local function runFastMode()
    for _, v in pairs(workspace:GetDescendants()) do
        if v:IsA("BasePart") or v:IsA("MeshPart") then
            local n = v.Name:lower()
            if n:find("tree") or n:find("rock") or n:find("mountain") or n:find("bush") then
                v:Destroy()
            end
        end
    end
end

-- AVOID PLAYER
local function getDangerPlayer()
    if not avoidPlayerEnabled then return nil end
    local hrp = getHRP()
    if not hrp then return nil end
    local myGrowth = getGrowth(player)

    local nearest = nil
    local minDist = avoidDistance + 30
    for _, p in pairs(Players:GetPlayers()) do
        if p ~= player and p.Character then
            local tHrp = getHRP(p.Character)
            if tHrp then
                local d = (hrp.Position - tHrp.Position).Magnitude
                if d < minDist and getGrowth(p) > myGrowth then
                    minDist = d
                    nearest = tHrp
                end
            end
        end
    end
    return nearest
end

-- STOP TWEEN
local function stopTween()
    if currentTween then
        currentTween:Cancel()
        currentTween = nil
    end
end

-- TWEEN MOVE
local function tweenTo(targetPos, speed)
    local hrp = getHRP()
    if not hrp then return end

    stopTween()

    local dist = (hrp.Position - targetPos).Magnitude
    local time = dist / speed

    local tween = TweenService:Create(
        hrp,
        TweenInfo.new(time, Enum.EasingStyle.Linear),
        {CFrame = CFrame.new(targetPos)}
    )

    currentTween = tween
    tween:Play()
end

-- LOOP
local moverConn
local function stopMover()
    if moverConn then moverConn:Disconnect() moverConn = nil end
    stopTween()
end

local function startMovementLoop()
    stopMover()
    moverConn = RunService.Heartbeat:Connect(function()
        local hrp = getHRP()
        if not hrp or not running then return end

        if hrp.Position.Y < SAFE_Y then
            hrp.CFrame = CFrame.new(0, 50, 0)
            stopTween()
            return
        end

        local danger = getDangerPlayer()

        if danger then
            local dir = (hrp.Position - danger.Position).Unit
            local target = hrp.Position + dir * 100
            tweenTo(target, avoidSpeed)
        else
            local foodPos, dist = nil, math.huge
            for _, f in CollectionService:GetTagged("Food") do
                if f and f.Parent then
                    local p = f:IsA("Model") and f:GetPivot().Position or f.Position
                    local d = (hrp.Position - p).Magnitude
                    if d < dist then
                        dist = d
                        foodPos = p
                    end
                end
            end

            if foodPos then
                tweenTo(foodPos, farmSpeed)
            end
        end
    end)
end

