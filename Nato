-- ── บริการหลัก ──
local Players = game:GetService("Players")
local RunService = game:GetService("RunService")
local CollectionService = game:GetService("CollectionService")
local UserInputService = game:GetService("UserInputService")

local player = Players.LocalPlayer
local running = false
local speed = 100 -- ระยะ teleport ต่อ step
local targetFood = nil

-- ── ฟังก์ชันพื้นฐาน ──
local function getHRP()
    return player.Character and player.Character:FindFirstChild("HumanoidRootPart")
end

local function getClosestFood()
    local hrp = getHRP()
    if not hrp then return nil end
    local best, bestDist = nil, math.huge
    for _, food in ipairs(CollectionService:GetTagged("Food")) do
        if food and food.Parent then
            local pos = (food:IsA("Model") and food:GetPivot().Position) or (food:IsA("BasePart") and food.Position)
            if pos then
                local d = (hrp.Position - pos).Magnitude
                if d < bestDist then
                    bestDist = d
                    best = { instance = food, position = pos }
                end
            end
        end
    end
    return best
end

-- ── GUI มือถือ ──
local gui = Instance.new("ScreenGui", player:WaitForChild("PlayerGui"))
gui.Name = "BeDinoMobile"
gui.ResetOnSpawn = false

local panel = Instance.new("Frame", gui)
panel.Size = UDim2.new(0, 220, 0, 180)
panel.Position = UDim2.new(0.5, -110, 0.2, 0)
panel.BackgroundColor3 = Color3.fromRGB(35, 35, 45)
panel.Active = true
panel.Draggable = true
Instance.new("UICorner", panel)

local title = Instance.new("TextLabel", panel)
title.Size = UDim2.new(1, 0, 0, 35)
title.Text = "🦖 BE DINO MOBILE"
title.TextColor3 = Color3.new(1,1,1)
title.BackgroundColor3 = Color3.fromRGB(55, 55, 85)
Instance.new("UICorner", title)

local speedLbl = Instance.new("TextLabel", panel)
speedLbl.Size = UDim2.new(1, 0, 0, 25)
speedLbl.Position = UDim2.new(0, 0, 0, 40)
speedLbl.Text = "Speed: " .. speed
speedLbl.TextColor3 = Color3.new(1,1,1)
speedLbl.BackgroundTransparency = 1

-- Slider มือถือ
local sliderBg = Instance.new("Frame", panel)
sliderBg.Size = UDim2.new(0.8, 0, 0, 15)
sliderBg.Position = UDim2.new(0.1, 0, 0, 70)
sliderBg.BackgroundColor3 = Color3.fromRGB(20, 20, 20)
local sliderFill = Instance.new("Frame", sliderBg)
sliderFill.Size = UDim2.new(speed/500, 0, 1, 0)
sliderFill.BackgroundColor3 = Color3.fromRGB(0, 200, 255)
local sliderBtn = Instance.new("TextButton", sliderBg)
sliderBtn.Size = UDim2.new(1, 0, 1, 0)
sliderBtn.BackgroundTransparency = 1
sliderBtn.Text = ""

local function updateSlider(input)
    local inputPos = input.Position.X
    local relX = math.clamp((inputPos - sliderBg.AbsolutePosition.X) / sliderBg.AbsoluteSize.X, 0, 1)
    speed = math.max(10, math.floor(relX * 500))
    sliderFill.Size = UDim2.new(relX, 0, 1, 0)
    speedLbl.Text = "Speed: " .. speed
end

sliderBtn.InputBegan:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.Touch or input.UserInputType == Enum.UserInputType.MouseButton1 then
        local connection
        connection = RunService.RenderStepped:Connect(function()
            local currentInput = UserInputService:GetMouseLocation()
            updateSlider({Position = currentInput})
        end)
        local endRef
        endRef = UserInputService.InputEnded:Connect(function(inputEnd)
            if inputEnd.UserInputType == Enum.UserInputType.Touch or inputEnd.UserInputType == Enum.UserInputType.MouseButton1 then
                connection:Disconnect()
                endRef:Disconnect()
            end
        end)
    end
end)

