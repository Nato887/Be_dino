local Players = game:GetService("Players")
local RunService = game:GetService("RunService")
local CollectionService = game:GetService("CollectionService")
local UserInputService = game:GetService("UserInputService")
local HttpService = game:GetService("HttpService")
local TeleportService = game:GetService("TeleportService")
local VirtualUser = game:GetService("VirtualUser")

local player = Players.LocalPlayer

-- SETTINGS
local settings = {
    autoFood = false,
    huntWeaker = false,
    avoidPlayers = false,
    antiVoid = true,
    antiAFK = false,
    autoBoss = false,
    tweenSpeed = 150,
}

-- GUI (สว่างขึ้น)
local gui = Instance.new("ScreenGui", player:WaitForChild("PlayerGui"))
gui.Name = "NatoHub_Bright"

local main = Instance.new("Frame", gui)
main.Size = UDim2.new(0, 520, 0, 340)
main.Position = UDim2.new(0.5, -260, 0.5, -170)
main.BackgroundColor3 = Color3.fromRGB(40, 40, 60) -- สว่างขึ้น
main.Active = true
main.Draggable = true
Instance.new("UICorner", main)

local sidebar = Instance.new("Frame", main)
sidebar.Size = UDim2.new(0, 140, 1, 0)
sidebar.BackgroundColor3 = Color3.fromRGB(60, 60, 90)

local container = Instance.new("Frame", main)
container.Size = UDim2.new(1, -150, 1, -20)
container.Position = UDim2.new(0, 145, 0, 10)
container.BackgroundTransparency = 1

local tabs = {
    Tab1 = Instance.new("Frame", container),
    Tab2 = Instance.new("Frame", container)
}

for name, frame in pairs(tabs) do
    frame.Size = UDim2.new(1,0,1,0)
    frame.Visible = (name == "Tab1")
    frame.BackgroundTransparency = 1
    local layout = Instance.new("UIListLayout", frame)
    layout.Padding = UDim.new(0,10)
end

local function showTab(t)
    for n,f in pairs(tabs) do
        f.Visible = (n==t)
    end
end

local function createTabBtn(name, y, tab)
    local b = Instance.new("TextButton", sidebar)
    b.Size = UDim2.new(1,-10,0,40)
    b.Position = UDim2.new(0,5,0,y)
    b.Text = name
    b.TextColor3 = Color3.new(1,1,1)
    b.BackgroundColor3 = Color3.fromRGB(80,80,120)
    Instance.new("UICorner", b)

    b.MouseButton1Click:Connect(function()
        showTab(tab)
    end)
end

createTabBtn("Automation", 60, "Tab1")
createTabBtn("Boss/Misc", 110, "Tab2")

-- Toggle
local function createToggle(parent, text, key)
    local b = Instance.new("TextButton", parent)
    b.Size = UDim2.new(1,0,0,45)
    b.Text = text
    b.TextColor3 = Color3.new(1,1,1)
    b.BackgroundColor3 = Color3.fromRGB(90,90,140)
    Instance.new("UICorner", b)

    b.MouseButton1Click:Connect(function()
        settings[key] = not settings[key]
        b.BackgroundColor3 = settings[key] and Color3.fromRGB(140,100,255) or Color3.fromRGB(90,90,140)
    end)
end

-- TAB1
createToggle(tabs.Tab1,"Auto Food","autoFood")
createToggle(tabs.Tab1,"Hunt Smaller","huntWeaker")
createToggle(tabs.Tab1,"Avoid Players","avoidPlayers")
createToggle(tabs.Tab1,"Anti Void","antiVoid")

-- TAB2 (แก้ให้มีของแล้ว)
createToggle(tabs.Tab2,"Kill Boss (Auto)","autoBoss")

-- Anti AFK
local afkBtn = Instance.new("TextButton", tabs.Tab2)
afkBtn.Size = UDim2.new(1,0,0,45)
afkBtn.Text = "Anti AFK: OFF"
afkBtn.BackgroundColor3 = Color3.fromRGB(90,90,140)
Instance.new("UICorner", afkBtn)

afkBtn.MouseButton1Click:Connect(function()
    settings.antiAFK = not settings.antiAFK
    afkBtn.Text = "Anti AFK: "..(settings.antiAFK and "ON" or "OFF")
end)

-- Server Hop
local hopBtn = Instance.new("TextButton", tabs.Tab2)
hopBtn.Size = UDim2.new(1,0,0,45)
hopBtn.Text = "Server Hop"
hopBtn.BackgroundColor3 = Color3.fromRGB(90,90,140)
Instance.new("UICorner", hopBtn)

hopBtn.MouseButton1Click:Connect(function()
    local s = HttpService:JSONDecode(game:HttpGet("https://games.roblox.com/v1/games/"..game.PlaceId.."/servers/Public?limit=50"))
    for _,v in pairs(s.data) do
        if v.playing < v.maxPlayers then
            TeleportService:TeleportToPlaceInstance(game.PlaceId,v.id,player)
            break
        end
    end
end)

-- Anti AFK Logic
player.Idled:Connect(function()
    if settings.antiAFK then
        VirtualUser:CaptureController()
        VirtualUser:ClickButton2(Vector2.new())
    end
end)

-- AUTO BOSS
RunService.RenderStepped:Connect(function()
    if not settings.autoBoss then return end

    local pg = player:FindFirstChild("PlayerGui")
    if not pg then return end

    local gui = pg:FindFirstChild("BossBar") or pg:FindFirstChild("Minigame")
    if not gui then return end

    local bar = gui:FindFirstChildWhichIsA("Frame")
    if not bar then return end

    local green = bar:FindFirstChild("Green") or bar:FindFirstChild("Target")
    local white = bar:FindFirstChild("Slider") or bar:FindFirstChild("Cursor")

    if green and white then
        local g1 = green.AbsolutePosition.X
        local g2 = g1 + green.AbsoluteSize.X
        local w = white.AbsolutePosition.X + white.AbsoluteSize.X/2

        if w > g1 and w < g2 then
            VirtualUser:Button1Down(Vector2.new())
            VirtualUser:Button1Up(Vector2.new())
        end
    end
end)

