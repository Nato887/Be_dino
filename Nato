Instance.new("UICorner", knob).CornerRadius = UDim.new(1,0)

local dragging = false

knob.InputBegan:Connect(function() dragging = true end)
UserInputService.InputEnded:Connect(function() dragging = false end)

UserInputService.InputChanged:Connect(function(input)
    if dragging then
        local delta = math.clamp((input.Position.X - track.AbsolutePosition.X)/track.AbsoluteSize.X,0,1)
        farmSpeed = math.floor(delta*1000)
        knob.Position = UDim2.new(delta,-10,0.5,-10)
        speedText.Text = "Speed: "..farmSpeed
    end
end)

