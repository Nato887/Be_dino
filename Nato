-- ── Get the REAL root (Fixed for Dino Models) ──
local function getHRP()
    local char = player.Character
    if not char then return nil end
    -- ค้นหา RootPart หรือ PrimaryPart ที่มีอยู่จริงในโมเดล
    local hrp = char:FindFirstChild("RootPart") or char:FindFirstChild("HumanoidRootPart") or char.PrimaryPart
    return hrp
end

-- ── Get Growth (Fixed for Scale) ──
local function getGrowth(char)
    if not char then return 0 end
    local hrp = char:FindFirstChild("RootPart") or char:FindFirstChild("HumanoidRootPart") or char.PrimaryPart
    if hrp then
        return hrp.Size.Magnitude * 1000 -- ปรับตัวคูณให้เห็นความต่างชัดเจน
    end
    return 0
end

