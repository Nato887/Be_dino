-- ================= CORE LOGIC (RE-FIXED) =================
RunService.Heartbeat:Connect(function(dt)
    local hrp = getHRP()
    if not hrp then return end
    local myG = getGrowth(player.Character)

    -- 🛡️ Anti Void
    if settings.antiVoid and hrp.Position.Y < -50 then
        hrp.Velocity = Vector3.new(0,0,0); hrp.CFrame = CFrame.new(hrp.Position.X, 150, hrp.Position.Z); return
    end

    local targetPos = nil

    -- 🏃 1. ระบบหนี (Avoid) - Priority สูงสุด
    if settings.avoidPlayers then
        for _, p in ipairs(Players:GetPlayers()) do
            if p ~= player and p.Character then
                local eR = p.Character:FindFirstChild("RootPart") or p.Character:FindFirstChild("HumanoidRootPart") or p.Character.PrimaryPart
                if eR then
                    local dist = (hrp.Position - eR.Position).Magnitude
                    if dist < 150 and getGrowth(p.Character) > myG then
                        local escapeDir = (hrp.Position - eR.Position).Unit
                        hrp.CFrame = CFrame.new(hrp.Position + (escapeDir * settings.tweenSpeed * dt))
                        return -- หนีก่อน ห้ามขยับไปที่อื่น
                    end
                end
            end
        end
    end

    -- 🦖 2. ระบบล่า (Hunt 10k+)
    if settings.huntWeaker then
        local minDist = math.huge
        for _, p in ipairs(Players:GetPlayers()) do
            if p ~= player and p.Character then
                local eR = p.Character:FindFirstChild("RootPart") or p.Character:FindFirstChild("HumanoidRootPart") or p.Character.PrimaryPart
                local eG = getGrowth(p.Character)
                if eR and eG < myG and eG >= 10000 then
                    local d = (hrp.Position - eR.Position).Magnitude
                    if d < minDist then minDist = d; targetPos = eR.Position end
                end
            end
        end
    end

    -- 🍖 3. ระบบหาอาหาร (Auto Food) - Fixed Position Search
    if not targetPos and settings.autoFood then
        local minDist = math.huge
        -- ค้นหาอาหารจากทั้ง Tag และ ชื่อวัตถุ
        for _, v in ipairs(workspace:GetDescendants()) do
            if (v.Name:find("Food") or v.Name:find("Meat") or CollectionService:HasTag(v, "Food")) and v:IsA("BasePart") then
                local d = (hrp.Position - v.Position).Magnitude
                if d < minDist then minDist = d; targetPos = v.Position end
            end
        end
    end

    -- Movement Execution (Tween)
    if targetPos then
        local moveDir = (targetPos - hrp.Position).Unit
        -- ใช้ CFrame.new(ตำแหน่งเรา + ทิศทางพุ่งไป, มองไปที่เป้าหมาย)
        hrp.CFrame = CFrame.new(hrp.Position + (moveDir * settings.tweenSpeed * dt), targetPos)
        hrp.Velocity = Vector3.new(0, 0.1, 0)
    end
end)

