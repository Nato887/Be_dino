-- ── Get Root Part ──
local function getHRP()
    local char = player.Character
    if not char then return nil end
    for _, v in ipairs(char:GetChildren()) do
        if v.Name == "RootPart" and v:IsA("BasePart") and not v.Massless then
            return v
        end
    end
    return char.PrimaryPart
end

-- ── Get Growth ──
local function getGrowth(char)
    if not char then return 0 end
    local root = char:FindFirstChild("RootPart") or char:FindFirstChild("HumanoidRootPart")
    return root and (root.Size.X * root.Size.Y * root.Size.Z) or 0
end

