-- ROOT
local function getHRP()
    local char = player.Character
    if not char then return nil end
    return char:FindFirstChild("HumanoidRootPart") or char.PrimaryPart
end

-- FAST MODE LOOP
local function optimizeMapLoop()
    while fastMode do
        for _,v in pairs(workspace:GetDescendants()) do
            if v:IsA("BasePart") or v:IsA("MeshPart") then
                local n = v.Name:lower()
                if not n:find("floor") and not n:find("terrain") then
                    if n:find("tree") or n:find("rock") or n:find("mountain") or n:find("bush") then
                        v.LocalTransparencyModifier = 1
                        v.CanCollide = false
                    end
                end
            end
        end
        task.wait(0.1)
    end
end

-- FOOD
local function getClosestFood()
    local hrp = getHRP()
    if not hrp then return nil end
    local best, dist = nil, math.huge
    for _,f in CollectionService:GetTagged("Food") do
        if f and f.Parent then
            local pos = f:IsA("Model") and f:GetPivot().Position or f.Position
            local d = (hrp.Position - pos).Magnitude
            if d < dist then
                dist = d
                best = pos
            end
        end
    end
    return best
end

-- ESCAPE CHECK
local function getEscapePlayer()
    local hrp = getHRP()
    if not hrp then return nil end

    local myGrowth = player.Character:FindFirstChild("Growth") and player.Character.Growth.Value or 0

    for _,p in ipairs(Players:GetPlayers()) do
        if p ~= player and p.Character then
            local root = p.Character:FindFirstChild("HumanoidRootPart")
            local growth = p.Character:FindFirstChild("Growth")
            if root and growth then
                local d = (hrp.Position - root.Position).Magnitude
                if d <= DETECT_DISTANCE and growth.Value > myGrowth then
                    return root
                end
            end
        end
    end
end

local function getEscapePos(enemy)
    local hrp = getHRP()
    local dir = (hrp.Position - enemy.Position).Unit
    return hrp.Position + dir * ESCAPE_DISTANCE
end

-- MOVE
local function stopMover()
    if moverConn then moverConn:Disconnect() moverConn = nil end
end

local function moveTo(pos)
    stopMover()
    moverConn = RunService.Heartbeat:Connect(function(dt)
        local hrp = getHRP()
        if not hrp or not running then return end

        if hrp.Position.Y < SAFE_Y then
            hrp.CFrame = CFrame.new(hrp.Position.X,50,hrp.Position.Z)
        end

        local diff = pos - hrp.Position
        local dist = diff.Magnitude
        if dist < 3 then return end

        local step = math.min(tweenSpeed * dt, dist)
        hrp.CFrame = CFrame.new(hrp.Position + diff.Unit * step)
    end)
end

local function moveToEscape(pos)
    local old = tweenSpeed
    tweenSpeed = escapeSpeed
    moveTo(pos)
    tweenSpeed = old
end

