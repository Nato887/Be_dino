local Players           = game:GetService("Players")
local CollectionService = game:GetService("CollectionService")
local UserInputService  = game:GetService("UserInputService")
local VirtualUser       = game:GetService("VirtualUser")

local player = Players.LocalPlayer
if not player.Character then player.CharacterAdded:Wait() end

-- ✅ Anti AFK
player.Idled:Connect(function()
    VirtualUser:Button2Down(Vector2.new(0,0), workspace.CurrentCamera.CFrame)
    task.wait(1)
    VirtualUser:Button2Up(Vector2.new(0,0), workspace.CurrentCamera.CFrame)
end)

local running = false
local busy = false

-- Root
local function getHRP()
    local char = player.Character
    if not char then return nil end
    for _, v in ipairs(char:GetChildren()) do
        if v.Name == "RootPart" and v:IsA("BasePart") and not v.Massless then
            return v
        end
    end
    return char.PrimaryPart
end

-- 🛡️ กันตกแมพ
local function safeCFrame(pos)
    return CFrame.new(pos + Vector3.new(0, 6, 0))
end

-- 🔥 หลบผู้เล่น 100
local function isPlayerNear(pos)
    for _, plr in ipairs(Players:GetPlayers()) do
        if plr ~= player and plr.Character then
            local root = plr.Character:FindFirstChild("HumanoidRootPart") or plr.Character.PrimaryPart
            if root and (root.Position - pos).Magnitude < 100 then
                return true
            end
        end
    end
    return false
end

-- 🔥 หาอาหาร (คัดโซนโล่ง)
local function getManyFoods(limit)
    local hrp = getHRP()
    if not hrp then return {} end

    local foods = {}

    for _, food in CollectionService:GetTagged("Food") do
        if food and food.Parent then
            local ok, pos = pcall(function()
                if food:IsA("Model") then return food:GetPivot().Position
                elseif food:IsA("BasePart") then return food.Position end
            end)

            if ok and pos and not isPlayerNear(pos) then
                table.insert(foods, {instance = food, position = pos})
            end
        end
    end

    table.sort(foods, function(a,b)
        return (a.position - hrp.Position).Magnitude < (b.position - hrp.Position).Magnitude
    end)

    local result = {}
    for i = 1, math.min(limit, #foods) do
        table.insert(result, foods[i])
    end

    return result
end

-- ⚡ GOD WARP (เร็วสุด)
local function ultraWarp(targetPos)
    local hrp = getHRP()
    if not hrp then return end

    hrp.CFrame = safeCFrame(targetPos)
    hrp.CFrame = CFrame.new(targetPos + Vector3.new(0,2,0))
end

