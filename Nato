local statusLbl = Instance.new("TextLabel", gui)
statusLbl.Position = UDim2.new(0,20,0,120)
statusLbl.Size = UDim2.new(0,300,0,30)
statusLbl.Text = "Status: Idle"
statusLbl.TextColor3 = Color3.new(1,1,1)
statusLbl.BackgroundTransparency = 1

local function setStatus(txt)
    statusLbl.Text = "Status: "..txt
end

-- LOOP หลัก
local function farmLoop()
    while running do
        local foods = getSafeFoods(10)
        if #foods > 0 then
            setStatus("Farming "..#foods.." foods")
            for _, f in ipairs(foods) do
                if not running then break end
                local success = stepWarp(f.position)
                if not success then
                    task.wait(0.2) -- เจอผู้เล่นพลังสูง → รอแล้วหาอาหารใหม่
                    break
                end
            end
        else
            setStatus("No safe food")
            task.wait(0.2)
        end
        task.wait(0.05)
    end
    setStatus("Stopped")
end

start.MouseButton1Click:Connect(function()
    if running then return end
    running = true
    task.spawn(farmLoop)
end)

stop.MouseButton1Click:Connect(function()
    running = false
end)
