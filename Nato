-- CONFIG
local SAFE_Y = -50
local DETECT_DISTANCE = 100

local running   = false
local tweenSpeed = 100
local moverConn  = nil
local fastMode   = false
local huntMode   = false
local updateRate = 0.05

-- ROOT
local function getHRP()
    local char = player.Character
    if not char then return nil end
    return char:FindFirstChild("HumanoidRootPart")
        or char:FindFirstChild("RootPart")
        or char.PrimaryPart
end

-- FAST MODE: ลบ obstacle แต่ไม่ลบพื้น
local function optimizeMap(enable)
    for _,v in pairs(workspace:GetDescendants()) do
        if v:IsA("BasePart") or v:IsA("MeshPart") then
            local name = string.lower(v.Name)
            local parentName = v.Parent and string.lower(v.Parent.Name) or ""
            -- ไม่ลบพื้น/plateau/terrain
            if name:find("floor") or name:find("terrain") then continue end
            if name:find("tree") or name:find("rock") or name:find("mountain") or name:find("bush")
            or parentName:find("tree") or parentName:find("rock") or parentName:find("mountain") or parentName:find("bush") then
                if enable then
                    v.LocalTransparencyModifier = 1
                    v.CanCollide = false
                else
                    v.LocalTransparencyModifier = 0
                    v.CanCollide = true
                end
            end
        end
    end
end

-- FOOD
local function getClosestFood()
    local hrp = getHRP()
    if not hrp then return nil end
    local best, bestDist = nil, math.huge
    for _, food in CollectionService:GetTagged("Food") do
        if not food or not food.Parent then continue end
        local pos = food:IsA("Model") and food:GetPivot().Position or food.Position
        local d = (hrp.Position - pos).Magnitude
        if d < bestDist then
            bestDist = d
            best = { instance = food, position = pos }
        end
    end
    return best
end

-- GROWTH
local function getMyGrowth()
    local char = player.Character
    local g = char and char:FindFirstChild("Growth")
    if g then return g.Value end
    local ls = player:FindFirstChild("leaderstats")
    if ls and ls:FindFirstChild("Growth") then return ls.Growth.Value end
    return 0
end

-- PLAYER AI (ESCAPE > HUNT)
local function getTargetPlayer()
    local hrp = getHRP()
    if not hrp then return nil end

    local myGrowth = getMyGrowth()
    local nearestHunt = nil
    local nearestDist = math.huge
    local escapeTarget = nil

    for _, plr in ipairs(Players:GetPlayers()) do
        if plr ~= player and plr.Character then
            local root = plr.Character:FindFirstChild("HumanoidRootPart")
                or plr.Character:FindFirstChild("RootPart")
                or plr.Character.PrimaryPart
            local growth = plr.Character:FindFirstChild("Growth")
                or (plr:FindFirstChild("leaderstats") and plr.leaderstats:FindFirstChild("Growth"))
            if root and growth then
                local dist = (hrp.Position - root.Position).Magnitude
                if dist <= DETECT_DISTANCE and growth.Value > myGrowth then
                    escapeTarget = root
                end
                if huntMode and growth.Value < myGrowth then
                    if dist < nearestDist then
                        nearestDist = dist
                        nearestHunt = root
                    end
                end
            end
        end
    end

    if escapeTarget then return "ESCAPE", escapeTarget.Position
    elseif nearestHunt then return "HUNT", nearestHunt end
    return nil
end

-- MOVE
local function stopMover()
    if moverConn then moverConn:Disconnect(); moverConn = nil end
end

local function moveTo(targetPos)
    stopMover()
    moverConn = RunService.Heartbeat:Connect(function(dt)
        local hrp = getHRP()
        if not hrp or not running then return end
        -- Anti-Void
        if hrp.Position.Y < SAFE_Y then
            hrp.CFrame = CFrame.new(hrp.Position.X,50,hrp.Position.Z)
        end
        local diff = targetPos - hrp.Position
        local dist = diff.Magnitude
        if dist < 3 then return end
        local speed = tweenSpeed
        if dist < 20 then speed = speed * 0.4 elseif dist < 10 then speed = speed * 0.2 end
        local step = math.min(speed * dt, dist)
        hrp.CFrame = CFrame.new(hrp.Position + diff.Unit * step)
    end)
end

