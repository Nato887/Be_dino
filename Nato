local Players           = game:GetService("Players")
local CollectionService = game:GetService("CollectionService")
local VirtualUser       = game:GetService("VirtualUser")
local RunService        = game:GetService("RunService")

local player = Players.LocalPlayer
if not player.Character then player.CharacterAdded:Wait() end

-- Anti AFK
player.Idled:Connect(function()
    VirtualUser:Button2Down(Vector2.new(0,0), workspace.CurrentCamera.CFrame)
    task.wait(1)
    VirtualUser:Button2Up(Vector2.new(0,0), workspace.CurrentCamera.CFrame)
end)

local running = false

local function getHRP()
    local char = player.Character
    if not char then return nil end
    return char:FindFirstChild("HumanoidRootPart") or char.PrimaryPart
end

-- 👤 หลบผู้เล่น 150
local function isPlayerNear(pos)
    for _, plr in ipairs(Players:GetPlayers()) do
        if plr ~= player and plr.Character then
            local root = plr.Character:FindFirstChild("HumanoidRootPart")
            if root and (root.Position - pos).Magnitude < 150 then
                return true
            end
        end
    end
    return false
end

-- 🧠 AI PATH
local function getFoods()
    local hrp = getHRP()
    if not hrp then return {} end

    local safeFoods = {}
    local allFoods = {}

    for _, food in CollectionService:GetTagged("Food") do
        if food and food.Parent then
            local pos
            if food:IsA("Model") then
                pos = food:GetPivot().Position
            elseif food:IsA("BasePart") then
                pos = food.Position
            end

            if pos then
                table.insert(allFoods, pos)

                if not isPlayerNear(pos) then
                    table.insert(safeFoods, pos)
                end
            end
        end
    end

    local list = (#safeFoods > 0) and safeFoods or allFoods

    table.sort(list, function(a,b)
        return (a - hrp.Position).Magnitude < (b - hrp.Position).Magnitude
    end)

    return list
end

-- ⚡ AI SPEED
local warpDelay = 0.03
local minDelay = 0.01
local maxDelay = 0.08
local successStreak = 0

local function warp(pos)
    local hrp = getHRP()
    if not hrp then return false end

    -- วาร์ปขึ้นก่อน
    hrp.CFrame = CFrame.new(pos + Vector3.new(0,6,0))
    task.wait(warpDelay)

    -- ลงเก็บ
    hrp.CFrame = CFrame.new(pos + Vector3.new(0,2,0))

    return (hrp.Position - pos).Magnitude < 10
end

-- LOOP
local function loop()
    while running do
        local foods = getFoods()

        for _, pos in ipairs(foods) do
            local fps = 1 / RunService.Heartbeat:Wait()
            local success = warp(pos)

            -- ปรับสปีด
            if success then
                successStreak += 1
                warpDelay = math.max(minDelay, warpDelay - (successStreak > 5 and 0.003 or 0.001))
            else
                successStreak = 0
                warpDelay = math.min(maxDelay, warpDelay + 0.006)
            end

            -- ปรับตาม FPS
            if fps < 40 then
                warpDelay = math.min(maxDelay, warpDelay + 0.004)
            elseif fps > 55 then
                warpDelay = math.max(minDelay, warpDelay - 0.002)
            end

            task.wait(warpDelay)
        end

        task.wait()
    end
end

-- GUI
local gui = Instance.new("ScreenGui", player:WaitForChild("PlayerGui"))

local start = Instance.new("TextButton", gui)
start.Size = UDim2.new(0,100,0,40)
start.Position = UDim2.new(0,20,0,20)
start.Text = "START"

local stop = Instance.new("TextButton", gui)
stop.Size = UDim2.new(0,100,0,40)
stop.Position = UDim2.new(0,20,0,70)
stop.Text = "STOP"

start.MouseButton1Click:Connect(function()
    if running then return end
    running = true
    task.spawn(loop)
end)

stop.MouseButton1Click:Connect(function()
    running = false
end)
