-- [[ WHITE SCREEN OVERLAY ]]
local whiteLabel
local function updateWhiteScreenInfo()
    if whiteLabel then
        whiteLabel.Text = "🦖 BE-DINO FARMING...\nFarm Speed: " .. farmSpeed .. "\nAvoid Speed: " .. avoidSpeed
    end
end

local function toggleWhiteScreen(state)
    if state then
        local frame = Instance.new("Frame", whiteGui)
        frame.Name = "Overlay"
        frame.Size = UDim2.new(1, 0, 1, 0)
        frame.BackgroundColor3 = Color3.new(1, 1, 1)
        frame.BorderSizePixel = 0
        
        whiteLabel = Instance.new("TextLabel", frame)
        whiteLabel.Size = UDim2.new(1, 0, 1, 0)
        whiteLabel.BackgroundTransparency = 1
        whiteLabel.TextColor3 = Color3.new(0, 0, 0)
        whiteLabel.Font = Enum.Font.GothamBold
        whiteLabel.TextSize = 30
        updateWhiteScreenInfo()
    else
        if whiteGui:FindFirstChild("Overlay") then whiteGui.Overlay:Destroy() end
        whiteLabel = nil
    end
end

