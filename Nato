-- CONFIG
local running = false
local farmSpeed = 120
local startTime = os.time()

-- UTILS
local function getHRP()
    return player.Character and player.Character:FindFirstChild("HumanoidRootPart")
end

-- MOVE (กันตกแมพ)
local function moveTo(targetPos, speed, dt)
    local hrp = getHRP()
    if not hrp then return end

    local target = Vector3.new(targetPos.X, hrp.Position.Y, targetPos.Z)
    local diff = target - hrp.Position
    local dist = diff.Magnitude

    if dist < 2 then return end

    local step = math.min(speed * dt, dist)
    hrp.CFrame = CFrame.new(hrp.Position + diff.Unit * step)
end

-- LOOP
local mover
local function stopFarm()
    running = false
    if mover then mover:Disconnect() mover = nil end
end

local function startFarm()
    stopFarm()
    running = true

    mover = RunService.Heartbeat:Connect(function(dt)
        if not running then return end
        local hrp = getHRP()
        if not hrp then return end

        local closest, dist = nil, math.huge
        local foods = CollectionService:GetTagged("Food")

        for _, f in pairs(foods) do
            if f and f.Parent then
                local pos = f:IsA("Model") and f:GetPivot().Position or f.Position
                local d = (hrp.Position - pos).Magnitude
                if d < dist then
                    dist = d
                    closest = pos
                end
            end
        end

        if closest then
            moveTo(closest, farmSpeed, dt)
        end
    end)
end

