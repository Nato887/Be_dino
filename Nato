-- ================= AUTO BOSS =================
RunService.RenderStepped:Connect(function()
    if not settings.autoBoss then return end

    local playerGui = player:FindFirstChild("PlayerGui")
    if not playerGui then return end

    -- 🔴 เปลี่ยนชื่อตรงนี้ถ้าไม่ทำงาน
    local bossGui = playerGui:FindFirstChild("BossBar") or playerGui:FindFirstChild("Minigame")
    if not bossGui then return end

    local bar = bossGui:FindFirstChildWhichIsA("Frame")
    if not bar then return end

    local greenZone = bar:FindFirstChild("Green") or bar:FindFirstChild("Target")
    local whiteBar = bar:FindFirstChild("Slider") or bar:FindFirstChild("Cursor")

    if greenZone and whiteBar then
        local gStart = greenZone.AbsolutePosition.X
        local gEnd = gStart + greenZone.AbsoluteSize.X

        local wMid = whiteBar.AbsolutePosition.X + whiteBar.AbsoluteSize.X / 2

        if wMid > gStart and wMid < gEnd then
            VirtualUser:CaptureController()
            VirtualUser:Button1Down(Vector2.new())
            VirtualUser:Button1Up(Vector2.new())
        end
    end
end)

