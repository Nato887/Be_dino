-- SLIDER
local function makeSlider(y, max, default, name, callback)
    local label = Instance.new("TextLabel", panel)
    label.Size = UDim2.new(0,420,0,20)
    label.Position = UDim2.new(0,20,0,y)
    label.Text = name..": "..default
    label.TextColor3 = Color3.new(1,1,1)
    label.BackgroundTransparency = 1

    local bar = Instance.new("TextButton", panel)
    bar.Size = UDim2.new(0,420,0,10)
    bar.Position = UDim2.new(0,20,0,y+25)
    bar.BackgroundColor3 = Color3.fromRGB(0,255,150)

    bar.MouseButton1Down:Connect(function()
        local val = math.random(1,max)
        label.Text = name..": "..val
        callback(val)
    end)
end

