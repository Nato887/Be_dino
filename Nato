local Players           = game:GetService("Players")
local RunService        = game:GetService("RunService")
local CollectionService = game:GetService("CollectionService")
local UserInputService  = game:GetService("UserInputService")
local VirtualUser       = game:GetService("VirtualUser")

local player = Players.LocalPlayer
if not player.Character then player.CharacterAdded:Wait() end

-- CONFIG
local SAFE_Y = -50
local DETECT_DISTANCE = 100

local running   = false
local tweenSpeed = 100
local moverConn  = nil

-- ROOT
local function getHRP()
    local char = player.Character
    if not char then return nil end
    for _, v in ipairs(char:GetChildren()) do
        if v.Name == "RootPart" and v:IsA("BasePart") and not v.Massless then
            return v
        end
    end
    return char.PrimaryPart
end

-- FOOD
local function getClosestFood()
    local hrp = getHRP()
    if not hrp then return nil end
    local best, bestDist = nil, math.huge
    for _, food in CollectionService:GetTagged("Food") do
        if not food or not food.Parent then continue end
        local pos = food:IsA("Model") and food:GetPivot().Position or food.Position
        local d = (hrp.Position - pos).Magnitude
        if d < bestDist then
            bestDist = d
            best = { instance = food, position = pos }
        end
    end
    return best
end

-- GROWTH
local function getMyGrowth()
    local char = player.Character
    local g = char and char:FindFirstChild("Growth")
    return g and g.Value or 0
end

-- PLAYER AI (FINAL LOGIC)
local function getTargetPlayer()
    local hrp = getHRP()
    if not hrp then return nil end

    local myGrowth = getMyGrowth()
    local huntTarget = nil
    local huntDist = math.huge

    for _, plr in Players:GetPlayers() do
        if plr ~= player and plr.Character then
            local root = plr.Character:FindFirstChild("HumanoidRootPart")
            local growth = plr.Character:FindFirstChild("Growth")

            if root and growth then
                local dist = (hrp.Position - root.Position).Magnitude

                -- 🔴 หนี (เฉพาะใหญ่กว่า + ใน 100)
                if dist <= DETECT_DISTANCE and growth.Value > myGrowth then
                    return "ESCAPE", root.Position
                end

                -- 🟢 ล่า (ตัวเล็กกว่า ทั้งแมพ)
                if growth.Value < myGrowth and dist < huntDist then
                    huntDist = dist
                    huntTarget = root.Position
                end
            end
        end
    end

    if huntTarget then
        return "HUNT", huntTarget
    end

    return nil
end

-- MOVE
local function stopMover()
    if moverConn then moverConn:Disconnect(); moverConn = nil end
end

local function moveTo(targetPos)
    local reached = false
    stopMover()
    moverConn = RunService.Heartbeat:Connect(function(dt)
        local hrp = getHRP()
        if not hrp or not running then reached = true; stopMover(); return end

        -- anti void
        if hrp.Position.Y < SAFE_Y then
            hrp.CFrame = CFrame.new(0,50,0)
        end

        local diff = targetPos - hrp.Position
        local dist = diff.Magnitude
        if dist < 2 then reached = true; stopMover(); return end

        local step = math.min(tweenSpeed * dt, dist)
        hrp.CFrame = CFrame.new(hrp.Position + diff.Unit * step)
    end)
    while not reached do task.wait(0.05) end
end

