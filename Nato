-- SLIDER
local function makeSlider(y, max, default, name, callback)
    local label = Instance.new("TextLabel", panel)
    label.Position = UDim2.new(0,20,0,y)
    label.Size = UDim2.new(0,420,0,20)
    label.Text = name..": "..default
    label.BackgroundTransparency = 1
    label.TextColor3 = Color3.new(1,1,1)

    local track = Instance.new("Frame", panel)
    track.Position = UDim2.new(0,20,0,y+25)
    track.Size = UDim2.new(0,420,0,8)
    track.BackgroundColor3 = Color3.fromRGB(120,120,120)
    Instance.new("UICorner", track)

    local knob = Instance.new("Frame", track)
    knob.Size = UDim2.new(0,20,0,20)
    knob.BackgroundColor3 = Color3.new(1,1,1)
    knob.Position = UDim2.new(default/max,-10,0.5,-10)
    Instance.new("UICorner", knob).CornerRadius = UDim.new(1,0)

    local dragging = false

    knob.InputBegan:Connect(function()
        dragging = true
    end)

    UserInputService.InputEnded:Connect(function()
        dragging = false
    end)

    UserInputService.InputChanged:Connect(function(input)
        if dragging then
            local delta = math.clamp((input.Position.X - track.AbsolutePosition.X)/track.AbsoluteSize.X,0,1)
            local val = math.floor(delta*max)
            knob.Position = UDim2.new(delta,-10,0.5,-10)
            label.Text = name..": "..val
            callback(val)
        end
    end)
end

makeSlider(60,1000,farmSpeed,"Speed Farm",function(v) farmSpeed=v end)
makeSlider(120,1000,avoidSpeed,"Speed Avoid",function(v) avoidSpeed=v end)

