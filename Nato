stopBtn.Text = "STOP"

startBtn.MouseButton1Click:Connect(function()
    if running then return end
    running = true
    task.spawn(function()
        while running do
            local state, target = getTargetPlayer()
            if state == "ESCAPE" then
                setStatus("ESCAPING")
                local hrp = getHRP()
                local dir = (hrp.Position - target).Unit
                moveTo(hrp.Position + dir * 200)
            elseif state == "HUNT" and target then
                setStatus("HUNTING")
                stopMover()
                moverConn = RunService.Heartbeat:Connect(function()
                    local hrp = getHRP()
                    if not hrp then return end
                    hrp.CFrame = CFrame.new(target.Position + Vector3.new(0,2,0))
                end)
            else
                local food = getClosestFood()
                if food then
                    setStatus("FARMING")
                    moveTo(food.position)
                else
                    setStatus("IDLE")
                end
            end
            task.wait(updateRate)
        end
    end)
end)

stopBtn.MouseButton1Click:Connect(function()
    running = false
    stopMover()
end)

