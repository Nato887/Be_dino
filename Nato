local Players           = game:GetService("Players")
local RunService        = game:GetService("RunService")
local CollectionService = game:GetService("CollectionService")
local UserInputService  = game:GetService("UserInputService")

local player = Players.LocalPlayer
if not player.Character then player.CharacterAdded:Wait() end

local running = false

local SAFE_RADIUS = 75 -- ระยะอันตราย

-- ── Root ──
local function getHRP()
    local char = player.Character
    if not char then return nil end
    return char:FindFirstChild("HumanoidRootPart") or char.PrimaryPart
end

-- 🧠 หาระยะใกล้สุดของผู้เล่นที่อยู่รอบ "ตำแหน่งนั้น"
local function getNearestPlayerDistance(pos)
    local nearest = math.huge

    for _, p in ipairs(Players:GetPlayers()) do
        if p ~= player and p.Character and p.Character:FindFirstChild("HumanoidRootPart") then
            local d = (p.Character.HumanoidRootPart.Position - pos).Magnitude
            if d < nearest then
                nearest = d
            end
        end
    end

    return nearest
end

-- 🧠 หาอาหารที่ "ปลอดภัยที่สุด"
local function getBestFood()
    local hrp = getHRP()
    if not hrp then return nil end

    local best = nil
    local bestScore = -math.huge

    for _, food in CollectionService:GetTagged("Food") do
        if not food or not food.Parent then continue end

        local ok, pos = pcall(function()
            if food:IsA("Model") then return food:GetPivot().Position
            elseif food:IsA("BasePart") then return food.Position end
        end)

        if ok and pos then
            local playerDist = getNearestPlayerDistance(pos)

            -- ❌ ถ้าใกล้คนเกินไป ตัดทิ้ง
            if playerDist < SAFE_RADIUS then continue end

            local myDist = (hrp.Position - pos).Magnitude

            -- 🎯 คะแนน = ความปลอดภัย - ระยะทาง
            local score = playerDist - myDist

            if score > bestScore then
                bestScore = score
                best = { instance = food, position = pos }
            end
        end
    end

    return best
end

-- ⚡ Instant Warp + กันตาย
local function instantWarp(pos)
    local hrp = getHRP()
    if not hrp then return end

    -- 🧠 เช็คก่อนวาร์ป
    if getNearestPlayerDistance(pos) < SAFE_RADIUS then return end

    hrp.CFrame = CFrame.new(pos)
end

-- 💀 ตายแล้วหยุด
local function bindCharacter(char)
    local hum = char:WaitForChild("Humanoid")

    hum.Died:Connect(function()
        running = false
    end)
end

if player.Character then
    bindCharacter(player.Character)
end

player.CharacterAdded:Connect(function(char)
    bindCharacter(char)
end)

-- ── GUI ──
local gui = Instance.new("ScreenGui")
gui.ResetOnSpawn = false
gui.Parent = player:WaitForChild("PlayerGui")

local panel = Instance.new("Frame", gui)
panel.Size = UDim2.new(0,270,0,180)
panel.Position = UDim2.new(0.5,-135,0.5,-90)
panel.BackgroundColor3 = Color3.fromRGB(20,20,30)
panel.Active = true
panel.Draggable = true

local statusLbl = Instance.new("TextLabel", panel)
statusLbl.Size = UDim2.new(1,0,0,30)
statusLbl.BackgroundTransparency = 1
statusLbl.Text = "Status: Idle"

local function setStatus(t)
    statusLbl.Text = "Status: "..t
end

-- ── Loop ──
local function loop()
    while running do
        local food = getBestFood()

        if food then
            setStatus("Warping "..food.instance.Name)
            instantWarp(food.position)
        else
            setStatus("No safe food")
        end

        task.wait(0.05) -- เร็วมาก
    end
end

-- ปุ่ม
local start = Instance.new("TextButton", panel)
start.Position = UDim2.new(0,10,1,-40)
start.Size = UDim2.new(0.4,0,0,30)
start.Text = "Start"

local stop = Instance.new("TextButton", panel)
stop.Position = UDim2.new(0.55,0,1,-40)
stop.Size = UDim2.new(0.4,0,0,30)
stop.Text = "Stop"

start.MouseButton1Click:Connect(function()
    if running then return end
    running = true
    task.spawn(loop)
end)

stop.MouseButton1Click:Connect(function()
    running = false
end)
