local Players           = game:GetService("Players")
local TweenService      = game:GetService("TweenService")
local CollectionService = game:GetService("CollectionService")
local UserInputService  = game:GetService("UserInputService")

local player = Players.LocalPlayer
local running = false
local avoidPlayers = true
local tweenSpeed = 100
local currentTween = nil

-- ── ฟังก์ชันหาตำแหน่งตัวละคร (RootPart) ──
local function getHRP()
    local char = player.Character
    return char and (char:FindFirstChild("HumanoidRootPart") or char.PrimaryPart)
end

-- ── ระบบหลบผู้เล่นอื่นในระยะ 50 Studs ──
local function getAvoidanceOffset()
    if not avoidPlayers then return Vector3.new() end
    local hrp = getHRP()
    if not hrp then return Vector3.new() end
    local force = Vector3.new()
    for _, other in ipairs(Players:GetPlayers()) do
        if other ~= player and other.Character and other.Character:FindFirstChild("HumanoidRootPart") then
            local otherHrp = other.Character.HumanoidRootPart
            local diff = hrp.Position - otherHrp.Position
            if diff.Magnitude < 50 then -- ระยะหลบ 50 studs ตามสั่ง
                force = force + (diff.Unit * (50 - diff.Magnitude))
            end
        end
    end
    return force
end

-- ── ระบบค้นหาอาหาร (รองรับ Tag และ ชื่อ) ──
local function getTarget()
    local hrp = getHRP()
    if not hrp then return nil end
    local best, bestDist = nil, math.huge
    
    -- รวมการหาจาก Tag และจากชื่อใน Workspace
    local targets = CollectionService:GetTagged("Food")
    for _, obj in ipairs(workspace:GetDescendants()) do
        if obj:IsA("BasePart") and (obj.Name:find("Meat") or obj.Name:find("Food") or obj.Name:find("Egg")) then
            table.insert(targets, obj)
        end
    end

    for _, obj in ipairs(targets) do
        if obj and obj.Parent then
            local pos = obj:IsA("Model") and obj:GetPivot().Position or obj.Position
            local dist = (hrp.Position - pos).Magnitude
            if dist < bestDist then
                bestDist = dist
                best = {instance = obj, pos = pos}
            end
        end
    end
    return best
end

local function stopTween()
    if currentTween then currentTween:Cancel(); currentTween = nil end
end

-- ── ระบบเดินแบบ Tween ──
local function moveTo(targetPos)
    local hrp = getHRP()
    if not hrp then return end
    stopTween()
    
    local avoid = getAvoidanceOffset()
    local finalPos = Vector3.new(targetPos.X + avoid.X, hrp.Position.Y, targetPos.Z + avoid.Z)
    
    local dist = (hrp.Position - finalPos).Magnitude
    if dist < 4 then return end
    
    local duration = dist / math.max(tweenSpeed, 10)
    currentTween = TweenService:Create(hrp, TweenInfo.new(duration, Enum.EasingStyle.Linear), {
        CFrame = CFrame.new(finalPos, Vector3.new(targetPos.X, hrp.Position.Y, targetPos.Z))
    })
    currentTween:Play()
    task.wait(duration)
end

