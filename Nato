local function setStatus(t)
    statusLbl.Text = "Status: "..t
end

local function makeBtn(text, color, x)
    local b = Instance.new("TextButton", panel)
    b.Size = UDim2.new(0,110,0,35)
    b.Position = UDim2.new(0,x,0,150)
    b.Text = text
    b.BackgroundColor3 = color
    b.TextColor3 = Color3.new(1,1,1)
    return b
end

local startBtn = makeBtn("START", Color3.fromRGB(40,165,70), 10)
local stopBtn  = makeBtn("STOP",  Color3.fromRGB(180,60,60), 140)

-- 🔥 LOOP FINAL
local function loop()
    while running do

        -- 💀 ตาย
        if isDead() then
            running = false
            busy = false

            waitForRespawn()
            waitUntilEggDone()

            running = true
            setStatus("Resumed")
        end

        if busy then
            task.wait()
            continue
        end

        busy = true

        local foods = getManyFoods(30)

        if #foods > 0 then
            setStatus("⚡ GOD SAFE FARM")

            for _, food in ipairs(foods) do
                if not isPlayerNear(food.position) then
                    ultraWarp(food.position)
                end
            end
        else
            setStatus("Searching...")
            task.wait(0.15)
        end

        busy = false
        task.wait()
    end

    setStatus("Stopped")
end

startBtn.MouseButton1Click:Connect(function()
    if running then return end
    running = true
    setStatus("Running")
    task.spawn(loop)
end)

stopBtn.MouseButton1Click:Connect(function()
    running = false
    setStatus("Stopped")
end)

setStatus("Idle")
