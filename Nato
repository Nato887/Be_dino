local Players           = game:GetService("Players")
local TweenService      = game:GetService("TweenService")
local UserInputService  = game:GetService("UserInputService")

local player = Players.LocalPlayer
local running = false
local avoidPlayers = true
local tweenSpeed = 100
local currentTween = nil

-- ── ฟังก์ชันหาตำแหน่งตัวละคร ──
local function getHRP()
    local char = player.Character
    return char and (char:FindFirstChild("HumanoidRootPart") or char.PrimaryPart)
end

-- ── ฟังก์ชันหลบผู้เล่นอื่น ──
local function getAvoidanceOffset()
    local hrp = getHRP()
    if not hrp or not avoidPlayers then return Vector3.new() end
    local force = Vector3.new()
    for _, other in ipairs(Players:GetPlayers()) do
        if other ~= player and other.Character and other.Character:FindFirstChild("HumanoidRootPart") then
            local otherPos = other.Character.HumanoidRootPart.Position
            local diff = hrp.Position - otherPos
            if diff.Magnitude < 30 then 
                force = force + (diff.Unit * (30 - diff.Magnitude))
            end
        end
    end
    return force
end

-- ── แก้ไขใหม่: ค้นหาเนื้อ/ของกินในแมพ ──
local function getTarget()
    local hrp = getHRP()
    if not hrp then return nil end
    local best, bestDist = nil, math.huge
    
    -- ค้นหาวัตถุที่มีชื่อว่า Meat, Food, หรือ Egg ใน Workspace
    for _, obj in ipairs(workspace:GetDescendants()) do
        if obj:IsA("BasePart") and (obj.Name == "Meat" or obj.Name == "Food" or obj.Name == "Egg") then
            local dist = (hrp.Position - obj.Position).Magnitude
            if dist < bestDist then
                bestDist = dist
                best = {instance = obj, pos = obj.Position}
            end
        end
    end
    return best
end

local function stopTween()
    if currentTween then currentTween:Cancel(); currentTween = nil end
end

-- ── แก้ไขใหม่: ระบบเคลื่อนที่ ──
local function moveTo(targetPos)
    local hrp = getHRP()
    if not hrp then return end
    
    stopTween()
    local avoid = getAvoidanceOffset()
    -- คำนวณตำแหน่งปลายทาง (ล็อกความสูง Y เท่าเดิมกันตกแมพ)
    local finalPos = Vector3.new(targetPos.X + avoid.X, hrp.Position.Y, targetPos.Z + avoid.Z)
    
    local dist = (hrp.Position - finalPos).Magnitude
    if dist < 3 then return end -- ถ้าใกล้มากแล้วหยุด

    local duration = dist / math.max(tweenSpeed, 10)
    local info = TweenInfo.new(duration, Enum.EasingStyle.Linear)
    
    -- หมุนหน้าไปหาเป้าหมายและเลื่อนตำแหน่ง
    currentTween = TweenService:Create(hrp, info, {
        CFrame = CFrame.new(finalPos, Vector3.new(targetPos.X, hrp.Position.Y, targetPos.Z))
    })
    currentTween:Play()
    task.wait(duration) -- รอจนถึงที่หมาย
end

