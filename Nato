-- ฟังก์ชันสร้างปุ่มพร้อมคำอธิบาย (ตามที่คุณถาม)
local function createToggle(name, subText, prop, pos)
    local btn = Instance.new("TextButton", main)
    btn.Size = UDim2.new(0, 300, 0, 50)
    btn.Position = UDim2.new(0, 135, 0, pos)
    btn.BackgroundColor3 = Color3.fromRGB(30, 25, 50)
    btn.Text = "" 
    btn.AutoButtonColor = false
    Instance.new("UICorner", btn)

    -- ชื่อเมนูหลัก
    local mainLabel = Instance.new("TextLabel", btn)
    mainLabel.Size = UDim2.new(1, -60, 0, 25)
    mainLabel.Position = UDim2.new(0, 12, 0, 5)
    mainLabel.Text = name
    mainLabel.TextColor3 = Color3.new(1, 1, 1)
    mainLabel.Font = Enum.Font.SourceSansBold
    mainLabel.TextSize = 15
    mainLabel.BackgroundTransparency = 1
    mainLabel.TextXAlignment = Enum.TextXAlignment.Left

    -- คำอธิบายตัวเล็กด้านล่าง (ที่คุณถามถึง)
    local descLabel = Instance.new("TextLabel", btn)
    descLabel.Size = UDim2.new(1, -60, 0, 20)
    descLabel.Position = UDim2.new(0, 12, 0, 25)
    descLabel.Text = subText
    descLabel.TextColor3 = Color3.fromRGB(130, 130, 150)
    descLabel.Font = Enum.Font.SourceSans
    descLabel.TextSize = 12
    descLabel.BackgroundTransparency = 1
    descLabel.TextXAlignment = Enum.TextXAlignment.Left

    -- สวิตซ์เปิด-ปิด (Indicator)
    local status = Instance.new("Frame", btn)
    status.Size = UDim2.new(0, 35, 0, 18)
    status.Position = UDim2.new(1, -45, 0.5, -9)
    status.BackgroundColor3 = settings[prop] and Color3.fromRGB(130, 60, 255) or Color3.fromRGB(15, 15, 15)
    Instance.new("UICorner", status).CornerRadius = UDim.new(1, 0)

    btn.MouseButton1Click:Connect(function()
        settings[prop] = not settings[prop]
        status.BackgroundColor3 = settings[prop] and Color3.fromRGB(130, 60, 255) or Color3.fromRGB(15, 15, 15)
    end)
end

-- สร้างรายการเมนู (เลียนแบบในรูป)
createToggle("Auto Feed", "Priority: Eggs > Players > Meats", "AutoFeed", 50)
createToggle("Avoid Players", "Avoid players with distance: 134", "AvoidPlayers", 110)
createToggle("Eat Smaller Players", "Hunt players with Growth > 5000 when safe", "EatSmaller", 170)
createToggle("Anti Void", "Prevent you from falling into the void", "AntiVoid", 230)

-- ================= LOGIC SYSTEM =================

runService.RenderStepped:Connect(function()
    local char = player.Character
    local root = char and char:FindFirstChild("HumanoidRootPart")
    if not root then return end

    -- 1. Anti Void (ถ้าตกแมพให้วาร์ปขึ้นมา)
    if settings.AntiVoid and root.Position.Y < -50 then
        root.CFrame = root.CFrame + Vector3.new(0, 200, 0)
        root.AssemblyLinearVelocity = Vector3.new(0,0,0)
    end

    -- 2. Avoid Players (หนีตัวใหญ่)
    if settings.AvoidPlayers then
        for _, p in ipairs(players:GetPlayers()) do
            if p ~= player and p.Character and p.Character:FindFirstChild("HumanoidRootPart") then
                local eRoot = p.Character.HumanoidRootPart
                -- เงื่อนไข: ถ้ามันตัวใหญ่กว่าเรา และอยู่ใกล้เกิน 134 studs
                if eRoot.Size.Magnitude > root.Size.Magnitude and (root.Position - eRoot.Position).Magnitude < 134 then
                    local escapeDir = (root.Position - eRoot.Position).Unit
                    root.CFrame = root.CFrame + escapeDir * 15 -- วาร์ปหนี
                    return
                end
            end
        end
    end

    -- 3. Auto Farm & Hunt
    if settings.AutoFeed then
        local target = nil
        
        -- ตรวจหา Player ตัวเล็ก (เงื่อนไข Growth > 5000)
        if settings.EatSmaller then
            for _, p in ipairs(players:GetPlayers()) do
                if p ~= player and p.Character and p.Character:FindFirstChild("HumanoidRootPart") then
                    local pRoot = p.Character.HumanoidRootPart
                    -- สมมติว่าค่า Growth ในเกมนี้วัดจาก Size.Magnitude นะครับ
                    if pRoot.Size.Magnitude < root.Size.Magnitude and pRoot.Size.Magnitude > 10 then 
                        target = pRoot
                        break
                    end
                end
            end
        end

        -- ถ้าไม่มีคนให้ล่า ให้ไปหาเนื้อ (Meat) หรือไข่ (Egg)
        if not target then
            for _, v in ipairs(workspace:GetDescendants()) do
                if v:IsA("BasePart") and (v.Name:lower():find("meat") or v.Name:lower():find("egg")) then
                    target = v
                    break
                end
            end
        end

        -- วาร์ปไปกิน
        if target then
            root.CFrame = target.CFrame + Vector3.new(0, 2, 0)
        end
    end
end)
