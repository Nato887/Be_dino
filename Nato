local Players = game:GetService("Players")
local RunService = game:GetService("RunService")
local CollectionService = game:GetService("CollectionService")
local UserInputService = game:GetService("UserInputService")

local player = Players.LocalPlayer

-- ================= SETTINGS (V20 Tween Edition) =================
local settings = {
    autoFood = false,
    huntWeaker = false, -- ระบบกินผู้เล่น Growth น้อยกว่า
    avoidPlayers = false, -- ระบบหนีผู้เล่น Growth เยอะกว่า
    antiVoid = true,
    antiAFK = true,
    tweenSpeed = 150,
}

-- ── Get Root Part ──
local function getHRP()
    local char = player.Character
    return char and (char:FindFirstChild("HumanoidRootPart") or char.PrimaryPart)
end

-- ================= GUI Nato Hub V20 (Horizontal) =================
local gui = Instance.new("ScreenGui", player:WaitForChild("PlayerGui"))
gui.Name = "NatoHub_V20"; gui.ResetOnSpawn = false

local main = Instance.new("Frame", gui)
main.Size = UDim2.new(0, 420, 0, 180) 
main.Position = UDim2.new(0.5, -210, 0.8, -100) 
main.BackgroundColor3 = Color3.fromRGB(15, 10, 25)
main.BorderSizePixel = 0; main.Active = true; main.Draggable = true
Instance.new("UICorner", main)

-- [ Sidebar & Content ระบบเดิมที่ประหยัดพื้นที่ ]
local tabFrame = Instance.new("Frame", main)
tabFrame.Size = UDim2.new(0, 80, 1, 0); tabFrame.BackgroundColor3 = Color3.fromRGB(25, 20, 45)
Instance.new("UICorner", tabFrame)

local mainPage = Instance.new("Frame", main)
mainPage.Size = UDim2.new(1, -90, 1, -10); mainPage.Position = UDim2.new(0, 85, 0, 5); mainPage.BackgroundTransparency = 1

local function createToggle(name, x, y, prop)
    local btn = Instance.new("TextButton", mainPage)
    btn.Size = UDim2.new(0, 155, 0, 35); btn.Position = UDim2.new(0, x, 0, y)
    btn.BackgroundColor3 = settings[prop] and Color3.fromRGB(130, 60, 255) or Color3.fromRGB(35, 30, 60)
    btn.Text = name; btn.TextColor3 = Color3.new(1,1,1); btn.Font = Enum.Font.GothamBold; btn.TextSize = 10; Instance.new("UICorner", btn)
    btn.MouseButton1Click:Connect(function()
        settings[prop] = not settings[prop]
        btn.BackgroundColor3 = settings[prop] and Color3.fromRGB(130, 60, 255) or Color3.fromRGB(35, 30, 60)
    end)
end

-- ปุ่มเมนู
createToggle("Auto Food", 5, 10, "autoFood")
createToggle("Eat Smaller (Hunt)", 165, 10, "huntWeaker")
createToggle("Avoid Bigger (150s)", 5, 50, "avoidPlayers")
createToggle("Anti Void", 165, 50, "antiVoid")
createToggle("Anti AFK", 5, 90, "antiAFK")

-- 🎚️ SPEED SLIDER
local speedLabel = Instance.new("TextLabel", mainPage)
speedLabel.Size = UDim2.new(0, 150, 0, 15); speedLabel.Position = UDim2.new(0, 165, 0, 90)
speedLabel.Text = "Speed: 150"; speedLabel.TextColor3 = Color3.new(0.8, 0.8, 1); speedLabel.BackgroundTransparency = 1; speedLabel.TextSize = 10

local track = Instance.new("Frame", mainPage)
track.Size = UDim2.new(0, 310, 0, 4); track.Position = UDim2.new(0, 10, 0, 140); track.BackgroundColor3 = Color3.fromRGB(45, 45, 70); Instance.new("UICorner", track)
local knob = Instance.new("TextButton", track)
knob.Size = UDim2.new(0, 14, 0, 14); knob.Position = UDim2.new(0.15, -7, 0.5, -7); knob.BackgroundColor3 = Color3.new(1,1,1); Instance.new("UICorner", knob)

knob.InputChanged:Connect(function(i)
    if (i.UserInputType == Enum.UserInputType.Touch or i.UserInputType == Enum.UserInputType.MouseMovement) and UserInputService:IsMouseButtonPressed(Enum.UserInputType.MouseButton1) then
        local r = math.clamp((i.Position.X - track.AbsolutePosition.X) / track.AbsoluteSize.X, 0, 1)
        settings.tweenSpeed = math.floor(r * 1000); knob.Position = UDim2.new(r, -7, 0.5, -7); speedLabel.Text = "Speed: " .. settings.tweenSpeed
    end
end)

-- ================= MAIN LOOP (Tween Away/To Logic) =================
RunService.Heartbeat:Connect(function(dt)
    local hrp = getHRP()
    if not hrp then return end

    -- 🛡️ 1. Anti Void
    if settings.antiVoid and hrp.Position.Y < -50 then
        hrp.Velocity = Vector3.new(0,0,0); hrp.CFrame = CFrame.new(hrp.Position.X, 120, hrp.Position.Z); return
    end

    -- 🛡️ 2. ระบบหนี (Tween Away from Bigger Dino)
    if settings.avoidPlayers then
        for _, p in ipairs(Players:GetPlayers()) do
            if p ~= player and p.Character and p.Character:FindFirstChild("HumanoidRootPart") then
                local eRoot = p.Character.HumanoidRootPart
                -- เงื่อนไข: ถ้าคนนั้น Growth > เรา (ตัวใหญ่กว่า) ในระยะ 150
                if eRoot.Size.Magnitude > hrp.Size.Magnitude and (hrp.Position - eRoot.Position).Magnitude < 150 then
                    local escapeDir = (hrp.Position - eRoot.Position).Unit
                    -- Tween Away (หนีออกห่าง)
                    hrp.CFrame = CFrame.new(hrp.Position + (escapeDir * settings.tweenSpeed * dt))
                    return -- ให้ความสำคัญกับการหนีก่อน
                end
            end
        end
    end

    -- 🦖 3. ระบบกิน (Tween to Smaller Player)
    local target = nil
    if settings.huntWeaker then
        for _, p in ipairs(Players:GetPlayers()) do
            if p ~= player and p.Character and p.Character:FindFirstChild("HumanoidRootPart") then
                local eRoot = p.Character.HumanoidRootPart
                -- เงื่อนไข: ถ้าคนนั้น Growth < เรา (ตัวเล็กกว่า) และโตพอให้กิน (Size > 20)
                if eRoot.Size.Magnitude < hrp.Size.Magnitude and eRoot.Size.Magnitude > 20 then
                    target = eRoot; break 
                end
            end
        end
    end

    -- 🍖 4. ระบบฟาร์มของกิน (Tween to Food)
    if not target and settings.autoFood then
        for _, v in ipairs(CollectionService:GetTagged("Food")) do
            if v and v.Parent then target = v; break end
        end
    end

    -- 执行 Tween To (พุ่งไปหาเป้าหมาย)
    if target then
        local tPos = (target:IsA("Model") and target:GetPivot().Position) or target.Position
        local moveDir = (tPos - hrp.Position).Unit
        hrp.CFrame = CFrame.new(hrp.Position + (moveDir * settings.tweenSpeed * dt))
        hrp.Velocity = Vector3.new(0, 0.1, 0) -- ต้านแรงโน้มถ่วง
    end
end)

