-- SPEED
local speedLbl = Instance.new("TextLabel", panel)
speedLbl.Size = UDim2.new(1,-20,0,20)
speedLbl.Position = UDim2.new(0,10,0,70)
speedLbl.Text = "Speed: 100"

-- SLIDER (10000)
local track = Instance.new("Frame", panel)
track.Size = UDim2.new(1,-20,0,8)
track.Position = UDim2.new(0,10,0,100)

local fill = Instance.new("Frame", track)
fill.Size = UDim2.new(tweenSpeed/10000,0,1,0)

local knob = Instance.new("TextButton", track)
knob.Size = UDim2.new(0,18,0,18)

local dragging = false

knob.MouseButton1Down:Connect(function() dragging = true end)
UserInputService.InputEnded:Connect(function() dragging = false end)

local function updateSlider(x)
    local ratio = math.clamp((x - track.AbsolutePosition.X)/track.AbsoluteSize.X,0,1)
    tweenSpeed = math.max(1, math.floor(ratio * 10000))
    fill.Size = UDim2.new(ratio,0,1,0)
    knob.Position = UDim2.new(ratio,-9,0.5,-9)
    speedLbl.Text = "Speed: " .. tweenSpeed
end

UserInputService.InputChanged:Connect(function(input)
    if dragging then updateSlider(input.Position.X) end
end)

UserInputService.TouchMoved:Connect(function(input)
    if dragging then updateSlider(input.Position.X) end
end)

-- LOOP
local function collectLoop()
    while running do
        local state, pos = getTargetPlayer()

        if state == "ESCAPE" then
            setStatus("Escaping")
            local hrp = getHRP()
            local dir = (hrp.Position - pos).Unit
            moveTo(hrp.Position + dir * 100)

        elseif state == "HUNT" then
            setStatus("Hunting")
            moveTo(pos)

        else
            local food = getClosestFood()
            if food then
                setStatus("Collecting Food")
                moveTo(food.position)
            else
                setStatus("Idle")
            end
        end

        task.wait(0.2)
    end
    setStatus("Stopped")
end

