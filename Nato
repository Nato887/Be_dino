-- ── ระบบปุ่มกด ──
startBtn.MouseButton1Click:Connect(function()
    if running then return end
    running = true
    startBtn.Text = "RUNNING..."
    task.spawn(function()
        while running do
            local target = getTarget()
            if target then
                status.Text = "Status: Eating " .. target.instance.Name
                moveTo(target.pos)
            else
                status.Text = "Status: Searching Food..."
                task.wait(1)
            end
            task.wait(0.1)
        end
        status.Text = "Status: Stopped"
        startBtn.Text = "START"
    end)
end)

stopBtn.MouseButton1Click:Connect(function()
    running = false
    stopTween()
end)
