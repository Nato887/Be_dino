panel.BackgroundColor3 = Color3.fromRGB(18,18,28)
panel.Active = true
panel.Draggable = true
panel.Parent = gui

local statusLbl = Instance.new("TextLabel", panel)
statusLbl.Size = UDim2.new(1, -20, 0, 22)
statusLbl.Position = UDim2.new(0, 10, 0, 46)
statusLbl.BackgroundTransparency = 1
statusLbl.Text = "Status: Idle"
statusLbl.TextColor3 = Color3.fromRGB(150,150,180)

local function setStatus(msg)
    statusLbl.Text = "Status: "..msg
end

-- 🔥 LOOP (เพิ่มหนีอย่างเดียว)
local function collectLoop()
    while running do

        -- 🔥 หนีทันที
        if isSomeoneNearMe(100) then
            setStatus("⚠ Escaping...")
            local safe = getSafeSpot()
            if safe then
                moveTo(safe)
            end
            task.wait(0.1)
            continue
        end

        local hrp = getHRP()
        if not hrp then
            task.wait(1)
            continue
        end

        local food = getClosestFood()
        if not food then
            setStatus("No food")
            task.wait(0.3)
            continue
        end

        setStatus("Going to "..food.instance.Name)
        moveTo(food.position)
    end
end

setStatus("Idle")
