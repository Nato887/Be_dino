local running = false

-- Root Part
local function getHRP()
    local char = player.Character
    if not char then return nil end
    return char:FindFirstChild("HumanoidRootPart") or char.PrimaryPart
end

-- ตรวจผู้เล่นใกล้
local function isPlayerNear(pos, radius)
    radius = radius or 150
    for _, plr in ipairs(Players:GetPlayers()) do
        if plr ~= player and plr.Character then
            local root = plr.Character:FindFirstChild("HumanoidRootPart") or plr.Character.PrimaryPart
            if root and (root.Position - pos).Magnitude < radius then
                return true
            end
        end
    end
    return false
end

-- หาอาหารหลายจุด
local function getFoods(limit)
    local hrp = getHRP()
    if not hrp then return {} end
    local foods = {}
    for _, food in ipairs(CollectionService:GetTagged("Food")) do
        if food and food.Parent then
            local pos
            if food:IsA("Model") then pos = food:GetPivot().Position
            elseif food:IsA("BasePart") then pos = food.Position end
            if pos and not isPlayerNear(pos, 150) then
                table.insert(foods, {instance = food, position = pos})
            end
        end
    end
    table.sort(foods, function(a,b)
        return (a.position - hrp.Position).Magnitude < (b.position - hrp.Position).Magnitude
    end)
    local result = {}
    for i = 1, math.min(limit, #foods) do
        table.insert(result, foods[i])
    end
    return result
end

-- วาร์ปแบบปลอดภัย (ขึ้นสูงแล้วลงเก็บ)
local function warpTo(target)
    local hrp = getHRP()
    if not hrp or not target.instance or not target.instance.Parent then return end
    -- step 1: ขึ้นสูง
    hrp.CFrame = CFrame.new(target.position + Vector3.new(0,10,0))
    task.wait()
    -- step 2: ลงเก็บ
    hrp.CFrame = CFrame.new(target.position + Vector3.new(0,2,0))
end

-- Loop ฟาร์ม
local function farmLoop()
    while running do
        if not player.Character then player.CharacterAdded:Wait(); task.wait(0.5) end
        local hrp = getHRP()
        if not hrp then task.wait(0.5); continue end

        local foods = getFoods(10) -- เก็บหลายจุดต่อรอบ
        if #foods > 0 then
            for _, f in ipairs(foods) do
                if not running then break end
                warpTo(f)
                task.wait(0.05)
            end
        else
            task.wait(0.2)
        end
        task.wait(0.01)
    end
end

