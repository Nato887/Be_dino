-- Slider ปรับความเร็ว
local speedLbl = Instance.new("TextLabel", panel)
speedLbl.Size = UDim2.new(1, 0, 0, 30)
speedLbl.Position = UDim2.new(0, 0, 0, 50)
speedLbl.Text = "Speed: " .. tweenSpeed
speedLbl.TextColor3 = Color3.new(1,1,1)
speedLbl.BackgroundTransparency = 1

local slider = Instance.new("TextButton", panel)
slider.Size = UDim2.new(0.8, 0, 0, 10)
slider.Position = UDim2.new(0.1, 0, 0, 85)
slider.BackgroundColor3 = Color3.new(0.3, 0.3, 0.3)
slider.Text = ""

local bar = Instance.new("Frame", slider)
bar.Size = UDim2.new(tweenSpeed/500, 0, 1, 0)
bar.BackgroundColor3 = Color3.fromRGB(0, 150, 255)

slider.MouseButton1Down:Connect(function()
    local moveConn
    moveConn = UserInputService.InputChanged:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseMovement then
            local relativeX = math.clamp((input.Position.X - slider.AbsolutePosition.X) / slider.AbsoluteSize.X, 0, 1)
            tweenSpeed = math.floor(relativeX * 500) + 20
            bar.Size = UDim2.new(relativeX, 0, 1, 0)
            speedLbl.Text = "Speed: " .. tweenSpeed
        end
    end)
    UserInputService.InputEnded:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then
            moveConn:Disconnect()
        end
    end)
end)

-- ปุ่ม Start / Stop
local startBtn = Instance.new("TextButton", panel)
