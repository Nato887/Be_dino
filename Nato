-- ================= MAIN LOOP =================
RunService.Heartbeat:Connect(function(dt)
	local hrp = getHRP()
	if not hrp then return end
	local myG = getGrowth(player.Character)

	-- Boss System Logic
	if settings.autoBoss then
		bossBarFrame.Visible = true
		sliderPos = sliderPos + (dt * 1.5 * direction) -- ความเร็ว 1.5
		if sliderPos >= 1 or sliderPos <= 0 then direction *= -1 end
		whiteIndicator.Position = UDim2.new(sliderPos, 0, 0, -3)

		-- Auto Hit Check
		local diff = math.abs(sliderPos - (targetPos + 0.1))
		if diff < 0.05 then
			VirtualUser:CaptureController()
			VirtualUser:Button1Down(Vector2.new(0,0))
			task.wait(0.05)
			VirtualUser:Button1Up(Vector2.new(0,0))
			randomizeBoss()
		end
	else
		bossBarFrame.Visible = false
	end

	-- Anti Void
	if settings.antiVoid and hrp.Position.Y < -50 then
		hrp.CFrame = CFrame.new(0,150,0)
		return
	end

	-- Avoid/Hunt/Food Logic (เหมือนเดิม)
	local target = nil
	if settings.avoidPlayers then
		for _, p in ipairs(Players:GetPlayers()) do
			if p ~= player and p.Character then
				local e = p.Character:FindFirstChild("HumanoidRootPart")
				if e and (hrp.Position - e.Position).Magnitude < 150 then
					if getGrowth(p.Character) > myG then
						hrp.CFrame = hrp.CFrame + (hrp.Position - e.Position).Unit * settings.tweenSpeed * dt
						return
					end
				end
			end
		end
	end

	if settings.huntWeaker then
		for _, p in ipairs(Players:GetPlayers()) do
			if p ~= player and p.Character then
				local e = p.Character:FindFirstChild("HumanoidRootPart")
				if e and getGrowth(p.Character) < myG then target = e.Position end
			end
		end
	end

	if not target and settings.autoFood then
		for _, food in ipairs(CollectionService:GetTagged("Food")) do target = food.Position end
	end

	if target then
		hrp.CFrame = hrp.CFrame + (target - hrp.Position).Unit * settings.tweenSpeed * dt
	end
end)

