local function makeBtn(text, color, x)
    local b = Instance.new("TextButton", panel)
    b.Size = UDim2.new(0,110,0,35)
    b.Position = UDim2.new(0,x,0,150)
    b.Text = text
    b.BackgroundColor3 = color
    b.TextColor3 = Color3.new(1,1,1)
