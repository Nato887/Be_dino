local running = false
local enabled = false

local player = game:GetService("Players").LocalPlayer
local tweenService = game:GetService("TweenService")

-- GUI
local gui = Instance.new("ScreenGui")
gui.Parent = player:WaitForChild("PlayerGui")
gui.Name = "MeatFarmGUI"
gui.ResetOnSpawn = false

local frame = Instance.new("Frame", gui)
frame.Size = UDim2.new(0, 200, 0, 120)
frame.Position = UDim2.new(0, 20, 0, 200)
frame.BackgroundColor3 = Color3.fromRGB(0,0,0)
Instance.new("UICorner", frame)

local startBtn = Instance.new("TextButton", frame)
startBtn.Size = UDim2.new(0.8,0,0,30)
startBtn.Position = UDim2.new(0.1,0,0.4,0)
startBtn.Text = "START"
startBtn.BackgroundColor3 = Color3.fromRGB(0,200,0)

local stopBtn = Instance.new("TextButton", frame)
stopBtn.Size = UDim2.new(0.8,0,0,30)
stopBtn.Position = UDim2.new(0.1,0,0.7,0)
stopBtn.Text = "STOP"
stopBtn.BackgroundColor3 = Color3.fromRGB(50,50,50)

startBtn.MouseButton1Click:Connect(function()
	enabled = true
	print("START แล้ว") -- debug
end)

stopBtn.MouseButton1Click:Connect(function()
	enabled = false
end)

-- Tween
local function tweenTo(root, cf)
	local tween = tweenService:Create(
		root,
		TweenInfo.new(0.015, Enum.EasingStyle.Linear),
		{CFrame = cf}
	)
	tween:Play()
	tween.Completed:Wait()
end

-- หา meat แบบชัวร์
local function getMeats()
	local meats = {}
	for _, v in ipairs(workspace:GetDescendants()) do -- 🔥 ดีกว่า GetChildren
		if v:IsA("BasePart") and v.Name:lower():find("meat") then
			table.insert(meats, v)
		end
	end
	return meats
end

-- loop หลัก
task.spawn(function()
	while true do
		if enabled and not running then
			running = true
			
			local char = player.Character or player.CharacterAdded:Wait()
			local root = char:WaitForChild("HumanoidRootPart")

			local meats = getMeats()
			print("เจอ meat:", #meats) -- debug
			
			for _, target in ipairs(meats) do
				if not enabled then break end
				tweenTo(root, target.CFrame)
			end
			
			running = false
		end
		
		task.wait(0.1)
	end
end)
