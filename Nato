-- ระบบเปิด/ปิดเมนูด้วยปุ่ม Keybind
userInputService.InputBegan:Connect(function(input, gp)
    if not gp and input.KeyCode == settings.MenuKey then
        main.Visible = not main.Visible
    end
end)

-- ฟังก์ชันสร้างปุ่มเมนู (มีชื่อหลัก และคำอธิบายตัวเล็กด้านล่าง)
local function createToggle(name, subText, prop, pos)
    local btn = Instance.new("TextButton", main)
    btn.Size = UDim2.new(0, 320, 0, 55)
    btn.Position = UDim2.new(0.5, -160, 0, pos)
    btn.BackgroundColor3 = Color3.fromRGB(30, 25, 55)
    btn.Text = "" 
    btn.AutoButtonColor = false
    Instance.new("UICorner", btn)

    local mainLabel = Instance.new("TextLabel", btn)
    mainLabel.Size = UDim2.new(1, -60, 0, 25)
    mainLabel.Position = UDim2.new(0, 12, 0, 8)
    mainLabel.Text = name
    mainLabel.TextColor3 = Color3.new(1, 1, 1)
    mainLabel.Font = Enum.Font.SourceSansBold
    mainLabel.TextSize = 16
    mainLabel.BackgroundTransparency = 1
    mainLabel.TextXAlignment = Enum.TextXAlignment.Left

    local descLabel = Instance.new("TextLabel", btn)
    descLabel.Size = UDim2.new(1, -60, 0, 20)
    descLabel.Position = UDim2.new(0, 12, 0, 28)
    descLabel.Text = subText
    descLabel.TextColor3 = Color3.fromRGB(150, 150, 170)
    descLabel.Font = Enum.Font.SourceSans
    descLabel.TextSize = 13
    descLabel.BackgroundTransparency = 1
    descLabel.TextXAlignment = Enum.TextXAlignment.Left

    local status = Instance.new("Frame", btn)
    status.Size = UDim2.new(0, 40, 0, 20)
    status.Position = UDim2.new(1, -55, 0.5, -10)
    status.BackgroundColor3 = settings[prop] and Color3.fromRGB(140, 50, 255) or Color3.fromRGB(10, 10, 10)
    Instance.new("UICorner", status).CornerRadius = UDim.new(1, 0)

    btn.MouseButton1Click:Connect(function()
        settings[prop] = not settings[prop]
        status.BackgroundColor3 = settings[prop] and Color3.fromRGB(140, 50, 255) or Color3.fromRGB(10, 10, 10)
    end)
end

-- สร้างรายการเมนู (เลียนแบบตามรูปภาพ)
createToggle("Auto Feed", "Priority: Eggs > Players > Meats", "AutoFeed", 55)
createToggle("Avoid Players", "Avoid players with distance: 134", "AvoidPlayers", 120)
createToggle("Eat Smaller Players", "Hunt players with Growth > 5000", "EatSmaller", 185)
createToggle("Anti Void", "Prevent you from falling into the void", "AntiVoid", 250)

-- ================= LOGIC SYSTEM =================

