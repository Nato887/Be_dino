-- ================= MAIN LOOP =================
RunService.Heartbeat:Connect(function(dt)
    local hrp = getHRP()
    if not hrp then return end

    if settings.antiVoid and hrp.Position.Y < -50 then
        hrp.Velocity = Vector3.new(0,0,0); hrp.CFrame = CFrame.new(hrp.Position.X, 120, hrp.Position.Z); return
    end

    if settings.avoidPlayers then
        for _, p in ipairs(Players:GetPlayers()) do
            if p ~= player and p.Character and p.Character:FindFirstChild("HumanoidRootPart") then
                local eRoot = p.Character.HumanoidRootPart
                if eRoot.Size.Magnitude > hrp.Size.Magnitude and (hrp.Position - eRoot.Position).Magnitude < 150 then
                    hrp.CFrame = CFrame.new(hrp.Position + (hrp.Position - eRoot.Position).Unit * (settings.tweenSpeed * dt)); return
                end
            end
        end
    end

    local target = nil
    if settings.huntWeaker then
        for _, p in ipairs(Players:GetPlayers()) do
            if p ~= player and p.Character and p.Character:FindFirstChild("HumanoidRootPart") then
                local eRoot = p.Character.HumanoidRootPart
                if eRoot.Size.Magnitude < hrp.Size.Magnitude and eRoot.Size.Magnitude > 25 then target = eRoot; break end
            end
        end
    end

    if not target and settings.autoFood then
        for _, v in ipairs(CollectionService:GetTagged("Food")) do
            if v and v.Parent then target = v; break end
        end
    end

    if target then
        local tPos = (target:IsA("Model") and target:GetPivot().Position) or target.Position
        hrp.CFrame = CFrame.new(hrp.Position + (tPos - hrp.Position).Unit * (settings.tweenSpeed * dt))
        hrp.Velocity = Vector3.new(0, 0.1, 0)
    end
    
    if settings.autoBoss then
        local qte = player.PlayerGui:FindFirstChild("QTE", true) or player.PlayerGui:FindFirstChild("SkillCheck", true)
        if qte and qte.Visible then
            task.wait(0.15); VirtualInputManager:SendMouseButtonEvent(0, 0, 0, true, game, 1); task.wait(0.05); VirtualInputManager:SendMouseButtonEvent(0, 0, 0, false, game, 1)
        end
    end
end)

