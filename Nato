-- ================= STATUS =================
local function setStatus(msg, color)
	statusLbl.Text = "Status: "..msg
	statusLbl.TextColor3 = color or Color3.fromRGB(150,150,180)
end

-- ================= LOOP =================
local function collectLoop()
	while running do
		local char = player.Character or player.CharacterAdded:Wait()
		local hrp = getHRP()
		if not hrp then task.wait(1) continue end

		-- 🔥 ล็อก + เรียง
		scanFood()
		sortTargets(hrp)

		for _, food in ipairs(targets) do
			if not running then break end
			
			if food and food.Parent then
				local pos = getPos(food)
				if pos then
					setStatus("เก็บ: "..food.Name, Color3.fromRGB(90,200,90))
					moveTo(pos)
				end
			end
		end

		task.wait(0.1)
	end
	setStatus("Stopped")
end

-- ================= BUTTON =================
startBtn.MouseButton1Click:Connect(function()
	if running then return end
	running = true
	setStatus("Running", Color3.fromRGB(90,200,90))
	task.spawn(collectLoop)
end)

stopBtn.MouseButton1Click:Connect(function()
	running = false
	stopMover()
	setStatus("Stopped")
end)
