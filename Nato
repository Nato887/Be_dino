local Players           = game:GetService("Players")
local RunService        = game:GetService("RunService")
local CollectionService = game:GetService("CollectionService")
local UserInputService  = game:GetService("UserInputService")

local player = Players.LocalPlayer

-- ================= SETTINGS =================
local settings = {
    flyToFood = false,
    avoidEnabled = false,
    huntWeaker = false,
    antiVoid = true, -- ✅ ระบบกันตกแมพ (เปิดไว้เป็นค่าเริ่มต้น)
    tweenSpeed = 100,
}

-- ── Get Root Part ──
local function getHRP()
    local char = player.Character
    return char and (char:FindFirstChild("HumanoidRootPart") or char.PrimaryPart)
end

-- ── 1. ระบบหาคนพลังน้อยกว่า ──
local function getWeakerPlayer()
    local hrp = getHRP()
    if not hrp or not settings.huntWeaker then return nil end
    local target, bestDist = nil, math.huge
    local mySize = hrp.Size.Magnitude 
    for _, p in ipairs(Players:GetPlayers()) do
        if p ~= player and p.Character and p.Character:FindFirstChild("HumanoidRootPart") then
            local enemyRoot = p.Character.HumanoidRootPart
            if enemyRoot.Size.Magnitude < mySize then
                local d = (hrp.Position - enemyRoot.Position).Magnitude
                if d < bestDist then bestDist = d; target = enemyRoot end
            end
        end
    end
    return target
end

-- ── 2. ระบบหาของกิน (Food Tag) ──
local function getClosestFood()
    local hrp = getHRP()
    if not hrp or not settings.flyToFood then return nil end
    local best, bestDist = nil, math.huge
    for _, food in ipairs(CollectionService:GetTagged("Food")) do
        if not food or not food.Parent then continue end
        local pos = (food:IsA("Model") and food:GetPivot().Position) or (food:IsA("BasePart") and food.Position)
        if pos then
            local d = (hrp.Position - pos).Magnitude
            if d < bestDist then bestDist = d; best = { position = pos } end
        end
    end
    return best
end

-- ── 3. ระบบ Avoid Player (หนีตัวใหญ่ 150 Studs) ──
local function getDangerPlayer()
    local hrp = getHRP()
    if not hrp or not settings.avoidEnabled then return nil end
    for _, p in ipairs(Players:GetPlayers()) do
        if p ~= player and p.Character and p.Character:FindFirstChild("HumanoidRootPart") then
            local enemyRoot = p.Character.HumanoidRootPart
            if enemyRoot.Size.Magnitude > hrp.Size.Magnitude and (hrp.Position - enemyRoot.Position).Magnitude < 150 then
                return enemyRoot
            end
        end
    end
    return nil
end

