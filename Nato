-- ── LOOP ───────────────────────────────
local function setStatus(msg)
    statusLbl.Text = "Status: "..msg
end

local function collectLoop()
    while running do
        local hrp = getHRP()
        if not hrp then task.wait(0.5); continue end

        countLbl.Text = "Food in world: "..#CollectionService:GetTagged("Food")
        local food = getClosestFood()
        if food and food.instance then
            setStatus("Going to "..food.instance.Name)
            moveTo(food.position)
        else
            setStatus("No food")
            task.wait(0.3)
        end
    end
    setStatus("Stopped")
end

startBtn.MouseButton1Click:Connect(function()
    if running then return end
    running = true
    setStatus("Running")
    task.spawn(collectLoop)
end)

stopBtn.MouseButton1Click:Connect(function()
    running = false
    stopMover()
    setStatus("Stopped")
end)
