local Players           = game:GetService("Players")
local RunService        = game:GetService("RunService")
local CollectionService = game:GetService("CollectionService")
local UserInputService  = game:GetService("UserInputService")
local TweenService      = game:GetService("TweenService")

local player = Players.LocalPlayer
local running = false
local tweenSpeed = 100 -- ค่าเริ่มต้น
local avoidRadius = 15 -- ระยะห่างที่จะหลบผู้เล่นอื่น
local currentTween = nil

-- ── ฟังก์ชันหา RootPart ──
local function getHRP()
    local char = player.Character
    if not char then return nil end
    return char:FindFirstChild("HumanoidRootPart") or char.PrimaryPart
end

-- ── ฟังก์ชันคำนวณตำแหน่งเป้าหมายแบบหลบผู้เล่น ──
local function getSafePosition(targetPos)
    local hrp = getHRP()
    if not hrp then return targetPos end
    
    for _, other in ipairs(Players:GetPlayers()) do
        if other ~= player and other.Character and other.Character:FindFirstChild("HumanoidRootPart") then
            local otherPos = other.Character.HumanoidRootPart.Position
            local dist = (targetPos - otherPos).Magnitude
            if dist < avoidRadius then
                -- ถ้าเป้าหมายใกล้คนอื่นเกินไป ให้ขยับตำแหน่งเบี่ยงออกมาเล็กน้อย
                local offset = (targetPos - otherPos).Unit * avoidRadius
                return otherPos + offset
            end
        end
    end
    return targetPos
end

-- ── ฟังก์ชันหาอาหารที่ใกล้ที่สุด ──
local function getClosestFood()
    local hrp = getHRP()
    if not hrp then return nil end
    local best, bestDist = nil, math.huge
    for _, food in ipairs(CollectionService:GetTagged("Food")) do
        if not food or not food.Parent then continue end
        local pos = (food:IsA("Model") and food:GetPivot().Position) or (food:IsA("BasePart") and food.Position)
        if pos then
            local d = (hrp.Position - pos).Magnitude
            if d < bestDist then
                bestDist = d
                best = { instance = food, position = pos }
            end
        end
    end
    return best
end

-- ── ฟังก์ชัน Tween ──
local function tweenTo(targetPos)
    local hrp = getHRP()
    if not hrp then return end
    
    local safePos = getSafePosition(targetPos)
    local distance = (hrp.Position - safePos).Magnitude
    local duration = distance / tweenSpeed
    
    local info = TweenInfo.new(duration, Enum.EasingStyle.Linear)
    currentTween = TweenService:Create(hrp, info, {CFrame = CFrame.new(safePos)})
    currentTween:Play()
    currentTween.Completed:Wait()
end

