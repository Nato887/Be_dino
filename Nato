-- ปุ่มเปิด/ปิด ระบบบินฟาร์มอัตโนมัติ (ตัวละครจะลอยและบินไปเอง)
local function createToggle(name, sub, pos, prop)
    local btn = Instance.new("TextButton", panel)
    btn.Size = UDim2.new(0, 250, 0, 50); btn.Position = UDim2.new(0.5, -125, 0, pos)
    btn.BackgroundColor3 = Color3.fromRGB(30, 25, 50); btn.Text = ""; Instance.new("UICorner", btn)
    
    local tl = Instance.new("TextLabel", btn)
    tl.Size = UDim2.new(1, 0, 0, 25); tl.Position = UDim2.new(0, 12, 0, 5); tl.Text = name
    tl.TextColor3 = Color3.new(1,1,1); tl.Font = Enum.Font.GothamBold; tl.BackgroundTransparency = 1; tl.TextXAlignment = Enum.TextXAlignment.Left
    
    local sl = Instance.new("TextLabel", btn)
    sl.Size = UDim2.new(1, 0, 0, 15); sl.Position = UDim2.new(0, 12, 0, 25); sl.Text = sub
    sl.TextColor3 = Color3.fromRGB(140, 140, 160); sl.Font = Enum.Font.Gotham; sl.TextSize = 10; sl.BackgroundTransparency = 1; sl.TextXAlignment = Enum.TextXAlignment.Left

    btn.MouseButton1Click:Connect(function()
        settings[prop] = not settings[prop]
        btn.BackgroundColor3 = settings[prop] and Color3.fromRGB(130, 60, 255) or Color3.fromRGB(30, 25, 50)
    end)
end

createToggle("🚀 Auto Fly Farm", "Fly & collect food automatically", 60, "flyFarm")
createToggle("🛡️ Avoid Players", "Escape from big dinos (150s)", 120, "avoidEnabled")

