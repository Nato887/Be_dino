container.Position = UDim2.new(0, 140, 0, 10)
container.BackgroundTransparency = 1

local tabs = {
    Tab1 = Instance.new("ScrollingFrame", container),
    Tab2 = Instance.new("ScrollingFrame", container)
}

for name, frame in pairs(tabs) do
    frame.Size = UDim2.new(1, 0, 1, 0)
    frame.Visible = (name == "Tab1")
    frame.BackgroundTransparency = 1
    frame.ScrollBarThickness = 0
    Instance.new("UIListLayout", frame).Padding = UDim.new(0, 10)
end

local function showTab(tName)
    for n, f in pairs(tabs) do
        f.Visible = (n == tName)
    end
end

local function createTabBtn(n, y, t)
    local b = Instance.new("TextButton", sidebar)
    b.Size = UDim2.new(0.9, 0, 0, 40)
    b.Position = UDim2.new(0, 6, 0, y)
    b.Text = n
    b.MouseButton1Click:Connect(function()
        showTab(t)
    end)
end

createTabBtn("Automation", 60, "Tab1")
createTabBtn("Boss/Misc", 110, "Tab2")

-- ================= TOGGLES =================
local function createToggle(p, n, pr)
    local b = Instance.new("TextButton", p)
    b.Size = UDim2.new(0.95, 0, 0, 45)
    b.Text = n
    b.BackgroundColor3 = Color3.fromRGB(30, 25, 50)

    b.MouseButton1Click:Connect(function()
        settings[pr] = not settings[pr]
        b.BackgroundColor3 = settings[pr] and Color3.fromRGB(130, 60, 255) or Color3.fromRGB(30, 25, 50)
    end)
end

createToggle(tabs.Tab1, "Auto Food", "autoFood")
createToggle(tabs.Tab1, "Hunt Smaller", "huntWeaker")
createToggle(tabs.Tab1, "Avoid Players", "avoidPlayers")
createToggle(tabs.Tab1, "Anti Void", "antiVoid")

