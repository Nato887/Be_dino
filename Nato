local Players           = game:GetService("Players")
local CollectionService = game:GetService("CollectionService")
local RunService        = game:GetService("RunService")
local VirtualUser       = game:GetService("VirtualUser")

local player = Players.LocalPlayer

-- Anti AFK
player.Idled:Connect(function()
    VirtualUser:Button2Down(Vector2.new(0,0), workspace.CurrentCamera.CFrame)
    task.wait(1)
    VirtualUser:Button2Up(Vector2.new(0,0), workspace.CurrentCamera.CFrame)
end)

local running = false

-- Root part
local function getHRP()
    local char = player.Character
    if not char then return nil end
    return char:FindFirstChild("HumanoidRootPart") or char.PrimaryPart
end

-- ตรวจผู้เล่นพลังสูงใกล้
local function isDangerousNear(pos, radius)
    radius = radius or 150
    local myChar = player.Character
    if not myChar then return false end
    local myHum = myChar:FindFirstChildOfClass("Humanoid")
    if not myHum then return false end

    for _, plr in ipairs(Players:GetPlayers()) do
        if plr ~= player and plr.Character then
            local root = plr.Character:FindFirstChild("HumanoidRootPart")
            local hum  = plr.Character:FindFirstChildOfClass("Humanoid")
            if root and hum then
                local dist = (root.Position - pos).Magnitude
                if dist < radius and hum.Health > myHum.Health then
                    return true
                end
            end
        end
    end
    return false
end

-- หาอาหารปลอดภัย ปรับทุกเฟรม
local function getSafeFoods(limit)
    local hrp = getHRP()
    if not hrp then return {} end
    local foods = {}
    for _, food in ipairs(CollectionService:GetTagged("Food")) do
        if food and food.Parent then
            local pos
            if food:IsA("Model") then
                pos = food:GetPivot().Position
            elseif food:IsA("BasePart") then
                pos = food.Position
            end
            -- มีอาหารจริง + ปลอดภัย
            if pos and food.Parent and not isDangerousNear(pos) then
                table.insert(foods, {instance = food, position = pos})
            end
        end
    end
    table.sort(foods, function(a,b)
        return (a.position - hrp.Position).Magnitude < (b.position - hrp.Position).Magnitude
    end)
    local result = {}
    for i=1, math.min(limit, #foods) do
        table.insert(result, foods[i])
    end
    return result
end

-- Step warp adaptive speed
local function adaptiveWarp(target)
    local hrp = getHRP()
    if not hrp or not target.instance or not target.instance.Parent then return false end
    local startPos = hrp.Position
    local targetPos = target.position
    local dist = (targetPos - startPos).Magnitude
    local steps = math.clamp(math.floor(dist / 4), 4, 25)

    for i = 1, steps do
        if not running then return false end
        -- ตรวจว่าจุดยังมีเป้าหมายอยู่
        if not target.instance or not target.instance.Parent then
            return false
        end

        local nextPos = startPos:Lerp(targetPos, i/steps)
        if isDangerousNear(nextPos, 150) then
            return false -- ข้ามจุดนี้
        end

        hrp.CFrame = CFrame.new(nextPos + Vector3.new(0,3,0))
        task.wait(0.015)
    end
    return true
end

-- FARM LOOP
local function farmLoop()
    while running do
        local hrp = getHRP()
        if not hrp then
            player.CharacterAdded:Wait()
            task.wait(1)
            continue
        end

        local foods = getSafeFoods(15)

        for _, target in ipairs(foods) do
            if not running then break end
            adaptiveWarp(target)
        end

        task.wait(0.01)
    end
end

