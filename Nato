-- Slider Touch Logic
local drag = false
knob.InputBegan:Connect(function(i) if i.UserInputType == Enum.UserInputType.Touch or i.UserInputType == Enum.UserInputType.MouseButton1 then drag = true end end)
UserInputService.InputEnded:Connect(function(i) if i.UserInputType == Enum.UserInputType.Touch or i.UserInputType == Enum.UserInputType.MouseButton1 then drag = false end end)
UserInputService.InputChanged:Connect(function(i)
    if drag and (i.UserInputType == Enum.UserInputType.Touch or i.UserInputType == Enum.UserInputType.MouseMovement) then
        local r = math.clamp((i.Position.X - track.AbsolutePosition.X) / track.AbsoluteSize.X, 0, 1)
        tweenSpeed = math.max(10, math.floor(r * 500))
        knob.Position = UDim2.new(r, -10, 0.5, -10)
        speedText.Text = "Speed: " .. tweenSpeed
    end
end)

-- Main Loop
start.MouseButton1Click:Connect(function()
    if running then return end
    running = true
    task.spawn(function()
        while running do
            local target = getTarget()
            if target then
                status.Text = "Status: Going to " .. target.instance.Name
                moveTo(target.pos)
            else
                status.Text = "Status: Searching..."
            end
            task.wait(0.1)
        end
        status.Text = "Status: Stopped"
    end)
end)

stop.MouseButton1Click:Connect(function()
    running = false
    stopTween()
end)

-- Draggable GUI
local dStart, sPos
main.InputBegan:Connect(function(i) if i.UserInputType == Enum.UserInputType.Touch or i.UserInputType == Enum.UserInputType.MouseButton1 then dStart = i.Position; sPos = main.Position end end)
main.InputChanged:Connect(function(i) if dStart and (i.UserInputType == Enum.UserInputType.Touch or i.UserInputType == Enum.UserInputType.MouseMovement) then
    local delta = i.Position - dStart
    main.Position = UDim2.new(sPos.X.Scale, sPos.X.Offset + delta.X, sPos.Y.Scale, sPos.Y.Offset + delta.Y)
end end)
main.InputEnded:Connect(function() dStart = nil end)
