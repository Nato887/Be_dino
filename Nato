local Players           = game:GetService("Players")
local RunService        = game:GetService("RunService")
local CollectionService = game:GetService("CollectionService")
local UserInputService  = game:GetService("UserInputService")

local player = Players.LocalPlayer
if not player.Character then player.CharacterAdded:Wait() end

local running    = false
local tweenSpeed = 100
local moverConn  = nil

-- ── ROOT ─────────────────────────────────────────
local function getHRP()
    local char = player.Character
    if not char then return nil end
    return char:FindFirstChild("HumanoidRootPart") or char.PrimaryPart
end

-- ── FOOD ─────────────────────────────────────────
local function getClosestFood()
    local hrp = getHRP()
    if not hrp then return nil end

    local best, bestDist = nil, math.huge

    for _, food in ipairs(CollectionService:GetTagged("Food")) do
        if not food or not food.Parent then continue end

        local pos
        if food:IsA("Model") then
            pos = food:GetPivot().Position
        elseif food:IsA("BasePart") then
            pos = food.Position
        end

        if pos then
            local dist = (hrp.Position - pos).Magnitude
            if dist < bestDist then
                bestDist = dist
                best = {instance = food, position = pos}
            end
        end
    end

    return best
end

-- ── PLAYER AVOID ─────────────────────────────────
local AVOID_DISTANCE = 12

local function getClosestPlayer()
    local hrp = getHRP()
    if not hrp then return nil end

    local closest, distMin = nil, math.huge

    for _, plr in ipairs(Players:GetPlayers()) do
        if plr ~= player and plr.Character then
            local root = plr.Character:FindFirstChild("HumanoidRootPart")
            if root then
                local d = (hrp.Position - root.Position).Magnitude
                if d < distMin then
                    distMin = d
                    closest = root
                end
            end
        end
    end

    return closest, distMin
end

-- ── MOVE ─────────────────────────────────────────
local function stopMover()
    if moverConn then
        moverConn:Disconnect()
        moverConn = nil
    end
end

local function moveTo(targetPos)
    local hrp = getHRP()
    if not hrp or not hrp.Parent then return end
    local humanoid = hrp.Parent:FindFirstChildOfClass("Humanoid")
    if not humanoid then return end

    local reached = false
    stopMover()

    moverConn = RunService.Heartbeat:Connect(function(dt)
        if not hrp or not hrp.Parent or not running then
            reached = true
            stopMover()
            return
        end

        local direction = targetPos - hrp.Position
        local dist = direction.Magnitude
        if dist < 2 then
            reached = true
            stopMover()
            return
        end

        local moveDir = direction.Unit

        -- ── AVOID PLAYER ──
        local threat, threatDist = getClosestPlayer()
        if threat and threatDist < AVOID_DISTANCE then
            local avoid = (hrp.Position - threat.Position)
            if avoid.Magnitude > 0 then
                moveDir = (moveDir + avoid.Unit * 2).Unit
            end
        end

        local nextPos = hrp.Position + moveDir * tweenSpeed * dt
        humanoid:MoveTo(Vector3.new(nextPos.X, hrp.Position.Y, nextPos.Z))
    end)

    while not reached do task.wait(0.03) end
end

