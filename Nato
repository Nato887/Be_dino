-- ฟังก์ชันสร้างปุ่มแบบจิ๋ว
local function createToggle(name, pos, prop, parent)
    local btn = Instance.new("TextButton", parent)
    btn.Size = UDim2.new(0, 180, 0, 38); btn.Position = UDim2.new(0.5, -90, 0, pos)
    btn.BackgroundColor3 = settings[prop] and Color3.fromRGB(130, 60, 255) or Color3.fromRGB(30, 25, 55)
    btn.Text = name; btn.TextColor3 = Color3.new(1,1,1); btn.Font = Enum.Font.GothamBold; btn.TextSize = 10; Instance.new("UICorner", btn)
    
    btn.MouseButton1Click:Connect(function()
        settings[prop] = not settings[prop]
        btn.BackgroundColor3 = settings[prop] and Color3.fromRGB(130, 60, 255) or Color3.fromRGB(30, 25, 55)
    end)
end

