-- ================= MAIN LOOP =================
RunService.Heartbeat:Connect(function(dt)
    local hrp = getHRP()
    if not hrp then return end

    -- 🛡️ 1. ระบบ Anti-Void (ลำดับความสำคัญสูงสุด)
    if settings.antiVoid and hrp.Position.Y < -50 then -- ถ้าความสูงต่ำกว่า -50
        hrp.Velocity = Vector3.new(0, 0, 0) -- หยุดแรงเหวี่ยง
        hrp.CFrame = CFrame.new(hrp.Position.X, 100, hrp.Position.Z) -- วาร์ปกลับขึ้นมาบนฟ้าที่ความสูง 100
        return
    end

    -- 🛡️ 2. ระบบหนีตัวใหญ่
    local danger = getDangerPlayer()
    if danger then
        local escapeDir = (hrp.Position - danger.Position).Unit
        hrp.CFrame = CFrame.new(hrp.Position + (escapeDir + Vector3.new(0, 0.3, 0)).Unit * (settings.tweenSpeed * dt))
        return
    end

    local targetPos = nil

    -- 🎯 3. บินหาคนพลังน้อย
    local weaker = getWeakerPlayer()
    if weaker then targetPos = weaker.Position end

    -- 🎯 4. บินหาของกิน
    if not targetPos and settings.flyToFood then
        local food = getClosestFood()
        if food then targetPos = food.position end
    end

    -- ✈️ การเคลื่อนที่ไปยังเป้าหมาย
    if targetPos then
        local diff = targetPos - hrp.Position
        if diff.Magnitude > 1.5 then
            hrp.CFrame = CFrame.new(hrp.Position + diff.Unit * (settings.tweenSpeed * dt))
            hrp.Velocity = Vector3.new(0, 0.1, 0) -- ต้านแรงโน้มถ่วง
        end
    end
end)
