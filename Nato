local Players = game:GetService("Players")
local RunService = game:GetService("RunService")
local CollectionService = game:GetService("CollectionService")
local UserInputService = game:GetService("UserInputService")
local VirtualUser = game:GetService("VirtualUser")

local player = Players.LocalPlayer
if not player.Character then player.CharacterAdded:Wait() end

-- CONFIG
local running = false
local farmSpeed = 100
local whiteScreenOn = false
local fastMode = false
local startTime = os.time()

-- UTILS
local function getHRP()
    local char = player.Character
    return char and char:FindFirstChild("HumanoidRootPart")
end

-- FIX: ไม่ตกแมพ (ล็อคแกน Y)
local function moveTo(targetPos, speed, dt)
    local hrp = getHRP()
    if not hrp then return end

    local safeY = hrp.Position.Y
    local target = Vector3.new(targetPos.X, safeY, targetPos.Z)

    local diff = target - hrp.Position
    local dist = diff.Magnitude
    if dist < 2 then return end

    local step = math.min(speed * dt, dist)
    hrp.CFrame = CFrame.new(hrp.Position + diff.Unit * step)
end

-- LOOP
local moverConn
local function stopMover()
    if moverConn then moverConn:Disconnect() moverConn = nil end
end

local function startMovementLoop()
    stopMover()

    moverConn = RunService.Heartbeat:Connect(function(dt)
        if not running then return end
        local hrp = getHRP()
        if not hrp then return end

        local foodPos, dist = nil, math.huge

        for _, f in CollectionService:GetTagged("Food") do
            if f and f.Parent then
                local p = f:IsA("Model") and f:GetPivot().Position or f.Position
                local d = (hrp.Position - p).Magnitude
                if d < dist then
                    dist = d
                    foodPos = p
                end
            end
        end

        if foodPos then
            moveTo(foodPos, farmSpeed, dt)
        end
    end)
end

