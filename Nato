local Players           = game:GetService("Players")
local RunService        = game:GetService("RunService")
local CollectionService = game:GetService("CollectionService")
local UserInputService  = game:GetService("UserInputService")
local VirtualUser       = game:GetService("VirtualUser")

local player = Players.LocalPlayer

-- ===== CONFIG =====
local SAFE_Y = -50
local DETECT_DISTANCE = 100

local running   = false
local tweenSpeed = 100
local moverConn  = nil

-- ===== CHARACTER =====
local function getChar()
    return player.Character or player.CharacterAdded:Wait()
end

local function getHRP()
    local char = getChar()
    return char:FindFirstChild("HumanoidRootPart") or char.PrimaryPart
end

-- ===== FOOD =====
local function getClosestFood()
    local hrp = getHRP()
    if not hrp then return nil end

    local best, bestDist = nil, math.huge
    for _, food in CollectionService:GetTagged("Food") do
        if food and food.Parent then
            local pos = food:IsA("Model") and food:GetPivot().Position or food.Position
            local d = (hrp.Position - pos).Magnitude
            if d < bestDist then
                bestDist = d
                best = {instance = food, position = pos}
            end
        end
    end
    return best
end

-- ===== GROWTH =====
local function getMyGrowth()
    local char = getChar()
    local g = char:FindFirstChild("Growth")
    return g and g.Value or 0
end

-- ===== PLAYER AI (100 STUDS ONLY) =====
local function getTargetPlayer()
    local hrp = getHRP()
    if not hrp then return nil end

    local myGrowth = getMyGrowth()
    local closest = nil
    local closestDist = DETECT_DISTANCE

    for _, plr in Players:GetPlayers() do
        if plr ~= player and plr.Character then
            local root = plr.Character:FindFirstChild("HumanoidRootPart")
            local growth = plr.Character:FindFirstChild("Growth")

            if root and growth then
                local dist = (hrp.Position - root.Position).Magnitude

                if dist <= DETECT_DISTANCE and dist < closestDist then
                    closestDist = dist
                    closest = {
                        pos = root.Position,
                        growth = growth.Value
                    }
                end
            end
        end
    end

    if not closest then return nil end

    if closest.growth > myGrowth then
        return "ESCAPE", closest.pos
    else
        return "HUNT", closest.pos
    end
end

-- ===== MOVE =====
local function stopMover()
    if moverConn then moverConn:Disconnect() moverConn = nil end
end

local function moveTo(pos)
    stopMover()

    moverConn = RunService.Heartbeat:Connect(function(dt)
        local hrp = getHRP()
        if not hrp or not running then return end

        -- anti void
        if hrp.Position.Y < SAFE_Y then
            hrp.CFrame = CFrame.new(0,50,0)
        end

        local diff = pos - hrp.Position
        local dist = diff.Magnitude

        if dist < 2 then stopMover() return end

        hrp.CFrame = CFrame.new(hrp.Position + diff.Unit * math.min(tweenSpeed*dt, dist))
    end)
end

-- ===== ANTI AFK =====
task.spawn(function()
    while true do
        task.wait(60)
        VirtualUser:CaptureController()
        VirtualUser:ClickButton2(Vector2.new())
    end
end)

-- ===== GUI =====
local gui = Instance.new("ScreenGui")
gui.Name = "FoodCollector"
gui.ResetOnSpawn = false
gui.Parent = player:WaitForChild("PlayerGui")

-- toggle
local toggle = Instance.new("TextButton", gui)
toggle.Size = UDim2.new(0,100,0,30)
toggle.Position = UDim2.new(0,10,0,10)
toggle.Text = "OPEN"

local panel = Instance.new("Frame", gui)
panel.Size = UDim2.new(0,270,0,200)
panel.Position = UDim2.new(0.5,-135,0.5,-100)
panel.Visible = false

toggle.MouseButton1Click:Connect(function()
    panel.Visible = not panel.Visible
end)

-- ===== MOBILE SLIDER =====
local dragging = false

local function updateSlider(x)
    local ratio = math.clamp((x - panel.AbsolutePosition.X)/200,0,1)
    tweenSpeed = math.max(1, math.floor(ratio * 1000))
end

UserInputService.InputBegan:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.Touch then
        dragging = true
    end
end)

UserInputService.InputEnded:Connect(function()
    dragging = false
end)

UserInputService.InputChanged:Connect(function(input)
    if dragging and input.UserInputType == Enum.UserInputType.Touch then
        updateSlider(input.Position.X)
    end
end)

-- ===== LOOP =====
local function loop()
    while running do
        local state, pos = getTargetPlayer()

        if state == "ESCAPE" then
            local hrp = getHRP()
            local dir = (hrp.Position - pos).Unit
            moveTo(hrp.Position + dir * 100)

        elseif state == "HUNT" then
            moveTo(pos)

        else
            local food = getClosestFood()
            if food then
                moveTo(food.position)
            end
        end

        task.wait(0.2)
    end
end

-- ===== BUTTON =====
local start = Instance.new("TextButton", panel)
start.Size = UDim2.new(0,100,0,40)
start.Position = UDim2.new(0,10,1,-50)
start.Text = "START"

local stop = Instance.new("TextButton", panel)
stop.Size = UDim2.new(0,100,0,40)
stop.Position = UDim2.new(1,-110,1,-50)
stop.Text = "STOP"

start.MouseButton1Click:Connect(function()
    if running then return end
    running = true
    task.spawn(loop)
end)

stop.MouseButton1Click:Connect(function()
    running = false
    stopMover()
end)

-- ===== RESPAWN FIX =====
player.CharacterAdded:Connect(function()
    task.wait(1)
    if running then
        task.spawn(loop)
    end
end)
