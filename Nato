local Players = game:GetService("Players")
local RunService = game:GetService("RunService")
local CollectionService = game:GetService("CollectionService")
local UserInputService = game:GetService("UserInputService")

local player = Players.LocalPlayer
local character = player.Character or player.CharacterAdded:Wait()

-- ================= SETTINGS =================
local settings = {
    running = false,
    avoidEnabled = false,
    flyFarm = false, -- ระบบบินฟาร์มอัตโนมัติ
    tweenSpeed = 100,
}

-- ── Get the REAL root ──
local function getHRP()
    local char = player.Character
    if not char then return nil end
    return char:FindFirstChild("HumanoidRootPart") or char.PrimaryPart
end

-- ── 1. ระบบหาของกิน (Food Tag) ──
local function getClosestFood()
    local hrp = getHRP()
    if not hrp then return nil end
    local best, bestDist = nil, math.huge
    for _, food in ipairs(CollectionService:GetTagged("Food")) do
        if not food or not food.Parent then continue end
        local pos = (food:IsA("Model") and food:GetPivot().Position) or (food:IsA("BasePart") and food.Position)
        if pos then
            local d = (hrp.Position - pos).Magnitude
            if d < bestDist then bestDist = d; best = { instance = food, position = pos } end
        end
    end
    return best
end

-- ── 2. ระบบ Avoid Player (หนี 150 Studs) ──
local function getDangerPlayer()
    local hrp = getHRP()
    if not hrp or not settings.avoidEnabled then return nil end
    for _, p in ipairs(Players:GetPlayers()) do
        if p ~= player and p.Character and p.Character:FindFirstChild("HumanoidRootPart") then
            local enemyRoot = p.Character.HumanoidRootPart
            if enemyRoot.Size.Magnitude > hrp.Size.Magnitude and (hrp.Position - enemyRoot.Position).Magnitude < 150 then
                return enemyRoot
            end
        end
    end
    return nil
end

