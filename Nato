local Players           = game:GetService("Players")
local CollectionService = game:GetService("CollectionService")
local RunService        = game:GetService("RunService")
local VirtualUser       = game:GetService("VirtualUser")

local player = Players.LocalPlayer
if not player.Character then player.CharacterAdded:Wait() end

-- Anti AFK
player.Idled:Connect(function()
    VirtualUser:Button2Down(Vector2.new(0,0), workspace.CurrentCamera.CFrame)
    task.wait(1)
    VirtualUser:Button2Up(Vector2.new(0,0), workspace.CurrentCamera.CFrame)
end)

local running = false

-- Root
local function getHRP()
    local char = player.Character
    if not char then return nil end
    return char:FindFirstChild("HumanoidRootPart") or char.PrimaryPart
end

-- ตรวจสอบผู้เล่นพลังสูงรอบตัวทุกเฟรม
local function isDangerousNear(pos, radius)
    radius = radius or 150
    for _, plr in ipairs(Players:GetPlayers()) do
        if plr ~= player and plr.Character then
            local root = plr.Character:FindFirstChild("HumanoidRootPart")
            local hum  = plr.Character:FindFirstChildOfClass("Humanoid")
            local myHum = player.Character:FindFirstChildOfClass("Humanoid")
            if root and hum and myHum then
                local dist = (root.Position - pos).Magnitude
                if dist < radius and hum.Health > myHum.Health then
                    return true
                end
            end
        end
    end
    return false
end

-- หาอาหารหลายจุดเฉพาะพื้นที่ปลอดภัย
local function getSafeFoods(limit)
    local hrp = getHRP()
    if not hrp then return {} end

    local foods = {}
    for _, food in ipairs(CollectionService:GetTagged("Food")) do
        if food and food.Parent then
            local pos
            if food:IsA("Model") then pos = food:GetPivot().Position
            elseif food:IsA("BasePart") then pos = food.Position end

            if pos and not isDangerousNear(pos) then
                table.insert(foods, {instance=food, position=pos})
            end
        end
    end

    table.sort(foods, function(a,b)
        return (a.position - hrp.Position).Magnitude < (b.position - hrp.Position).Magnitude
    end)

    local result = {}
    for i=1, math.min(limit, #foods) do
        table.insert(result, foods[i])
    end
    return result
end

-- วาร์ปช้า + ปลอดภัย
local function safeWarp(pos)
    local hrp = getHRP()
    if not hrp then return end
    -- step 1: ขึ้นสูง
    hrp.CFrame = CFrame.new(pos + Vector3.new(0,6,0))
    task.wait(0.05) -- ให้เกมโหลด
    -- step 2: ลงเก็บ
    hrp.CFrame = CFrame.new(pos + Vector3.new(0,2,0))
    task.wait(0.05)
end

-- LOOP หลัก
local function farmLoop()
    while running do
        local foods = getSafeFoods(8) -- เก็บหลายจุดต่อรอบ
        for _, f in ipairs(foods) do
            if not isDangerousNear(f.position) then
                safeWarp(f.position)
            else
                task.wait(0.2) -- พบผู้เล่นพลังสูง → รอ
            end
        end
        task.wait(0.05) -- ลื่นสุด
    end
end

-- GUI
local gui = Instance.new("ScreenGui", player:WaitForChild("PlayerGui"))

local start = Instance.new("TextButton", gui)
start.Size = UDim2.new(0,100,0,40)
start.Position = UDim2.new(0,20,0,20)
start.Text = "START"

local stop = Instance.new("TextButton", gui)
stop.Size = UDim2.new(0,100,0,40)
stop.Position = UDim2.new(0,20,0,70)
stop.Text = "STOP"

start.MouseButton1Click:Connect(function()
    if running then return end
    running = true
    task.spawn(farmLoop)
end)

stop.MouseButton1Click:Connect(function()
    running = false
end)
