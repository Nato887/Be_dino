-- Speed Slider (แบบสวยกว่าเดิม)
local sFrame = Instance.new("Frame", tabs.Main); sFrame.Size = UDim2.new(0.95, 0, 0, 60); sFrame.BackgroundTransparency = 1
local sLabel = Instance.new("TextLabel", sFrame); sLabel.Size = UDim2.new(1, 0, 0, 20); sLabel.Text = "Tween Speed: " .. settings.tweenSpeed; sLabel.TextColor3 = Color3.new(0.8, 0.8, 1); sLabel.BackgroundTransparency = 1
local track = Instance.new("Frame", sFrame); track.Size = UDim2.new(1, -20, 0, 6); track.Position = UDim2.new(0, 10, 0, 35); track.BackgroundColor3 = Color3.fromRGB(45, 45, 70); Instance.new("UICorner", track)
local knob = Instance.new("Frame", track); knob.Size = UDim2.new(0, 16, 0, 16); knob.Position = UDim2.new(0.15, -8, 0.5, -8); knob.BackgroundColor3 = Color3.new(1,1,1); Instance.new("UICorner", knob)

knob.InputBegan:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
        local connection
        connection = RunService.RenderStepped:Connect(function()
            local mousePos = UserInputService:GetMouseLocation().X
            local relativePos = math.clamp((mousePos - track.AbsolutePosition.X) / track.AbsoluteSize.X, 0, 1)
            knob.Position = UDim2.new(relativePos, -8, 0.5, -8)
            settings.tweenSpeed = math.floor(relativePos * 1000)
            sLabel.Text = "Tween Speed: " .. settings.tweenSpeed
            if not UserInputService:IsMouseButtonPressed(Enum.UserInputType.MouseButton1) then connection:Disconnect() end
        end)
    end
end)

-- ================= LOGIC IMPROVEMENT =================

RunService.Heartbeat:Connect(function(dt)
    local hrp = getHRP()
    if not hrp then return end

    -- 🛡️ Anti Void
    if settings.antiVoid and hrp.Position.Y < -50 then
        hrp.Velocity = Vector3.new(0,0,0)
        hrp.CFrame = CFrame.new(hrp.Position.X, 150, hrp.Position.Z)
        return
    end

    -- 🏃 Avoid Bigger Dino (ฉลาดขึ้น: หนีไปหาอาหารแทน)
    local isEscaping = false
    if settings.avoidPlayers then
        for _, p in ipairs(Players:GetPlayers()) do
            if p ~= player and p.Character and p.Character:FindFirstChild("HumanoidRootPart") then
                local eRoot = p.Character.HumanoidRootPart
                -- ถ้าศัตรูตัวใหญ่กว่า และอยู่ใกล้ระยะ 150
                if eRoot.Size.Magnitude > hrp.Size.Magnitude and (hrp.Position - eRoot.Position).Magnitude < 150 then
                    isEscaping = true
                    -- หาพิกัดหนี (ทิศทางตรงข้ามศัตรู)
                    local escapeDir = (hrp.Position - eRoot.Position).Unit
                    local targetPos = hrp.Position + (escapeDir * settings.tweenSpeed * dt)
                    
                    -- ถ้าเปิด Auto Food ให้พยายามหนีไปในทิศทางที่มีอาหาร
                    if settings.autoFood then
                        for _, food in ipairs(CollectionService:GetTagged("Food")) do
                            if food and food.Parent and (food.Position - eRoot.Position).Magnitude > 150 then
                                targetPos = food.Position
                                break
                            end
                        end
                    end
                    hrp.CFrame = CFrame.new(targetPos)
                    return
                end
            end
        end
    end

    -- 🦖 Hunt Smaller Dino (Tween ไปหาเหยื่อ)
    local target = nil
    if not isEscaping and settings.huntWeaker then
        for _, p in ipairs(Players:GetPlayers()) do
            if p ~= player and p.Character and p.Character:FindFirstChild("HumanoidRootPart") then
                local eRoot = p.Character.HumanoidRootPart
                if eRoot.Size.Magnitude < hrp.Size.Magnitude and eRoot.Size.Magnitude > 20 then
                    target = eRoot
                    break
                end
            end
        end
    end

    -- 🍖 Farm Food
    if not target and not isEscaping and settings.autoFood then
        for _, v in ipairs(CollectionService:GetTagged("Food")) do
            if v and v.Parent then target = v; break end
        end
    end

    -- Movement execution
    if target then
        local tPos = (target:IsA("Model") and target:GetPivot().Position) or target.Position
        local moveDir = (tPos - hrp.Position).Unit
        hrp.CFrame = CFrame.new(hrp.Position + (moveDir * settings.tweenSpeed * dt))
        hrp.Velocity = Vector3.new(0, 0.1, 0)
    end
end)

