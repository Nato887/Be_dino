local Players           = game:GetService("Players")
local RunService        = game:GetService("RunService")
local CollectionService = game:GetService("CollectionService")
local UserInputService  = game:GetService("UserInputService")
local TweenService      = game:GetService("TweenService")

local player = Players.LocalPlayer
if not player.Character then player.CharacterAdded:Wait() end

local running = false
local tweenSpeed = 100 -- studs per second
local moverConn = nil

-- ── Get the REAL root (non-massless, direct child of character) ──
local function getHRP()
    local char = player.Character
    if not char then return nil end
    for _, v in ipairs(char:GetChildren()) do
        if v.Name == "RootPart" and v:IsA("BasePart") and not v.Massless then
            return v
        end
    end
    return char.PrimaryPart
end

-- ── Avoid other players within 50 studs ──
local function adjustForPlayers(targetPos)
    for _, plr in ipairs(Players:GetPlayers()) do
        if plr ~= player and plr.Character and plr.Character.PrimaryPart then
            local dist = (plr.Character.PrimaryPart.Position - targetPos).Magnitude
            if dist < 50 then
                -- move target 50 studs away in opposite direction
                local direction = (targetPos - plr.Character.PrimaryPart.Position).Unit
                targetPos = plr.Character.PrimaryPart.Position + direction * 50
            end
        end
    end
    return targetPos
end

-- ── Get closest food ──
local function getClosestFood()
    local hrp = getHRP()
    if not hrp then return nil end
    local best, bestDist = nil, math.huge
    for _, food in CollectionService:GetTagged("Food") do
        if not food or not food.Parent then continue end
        local ok, pos = pcall(function()
            if food:IsA("Model") then return food:GetPivot().Position
            elseif food:IsA("BasePart") then return food.Position end
        end)
        if ok and pos then
            local d = (hrp.Position - pos).Magnitude
            if d < bestDist then
                bestDist = d
                best = { instance = food, position = pos }
            end
        end
    end
    return best
end

-- ── Move with Tween ──
local function moveTo(targetPos)
    local hrp = getHRP()
    if not hrp then return end

    targetPos = adjustForPlayers(targetPos)

    local distance = (hrp.Position - targetPos).Magnitude
    local time = distance / tweenSpeed
    local tweenInfo = TweenInfo.new(time, Enum.EasingStyle.Linear)
    local tween = TweenService:Create(hrp, tweenInfo, {CFrame = CFrame.new(targetPos)})
    tween:Play()
    tween.Completed:Wait()
end

