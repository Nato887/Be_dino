local Players           = game:GetService("Players")
local RunService        = game:GetService("RunService")
local CollectionService = game:GetService("CollectionService")
local UserInputService  = game:GetService("UserInputService")
local VirtualUser       = game:GetService("VirtualUser")

local player = Players.LocalPlayer
if not player.Character then player.CharacterAdded:Wait() end

-- ✅ Anti AFK
player.Idled:Connect(function()
    VirtualUser:Button2Down(Vector2.new(0,0), workspace.CurrentCamera.CFrame)
    task.wait(1)
    VirtualUser:Button2Up(Vector2.new(0,0), workspace.CurrentCamera.CFrame)
end)

local running   = false
local tweenSpeed = 100

-- Root
local function getHumanoid()
    local char = player.Character
    if not char then return nil end
    return char:FindFirstChildOfClass("Humanoid")
end

local function getHRP()
    local char = player.Character
    if not char then return nil end
    return char:FindFirstChild("HumanoidRootPart")
end

local function getClosestFood()
    local hrp = getHRP()
    if not hrp then return nil end

    local best, dist = nil, math.huge
    for _, food in CollectionService:GetTagged("Food") do
        if food and food.Parent then
            local pos = food:IsA("Model") and food:GetPivot().Position or food.Position
            local d = (hrp.Position - pos).Magnitude
            if d < dist then
                dist = d
                best = {instance = food, position = pos}
            end
        end
    end
    return best
end

-- ✅ ใช้ MoveTo แทน (ไม่ตกแมพ)
local function moveTo(pos)
    local hum = getHumanoid()
    if not hum then return end

    hum.WalkSpeed = math.clamp(tweenSpeed/10, 8, 100) -- ปรับตามสปีด

    hum:MoveTo(pos)
    hum.MoveToFinished:Wait()
end

-- GUI
local gui = Instance.new("ScreenGui", player.PlayerGui)

local panel = Instance.new("Frame", gui)
panel.Size = UDim2.new(0,260,0,200)
panel.Position = UDim2.new(0.5,-130,0.5,-100)
panel.BackgroundColor3 = Color3.fromRGB(20,20,30)
panel.Active = true
panel.Draggable = true

-- Status
local status = Instance.new("TextLabel", panel)
status.Size = UDim2.new(1,0,0,30)
status.Text = "Status: Idle"
status.BackgroundTransparency = 1
status.TextColor3 = Color3.new(1,1,1)

local speedLbl = Instance.new("TextLabel", panel)
speedLbl.Position = UDim2.new(0,0,0,30)
speedLbl.Size = UDim2.new(1,0,0,25)
speedLbl.BackgroundTransparency = 1
speedLbl.Text = "Speed: 100"

-- Slider
local track = Instance.new("Frame", panel)
track.Position = UDim2.new(0,10,0,70)
track.Size = UDim2.new(1,-20,0,8)

local fill = Instance.new("Frame", track)
fill.Size = UDim2.new(0.1,0,1,0)

local knob = Instance.new("Frame", track)
knob.Size = UDim2.new(0,18,0,18)
knob.Position = UDim2.new(0.1,-9,0.5,-9)

local dragging = false

local function updateSlider(x)
    local ratio = math.clamp((x - track.AbsolutePosition.X)/track.AbsoluteSize.X,0,1)
    tweenSpeed = math.floor(ratio * 1000)
    fill.Size = UDim2.new(ratio,0,1,0)
    knob.Position = UDim2.new(ratio,-9,0.5,-9)
    speedLbl.Text = "Speed: "..tweenSpeed
end

track.InputBegan:Connect(function(i)
    if i.UserInputType == Enum.UserInputType.MouseButton1 or i.UserInputType == Enum.UserInputType.Touch then
        dragging = true
        panel.Draggable = false -- 🔥 ปิดลากหน้าต่าง
        updateSlider(i.Position.X)
    end
end)

UserInputService.InputChanged:Connect(function(i)
    if dragging and (i.UserInputType == Enum.UserInputType.MouseMovement or i.UserInputType == Enum.UserInputType.Touch) then
        updateSlider(i.Position.X)
    end
end)

UserInputService.InputEnded:Connect(function(i)
    if i.UserInputType == Enum.UserInputType.MouseButton1 or i.UserInputType == Enum.UserInputType.Touch then
        dragging = false
        panel.Draggable = true -- 🔥 เปิดกลับ
    end
end)

-- Buttons
local startBtn = Instance.new("TextButton", panel)
startBtn.Position = UDim2.new(0,10,0,120)
startBtn.Size = UDim2.new(0,110,0,40)
startBtn.Text = "START"

local stopBtn = Instance.new("TextButton", panel)
stopBtn.Position = UDim2.new(0,130,0,120)
stopBtn.Size = UDim2.new(0,110,0,40)
stopBtn.Text = "STOP"

local function loop()
    while running do
        local food = getClosestFood()
        if food then
            status.Text = "Going: "..food.instance.Name
            moveTo(food.position)
        else
            status.Text = "No food"
            task.wait(0.3)
        end
    end
    status.Text = "Stopped"
end

startBtn.MouseButton1Click:Connect(function()
    if running then return end
    running = true
    status.Text = "Running"
    task.spawn(loop)
end)

stopBtn.MouseButton1Click:Connect(function()
    running = false
    status.Text = "Stopped"
end)
