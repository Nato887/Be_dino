local knob = Instance.new("Frame", track)
knob.Size = UDim2.new(0, 22, 0, 22); knob.Position = UDim2.new(settings.tweenSpeed/1000, -11, 0.5, -11)
knob.BackgroundColor3 = Color3.new(1,1,1); Instance.new("UICorner", knob)

local dragging = false
local function moveSlider(input)
    local ratio = math.clamp((input.Position.X - track.AbsolutePosition.X) / track.AbsoluteSize.X, 0, 1)
    knob.Position = UDim2.new(ratio, -11, 0.5, -11)
    settings.tweenSpeed = math.floor(ratio * 1000)
    sLabel.Text = "Tween Speed: " .. settings.tweenSpeed
end

knob.InputBegan:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then dragging = true end
end)

UserInputService.InputChanged:Connect(function(input)
    if dragging and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then moveSlider(input) end
end)

UserInputService.InputEnded:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then dragging = false end
end)

local function createToggle(parent, name, prop)
    local btn = Instance.new("TextButton", parent)
    btn.Size = UDim2.new(1, 0, 0, 45); btn.BackgroundColor3 = settings[prop] and Color3.fromRGB(130, 60, 255) or Color3.fromRGB(32, 28, 45)
    btn.Text = "   " .. name; btn.TextColor3 = Color3.new(1,1,1); btn.Font = Enum.Font.GothamMedium; btn.TextXAlignment = Enum.TextXAlignment.Left; Instance.new("UICorner", btn)
    btn.MouseButton1Click:Connect(function()
        settings[prop] = not settings[prop]
        TweenService:Create(btn, TweenInfo.new(0.2), {BackgroundColor3 = settings[prop] and Color3.fromRGB(130, 60, 255) or Color3.fromRGB(32, 28, 45)}):Play()
    end)
end

