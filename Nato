-- Function สลับ Tab
local function showTab(tabName)
    for name, frame in pairs(tabs) do frame.Visible = (name == tabName) end
    settings.currentTab = tabName
end

-- สร้างปุ่ม Tab
local function createTabBtn(name, yPos)
    local btn = Instance.new("TextButton", sidebar)
    btn.Size = UDim2.new(0.9, 0, 0, 35); btn.Position = UDim2.new(0.05, 0, 0, yPos)
    btn.BackgroundColor3 = Color3.fromRGB(40, 35, 55); btn.Text = name
    btn.TextColor3 = Color3.new(1,1,1); btn.Font = Enum.Font.GothamBold; Instance.new("UICorner", btn)
    btn.MouseButton1Click:Connect(function() showTab(name) end)
end

createTabBtn("Main", 10); createTabBtn("Boss", 50)

-- Function สร้าง Toggle แบบใหม่
local function createToggle(parent, name, prop)
    local btn = Instance.new("TextButton", parent)
    btn.Size = UDim2.new(0.95, 0, 0, 40); btn.BackgroundColor3 = settings[prop] and Color3.fromRGB(130, 60, 255) or Color3.fromRGB(35, 32, 48)
    btn.Text = "  " .. name; btn.TextColor3 = Color3.new(1,1,1); btn.Font = Enum.Font.GothamMedium
    btn.TextXAlignment = Enum.TextXAlignment.Left; btn.TextSize = 13; Instance.new("UICorner", btn)
    
    btn.MouseButton1Click:Connect(function()
        settings[prop] = not settings[prop]
        TweenService:Create(btn, TweenInfo.new(0.3), {BackgroundColor3 = settings[prop] and Color3.fromRGB(130, 60, 255) or Color3.fromRGB(35, 32, 48)}):Play()
    end)
end

