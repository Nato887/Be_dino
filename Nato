end

local startBtn = makeBtn("START", Color3.fromRGB(40,165,70), 10)
local stopBtn  = makeBtn("STOP",  Color3.fromRGB(180,60,60), 140)

local function setStatus(t)
    statusLbl.Text = "Status: "..t
end

-- 🔥 GOD LOOP
local function loop()
    while running do

        if busy then
            task.wait()
            continue
        end

        busy = true

        local foods = getManyFoods(30)

        if #foods > 0 then
            setStatus("⚡ GOD MAX FARMING")

            for _, food in ipairs(foods) do
                ultraWarp(food.position)
            end

        else
            setStatus("Searching safe zone...")
            task.wait(0.1)
        end

        busy = false
        task.wait()
    end

    setStatus("Stopped")
end

startBtn.MouseButton1Click:Connect(function()
    if running then return end
    running = true
    setStatus("Running")
    task.spawn(loop)
end)

stopBtn.MouseButton1Click:Connect(function()
    running = false
    setStatus("Stopped")
end)

setStatus("Idle")
