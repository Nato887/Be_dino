    local char = player.Character
    local root = char and char:FindFirstChild("HumanoidRootPart")
    if not root then return end

    -- 1. Anti Void
    if settings.AntiVoid and root.Position.Y < -40 then
        root.CFrame = root.CFrame * CFrame.new(0, 100, 0)
        root.Velocity = Vector3.new(0,0,0)
    end

    -- 2. Avoid Players (วาร์ปหนีตัวที่ใหญ่กว่า)
    if settings.AvoidPlayers then
        for _, p in ipairs(players:GetPlayers()) do
            if p ~= player and p.Character and p.Character:FindFirstChild("HumanoidRootPart") then
                local eRoot = p.Character.HumanoidRootPart
                if eRoot.Size.Magnitude > root.Size.Magnitude and (root.Position - eRoot.Position).Magnitude < 100 then
                    root.CFrame = root.CFrame * CFrame.new(0, 0, 10) -- ถอยหลังหนี
                    return
                end
            end
        end
    end

